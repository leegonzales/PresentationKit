{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DaWQbSy3HnNPLT3Gg91GmD","type":"tool_result","content":"     1→/**\n     2→ * Presentation Composition\n     3→ *\n     4→ * Main Remotion composition for rendering presentation videos.\n     5→ * Maps timeline data to slide sequences with synchronized audio and captions.\n     6→ */\n     7→\n     8→import React, { type FC, useMemo } from 'react';\n     9→import {\n    10→  AbsoluteFill,\n    11→  Audio,\n    12→  Sequence,\n    13→  useCurrentFrame,\n    14→  useVideoConfig,\n    15→  staticFile,\n    16→  interpolate,\n    17→} from 'remotion';\n    18→import type { PresentationProps, TimelineSlide } from './types.js';\n    19→import { DEFAULT_TRANSITION_DURATION } from './types.js';\n    20→import { Slide } from './components/Slide.js';\n    21→import { CaptionOverlay } from './components/CaptionOverlay.js';\n    22→import { SlideTransition } from './components/Transition.js';\n    23→\n    24→/**\n    25→ * Progress bar component showing presentation progress.\n    26→ */\n    27→interface ProgressBarProps {\n    28→  /** Current progress (0-1) */\n    29→  progress: number;\n    30→  /** Section color for the progress bar */\n    31→  sectionColor?: string;\n    32→}\n    33→\n    34→const ProgressBar: FC<ProgressBarProps> = ({ progress, sectionColor = '#ffffff' }) => {\n    35→  return (\n    36→    <div\n    37→      style={{\n    38→        position: 'absolute',\n    39→        bottom: 0,\n    40→        left: 0,\n    41→        width: '100%',\n    42→        height: 4,\n    43→        backgroundColor: 'rgba(255, 255, 255, 0.1)',\n    44→      }}\n    45→    >\n    46→      <div\n    47→        style={{\n    48→          height: '100%',\n    49→          width: `${progress * 100}%`,\n    50→          backgroundColor: sectionColor,\n    51→          boxShadow: `0 0 10px ${sectionColor}80`,\n    52→          transition: 'width 0.1s linear',\n    53→        }}\n    54→      />\n    55→    </div>\n    56→  );\n    57→};\n    58→\n    59→/**\n    60→ * Slide number indicator component.\n    61→ */\n    62→interface SlideIndicatorProps {\n    63→  /** Current slide number (1-indexed) */\n    64→  current: number;\n    65→  /** Total number of slides */\n    66→  total: number;\n    67→}\n    68→\n    69→const SlideIndicator: FC<SlideIndicatorProps> = ({ current, total }) => {\n    70→  return (\n    71→    <div\n    72→      style={{\n    73→        position: 'absolute',\n    74→        top: 20,\n    75→        right: 30,\n    76→        fontFamily: 'Inter, system-ui, sans-serif',\n    77→        fontSize: 18,\n    78→        color: 'rgba(255, 255, 255, 0.6)',\n    79→        backgroundColor: 'rgba(0, 0, 0, 0.5)',\n    80→        padding: '8px 16px',\n    81→        borderRadius: 6,\n    82→        fontWeight: 500,\n    83→      }}\n    84→    >\n    85→      {current} / {total}\n    86→    </div>\n    87→  );\n    88→};\n    89→\n    90→/**\n    91→ * Format seconds to MM:SS display format.\n    92→ */\n    93→const formatTime = (seconds: number): string => {\n    94→  const mins = Math.floor(seconds / 60);\n    95→  const secs = Math.floor(seconds % 60);\n    96→  return `${mins}:${secs.toString().padStart(2, '0')}`;\n    97→};\n    98→\n    99→/**\n   100→ * Time display component showing elapsed time.\n   101→ */\n   102→interface TimeDisplayProps {\n   103→  /** Current time in seconds */\n   104→  currentTime: number;\n   105→  /** Total duration in seconds */\n   106→  totalDuration: number;\n   107→}\n   108→\n   109→const TimeDisplay: FC<TimeDisplayProps> = ({ currentTime, totalDuration }) => {\n   110→  return (\n   111→    <div\n   112→      style={{\n   113→        position: 'absolute',\n   114→        bottom: 20,\n   115→        left: 30,\n   116→        fontFamily: 'Inter, system-ui, sans-serif',\n   117→        fontSize: 16,\n   118→        color: 'rgba(255, 255, 255, 0.6)',\n   119→        backgroundColor: 'rgba(0, 0, 0, 0.5)',\n   120→        padding: '6px 12px',\n   121→        borderRadius: 6,\n   122→        fontWeight: 500,\n   123→      }}\n   124→    >\n   125→      {formatTime(currentTime)} / {formatTime(totalDuration)}\n   126→    </div>\n   127→  );\n   128→};\n   129→\n   130→/**\n   131→ * Single slide sequence component.\n   132→ * Renders a slide with its captions and transition effects.\n   133→ */\n   134→interface SlideSequenceProps {\n   135→  /** Slide data from timeline */\n   136→  slide: TimelineSlide;\n   137→  /** Base path for assets */\n   138→  assetsPath: string;\n   139→  /** Duration of this slide in frames */\n   140→  durationInFrames: number;\n   141→  /** Slide index (0-based) */\n   142→  slideIndex: number;\n   143→  /** Total number of slides */\n   144→  totalSlides: number;\n   145→}\n   146→\n   147→const SlideSequence: FC<SlideSequenceProps> = ({\n   148→  slide,\n   149→  assetsPath,\n   150→  durationInFrames,\n   151→  slideIndex,\n   152→  totalSlides,\n   153→}) => {\n   154→  const frame = useCurrentFrame();\n   155→  const { fps } = useVideoConfig();\n   156→\n   157→  // Calculate current time relative to slide start (in seconds)\n   158→  const currentTime = frame / fps;\n   159→\n   160→  return (\n   161→    <AbsoluteFill>\n   162→      {/* Slide transition wrapper */}\n   163→      <SlideTransition\n   164→        durationInFrames={durationInFrames}\n   165→        type=\"fade\"\n   166→        transitionDuration={DEFAULT_TRANSITION_DURATION}\n   167→      >\n   168→        {/* Slide image with section indicator */}\n   169→        <Slide slide={slide} assetsPath={assetsPath} isActive={true} />\n   170→\n   171→        {/* Audio for this slide - use staticFile for relative paths, direct for absolute */}\n   172→        {slide.audioPath && (\n   173→          <Audio\n   174→            src={\n   175→              slide.audioPath.startsWith('/')\n   176→                ? slide.audioPath\n   177→                : staticFile(slide.audioPath)\n   178→            }\n   179→          />\n   180→        )}\n   181→\n   182→        {/* Caption overlay */}\n   183→        <CaptionOverlay\n   184→          captions={slide.captions}\n   185→          currentTime={currentTime}\n   186→          showWordHighlight={true}\n   187→        />\n   188→\n   189→        {/* Slide number indicator */}\n   190→        <SlideIndicator current={slideIndex + 1} total={totalSlides} />\n   191→      </SlideTransition>\n   192→    </AbsoluteFill>\n   193→  );\n   194→};\n   195→\n   196→/**\n   197→ * Main Presentation Composition\n   198→ *\n   199→ * Renders the complete presentation video by:\n   200→ * 1. Mapping timeline slides to Remotion sequences\n   201→ * 2. Handling audio playback synchronization\n   202→ * 3. Rendering captions over slides\n   203→ * 4. Managing slide transitions\n   204→ */\n   205→export const Presentation: FC<PresentationProps> = ({ timeline, assetsPath }) => {\n   206→  const frame = useCurrentFrame();\n   207→  const { fps, durationInFrames } = useVideoConfig();\n   208→\n   209→  // Current playback time in seconds\n   210→  const currentTime = frame / fps;\n   211→\n   212→  // Find the current slide based on time\n   213→  const currentSlide = useMemo(() => {\n   214→    return timeline.slides.find(\n   215→      (slide: TimelineSlide) => currentTime >= slide.startTime && currentTime < slide.endTime\n   216→    );\n   217→  }, [timeline.slides, currentTime]);\n   218→\n   219→  // Current slide index for progress calculation\n   220→  const currentSlideIndex = currentSlide\n   221→    ? timeline.slides.findIndex((s: TimelineSlide) => s.slug === currentSlide.slug)\n   222→    : 0;\n   223→\n   224→  // Calculate overall progress\n   225→  const progress = currentTime / timeline.totalDuration;\n   226→\n   227→  return (\n   228→    <AbsoluteFill style={{ backgroundColor: '#000' }}>\n   229→      {/* Render each slide as a Remotion Sequence */}\n   230→      {timeline.slides.map((slide: TimelineSlide, index: number) => {\n   231→        // Convert slide timing to frames\n   232→        const startFrame = Math.floor(slide.startTime * fps);\n   233→        const slideFrames = Math.floor(slide.duration * fps);\n   234→\n   235→        return (\n   236→          <Sequence\n   237→            key={slide.slug}\n   238→            from={startFrame}\n   239→            durationInFrames={slideFrames}\n   240→          >\n   241→            <SlideSequence\n   242→              slide={slide}\n   243→              assetsPath={assetsPath}\n   244→              durationInFrames={slideFrames}\n   245→              slideIndex={index}\n   246→              totalSlides={timeline.slides.length}\n   247→            />\n   248→          </Sequence>\n   249→        );\n   250→      })}\n   251→\n   252→      {/* Global progress bar */}\n   253→      <ProgressBar\n   254→        progress={progress}\n   255→        sectionColor={currentSlide?.sectionColor || '#ffffff'}\n   256→      />\n   257→\n   258→      {/* Time display */}\n   259→      <TimeDisplay\n   260→        currentTime={currentTime}\n   261→        totalDuration={timeline.totalDuration}\n   262→      />\n   263→    </AbsoluteFill>\n   264→  );\n   265→};\n   266→\n   267→/**\n   268→ * Presentation composition with concatenated audio track.\n   269→ *\n   270→ * Alternative composition that uses a single concatenated audio file\n   271→ * instead of per-slide audio. This is useful when slides have been\n   272→ * combined into a single audio track.\n   273→ */\n   274→interface PresentationWithAudioTrackProps extends PresentationProps {\n   275→  /** Path to the concatenated audio file */\n   276→  audioTrackPath: string;\n   277→}\n   278→\n   279→export const PresentationWithAudioTrack: FC<PresentationWithAudioTrackProps> = ({\n   280→  timeline,\n   281→  assetsPath,\n   282→  audioTrackPath,\n   283→}) => {\n   284→  const frame = useCurrentFrame();\n   285→  const { fps } = useVideoConfig();\n   286→\n   287→  const currentTime = frame / fps;\n   288→\n   289→  const currentSlide = useMemo(() => {\n   290→    return timeline.slides.find(\n   291→      (slide: TimelineSlide) => currentTime >= slide.startTime && currentTime < slide.endTime\n   292→    );\n   293→  }, [timeline.slides, currentTime]);\n   294→\n   295→  const progress = currentTime / timeline.totalDuration;\n   296→\n   297→  return (\n   298→    <AbsoluteFill style={{ backgroundColor: '#000' }}>\n   299→      {/* Single audio track for the entire presentation */}\n   300→      <Audio src={staticFile(audioTrackPath)} />\n   301→\n   302→      {/* Render slides without individual audio */}\n   303→      {timeline.slides.map((slide: TimelineSlide, index: number) => {\n   304→        const startFrame = Math.floor(slide.startTime * fps);\n   305→        const slideFrames = Math.floor(slide.duration * fps);\n   306→\n   307→        // Calculate caption time relative to absolute time, not slide start\n   308→        const captionCurrentTime = currentTime - slide.startTime;\n   309→\n   310→        return (\n   311→          <Sequence\n   312→            key={slide.slug}\n   313→            from={startFrame}\n   314→            durationInFrames={slideFrames}\n   315→          >\n   316→            <AbsoluteFill>\n   317→              <SlideTransition\n   318→                durationInFrames={slideFrames}\n   319→                type=\"fade\"\n   320→                transitionDuration={DEFAULT_TRANSITION_DURATION}\n   321→              >\n   322→                <Slide slide={slide} assetsPath={assetsPath} isActive={true} />\n   323→\n   324→                {/* Captions use slide-relative time for proper synchronization */}\n   325→                <CaptionOverlay\n   326→                  captions={slide.captions}\n   327→                  currentTime={Math.max(0, captionCurrentTime)}\n   328→                  showWordHighlight={true}\n   329→                />\n   330→\n   331→                <SlideIndicator current={index + 1} total={timeline.slides.length} />\n   332→              </SlideTransition>\n   333→            </AbsoluteFill>\n   334→          </Sequence>\n   335→        );\n   336→      })}\n   337→\n   338→      <ProgressBar\n   339→        progress={progress}\n   340→        sectionColor={currentSlide?.sectionColor || '#ffffff'}\n   341→      />\n   342→\n   343→      <TimeDisplay\n   344→        currentTime={currentTime}\n   345→        totalDuration={timeline.totalDuration}\n   346→      />\n   347→    </AbsoluteFill>\n   348→  );\n   349→};\n   350→\n   351→export default Presentation;\n   352→"}]},"parent_tool_use_id":"toolu_01XA55g9NLmhU434Jouh7cmK","session_id":"f896ae46-0735-4a4a-b213-fcf63f97824a","uuid":"af1c345c-a483-4112-9e56-26b9dec11d6c"}
