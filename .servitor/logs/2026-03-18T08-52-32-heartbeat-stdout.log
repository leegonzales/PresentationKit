{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PGXYDZQVuauaPnL4kRe7ki","type":"tool_result","content":"  1310→            slideCount: ${section.slideCount}\n  1311→        }`;\n  1312→  });\n  1313→\n  1314→  return `[\\n${sectionEntries.join(',\\n')}\\n        ]`;\n  1315→}\n  1316→\n  1317→/**\n  1318→ * Generates embedded JavaScript for presentation interactivity.\n  1319→ */\n  1320→function generateScript(\n  1321→  slides: PreparedHtmlSlide[],\n  1322→  sections: SectionInfo[],\n  1323→  metadata: PreparedHtmlMetadata,\n  1324→  options: Required<HtmlOptions>,\n  1325→): string {\n  1326→  const hasAudio = slides.some((s) => s.audioPath !== null);\n  1327→  const hasMultiVoice = slides.some((s) => s.voiceAudio && s.voiceAudio.length > 0);\n  1328→\n  1329→  // Get voice names from the first slide with voice audio\n  1330→  const voiceNames: string[] = [];\n  1331→  if (hasMultiVoice) {\n  1332→    const slideWithVoices = slides.find((s) => s.voiceAudio && s.voiceAudio.length > 0);\n  1333→    if (slideWithVoices?.voiceAudio) {\n  1334→      voiceNames.push(...slideWithVoices.voiceAudio.map((v) => v.name));\n  1335→    }\n  1336→  }\n  1337→\n  1338→  return `\n  1339→        // Presentation Data"}]},"parent_tool_use_id":"toolu_01XA55g9NLmhU434Jouh7cmK","session_id":"f896ae46-0735-4a4a-b213-fcf63f97824a","uuid":"69cd2935-f236-4701-a870-8822a5890963"}
