{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QWtDAVRmSd1PeotKT8swWW","type":"tool_result","content":"     1→/**\n     2→ * Orchestrator\n     3→ *\n     4→ * Main entry point for the presentation build pipeline.\n     5→ * Coordinates parsing, audio generation, timeline building, and rendering.\n     6→ */\n     7→\n     8→import { createHash } from 'node:crypto';\n     9→import { readFile, writeFile, mkdir } from 'node:fs/promises';\n    10→import { join, resolve, dirname, isAbsolute, relative } from 'node:path';\n    11→import { nanoid } from 'nanoid';\n    12→\n    13→// Asset copier for handling images\n    14→import { copyAssets, resolveImagePath } from '../utils/asset-copier.js';\n    15→\n    16→import type {\n    17→  BuildManifest,\n    18→  BuildOptions,\n    19→  BuildState,\n    20→} from './types.js';\n    21→import { BuildStateMachine } from './state-machine.js';\n    22→import { CostTracker, aggregateCosts, formatCostSummary } from './cost-tracker.js';\n    23→\n    24→// Parser imports\n    25→import { parseTalkTrack } from '../parsers/talk-track.js';\n    26→import type { TalkTrackV5 } from '../parsers/types.js';\n    27→\n    28→// Audio generator imports\n    29→import { generateKokoroAudio } from '../generators/audio/kokoro.js';\n    30→import type { AudioManifest as KokoroAudioManifest } from '../generators/audio/types.js';\n    31→\n    32→// Timeline builder imports\n    33→import { buildTimeline } from '../generators/timeline/index.js';\n    34→import type { Timeline, AudioManifest as TimelineAudioManifest, AudioManifestEntry } from '../generators/timeline/types.js';\n    35→\n    36→// Renderer imports\n    37→import { renderHtmlPresentation } from '../renderers/html/index.js';\n    38→import { renderSpeakerNotes } from '../renderers/notes/index.js';\n    39→import { renderVideo } from '../renderers/remotion/renderer.js';\n    40→\n    41→// Re-export types and utilities\n    42→export * from './types.js';\n    43→export { BuildStateMachine } from './state-machine.js';\n    44→export { CostTracker, aggregateCosts, formatCostSummary } from './cost-tracker.js';\n    45→export type { CostSummary } from './cost-tracker.js';\n    46→\n    47→// -----------------------------------------------------------------------------\n    48→// Serialization Helpers\n    49→// -----------------------------------------------------------------------------\n    50→\n    51→/**\n    52→ * Serializes a TalkTrackV5 object for JSON storage.\n    53→ * Converts the slideContent Map to a plain object.\n    54→ */\n    55→function serializeTalkTrack(talkTrack: TalkTrackV5): object {\n    56→  return {\n    57→    ...talkTrack,\n    58→    slideContent: Object.fromEntries(talkTrack.slideContent),\n    59→  };\n    60→}\n    61→\n    62→/**\n    63→ * Deserializes a TalkTrackV5 object from JSON.\n    64→ * Converts the slideContent object back to a Map.\n    65→ */\n    66→function deserializeTalkTrack(json: unknown): TalkTrackV5 {\n    67→  const obj = json as Omit<TalkTrackV5, 'slideContent'> & {\n    68→    slideContent: Record<string, TalkTrackV5['slideContent'] extends Map<string, infer V> ? V : never>;\n    69→  };\n    70→  return {\n    71→    ...obj,\n    72→    slideContent: new Map(Object.entries(obj.slideContent)),\n    73→  } as TalkTrackV5;\n    74→}\n    75→\n    76→/**\n    77→ * Converts an absolute audio path to a relative path.\n    78→ * e.g., /Users/.../output/audio/title.wav -> audio/title.wav\n    79→ *\n    80→ * Uses Node.js path functions for cross-platform compatibility.\n    81→ */\n    82→function normalizeAudioPath(audioPath: string, outputDir: string): string {\n    83→  if (!audioPath) {\n    84→    return audioPath;\n    85→  }\n    86→\n    87→  // If already relative, return as-is\n    88→  if (!isAbsolute(audioPath)) {\n    89→    return audioPath;\n    90→  }\n    91→\n    92→  // Use path.relative for cross-platform path resolution\n    93→  const absoluteOutputDir = resolve(outputDir);\n    94→  const relPath = relative(absoluteOutputDir, audioPath);\n    95→\n    96→  // Only accept paths that are inside the output directory (no .. prefix)\n    97→  if (!relPath.startsWith('..') && !isAbsolute(relPath)) {\n    98→    // Normalize to forward slashes for consistency across platforms\n    99→    return relPath.replace(/\\\\/g, '/');\n   100→  }\n   101→\n   102→  // If path cannot be made relative to the output directory, log a warning and return as-is\n   103→  // This helps identify unexpected path structures during debugging\n   104→  console.warn(`Warning: Audio path \"${audioPath}\" is not relative to output directory \"${outputDir}\"`);\n   105→  return audioPath;\n   106→}\n   107→\n   108→/**\n   109→ * Converts Kokoro AudioManifest format to Timeline AudioManifest format.\n   110→ * The timeline builder expects a different structure than what Kokoro produces.\n   111→ * Also normalizes absolute audio paths to relative paths.\n   112→ */\n   113→function convertToTimelineAudioManifest(\n   114→  kokoroManifest: KokoroAudioManifest,\n   115→  voice: string,\n   116→  outputDir: string,\n   117→): TimelineAudioManifest {\n   118→  const entries = new Map<string, AudioManifestEntry>();\n   119→\n   120→  for (const slide of kokoroManifest.slides) {\n   121→    entries.set(slide.slideSlug, {\n   122→      slug: slide.slideSlug,\n   123→      path: normalizeAudioPath(slide.audioPath, outputDir),\n   124→      duration: slide.durationSecs,\n   125→      provider: 'kokoro',\n   126→    });\n   127→  }\n   128→\n   129→  return {\n   130→    voice,\n   131→    provider: 'kokoro',\n   132→    entries,\n   133→  };\n   134→}\n   135→\n   136→/**\n   137→ * Build a presentation from a talk track file.\n   138→ *\n   139→ * @param talkTrackPath - Path to the talk track markdown file\n   140→ * @param options - Build options including outputs, audio provider, voice, etc.\n   141→ * @returns The build manifest with paths to generated outputs\n   142→ *\n   143→ * @example\n   144→ * ```typescript\n   145→ * const manifest = await buildPresentation('./talk-track.md', {\n   146→ *   outputs: ['html', 'video', 'notes'],\n   147→ *   audioProvider: 'kokoro',\n   148→ *   voice: 'af_bella',\n   149→ *   outputDir: './output',\n   150→ *   onProgress: (state, progress, message) => {\n   151→ *     console.log(`[${progress}%] ${message}`);\n   152→ *   },\n   153→ * });\n   154→ * ```\n   155→ */\n   156→export async function buildPresentation(\n   157→  talkTrackPath: string,\n   158→  options: BuildOptions\n   159→): Promise<BuildManifest> {\n   160→  // Resolve paths\n   161→  const absoluteTalkTrackPath = resolve(talkTrackPath);\n   162→  const absoluteOutputDir = resolve(options.outputDir);\n   163→\n   164→  // Ensure output directory exists\n   165→  await mkdir(absoluteOutputDir, { recursive: true });\n   166→\n   167→  // Read source file and compute hash\n   168→  const sourceContent = await readFile(absoluteTalkTrackPath, 'utf-8');\n   169→  const sourceHash = createHash('sha256').update(sourceContent).digest('hex').slice(0, 16);\n   170→\n   171→  // Create initial manifest\n   172→  const manifest: BuildManifest = {\n   173→    id: nanoid(),\n   174→    createdAt: new Date().toISOString(),\n   175→    source: {\n   176→      talkTrack: absoluteTalkTrackPath,\n   177→      sourceDir: dirname(absoluteTalkTrackPath),\n   178→      hash: sourceHash,\n   179→    },\n   180→    outputs: {},\n   181→    assets: {\n   182→      audio: [],\n   183→      images: [],\n   184→    },\n   185→    costs: [],\n   186→    state: 'init',\n   187→    audioProvider: options.audioProvider,\n   188→    voice: options.voice,\n   189→    requestedOutputs: options.outputs,\n   190→    videoQuality: options.videoQuality,\n   191→  };\n   192→\n   193→  // Create state machine\n   194→  const stateMachine = new BuildStateMachine(manifest, absoluteOutputDir);\n   195→\n   196→  // Set progress callback if provided\n   197→  if (options.onProgress) {\n   198→    stateMachine.setProgressCallback(options.onProgress);\n   199→  }\n   200→\n   201→  // Create cost tracker\n   202→  const costTracker = new CostTracker(stateMachine);\n   203→\n   204→  // Run the build pipeline\n   205→  return runBuildPipeline(stateMachine, costTracker, absoluteOutputDir);\n   206→}\n   207→\n   208→/**\n   209→ * Resume a build from an existing manifest.\n   210→ *\n   211→ * @param manifestPath - Path to the manifest.json file\n   212→ * @returns The updated build manifest\n   213→ *\n   214→ * @example\n   215→ * ```typescript\n   216→ * const manifest = await resumeBuild('./output/manifest.json');\n   217→ * ```\n   218→ */\n   219→export async function resumeBuild(\n   220→  manifestPath: string\n   221→): Promise<BuildManifest> {\n   222→  const absoluteManifestPath = resolve(manifestPath);\n   223→  const outputDir = dirname(absoluteManifestPath);\n   224→\n   225→  // Load existing state machine\n   226→  const stateMachine = await BuildStateMachine.fromManifestPath(absoluteManifestPath);\n   227→  const costTracker = new CostTracker(stateMachine);\n   228→\n   229→  // Check if we can resume\n   230→  const resumeState = stateMachine.getResumeState();\n   231→  if (!resumeState) {\n   232→    throw new Error(\n   233→      `Cannot resume build from state: ${stateMachine.getState()}. ` +\n   234→      'Build may already be complete or in a non-resumable state.'\n   235→    );\n   236→  }\n   237→\n   238→  // Run the build pipeline from the resume point\n   239→  return runBuildPipeline(stateMachine, costTracker, outputDir);\n   240→}\n   241→\n   242→/**\n   243→ * Run the build pipeline from the current state.\n   244→ * Internal function used by both buildPresentation and resumeBuild.\n   245→ */\n   246→async function runBuildPipeline(\n   247→  stateMachine: BuildStateMachine,\n   248→  costTracker: CostTracker,\n   249→  outputDir: string\n   250→): Promise<BuildManifest> {\n   251→  try {\n   252→    // Determine starting state\n   253→    const currentState = stateMachine.getState();\n   254→    const resumeState = stateMachine.getResumeState();\n   255→\n   256→    // If we're resuming from a failed state, go back to the resume point\n   257→    if (currentState === 'failed' && resumeState) {\n   258→      // Reset to resume state (this is handled by starting from the appropriate step)\n   259→    }\n   260→\n   261→    // Execute pipeline stages\n   262→    await executePipelineStages(stateMachine, costTracker, outputDir);\n   263→\n   264→    return stateMachine.getManifest();\n   265→  } catch (error) {\n   266→    const errorMessage = error instanceof Error ? error.message : String(error);\n   267→    await stateMachine.fail(errorMessage);\n   268→    throw error;\n   269→  }\n   270→}\n   271→\n   272→/**\n   273→ * Execute pipeline stages based on current state.\n   274→ */\n   275→async function executePipelineStages(\n   276→  stateMachine: BuildStateMachine,\n   277→  costTracker: CostTracker,\n   278→  outputDir: string\n   279→): Promise<void> {\n   280→  const manifest = stateMachine.getManifest();\n   281→  let currentState = manifest.state;\n   282→\n   283→  // If failed, try to resume from last successful state\n   284→  if (currentState === 'failed' && manifest.lastSuccessfulState) {\n   285→    currentState = manifest.lastSuccessfulState;\n   286→  }\n   287→\n   288→  // State: init -> parsing\n   289→  if (currentState === 'init') {\n   290→    await stateMachine.transitionTo('parsing');\n   291→    await executeParsing(stateMachine, outputDir);\n   292→    currentState = 'parsing';\n   293→  }\n   294→\n   295→  // State: parsing -> generating_audio\n   296→  if (currentState === 'parsing') {\n   297→    await stateMachine.transitionTo('generating_audio');\n   298→    await executeAudioGeneration(stateMachine, costTracker, outputDir);\n   299→    currentState = 'generating_audio';\n   300→  }\n   301→\n   302→  // State: generating_audio -> building_timeline\n   303→  if (currentState === 'generating_audio') {\n   304→    await stateMachine.transitionTo('building_timeline');\n   305→    await executeTimelineBuilding(stateMachine, outputDir);\n   306→    currentState = 'building_timeline';\n   307→  }\n   308→\n   309→  // Determine next state based on requested outputs\n   310→  const nextState = stateMachine.getNextState();\n   311→\n   312→  // State: building_timeline -> rendering_*\n   313→  if (currentState === 'building_timeline' && nextState) {\n   314→    await executeRenderingStages(stateMachine, costTracker, outputDir);\n   315→  }\n   316→\n   317→  // Mark complete if not already\n   318→  if (stateMachine.getState() !== 'complete' && stateMachine.getState() !== 'failed') {\n   319→    await stateMachine.transitionTo('complete');\n   320→  }\n   321→}\n   322→\n   323→/**\n   324→ * Execute parsing stage.\n   325→ * Parses the talk track markdown, copies assets, and persists the result for resumption.\n   326→ */\n   327→async function executeParsing(\n   328→  stateMachine: BuildStateMachine,\n   329→  outputDir: string\n   330→): Promise<void> {\n   331→  const manifest = stateMachine.getManifest();\n   332→  const sourceDir = manifest.source.sourceDir;\n   333→\n   334→  // Read and parse the talk track\n   335→  const sourceContent = await readFile(manifest.source.talkTrack, 'utf-8');\n   336→  const talkTrack = parseTalkTrack(sourceContent);\n   337→\n   338→  // Extract image paths from slide content\n   339→  const imagePaths = Array.from(talkTrack.slideContent.values())\n   340→    .map((sc) => sc.imagePath)\n   341→    .filter((p): p is string => !!p);\n   342→\n   343→  // Copy images from source directory to output directory\n   344→  console.log(`Copying ${imagePaths.length} images from ${sourceDir} to ${outputDir}/images/`);\n   345→  const copyResult = await copyAssets(imagePaths, sourceDir, outputDir);\n   346→\n   347→  if (copyResult.warnings.length > 0) {\n   348→    console.warn('Asset copy warnings:');\n   349→    copyResult.warnings.forEach((w) => console.warn(`  - ${w}`));\n   350→  }\n   351→  console.log(`Copied ${copyResult.imagesCopied} images`);\n   352→\n   353→  // Update talkTrack slideContent with new image paths\n   354→  for (const [slug, content] of talkTrack.slideContent) {\n   355→    if (content.imagePath) {\n   356→      const newPath = copyResult.pathMapping.get(content.imagePath);\n   357→      if (newPath) {\n   358→        content.imagePath = newPath;\n   359→      }\n   360→    }\n   361→  }\n   362→\n   363→  // Persist parsed data for resumption (with updated image paths)\n   364→  const talkTrackPath = join(outputDir, 'talktrack.json');\n   365→  await writeFile(talkTrackPath, JSON.stringify(serializeTalkTrack(talkTrack), null, 2));\n   366→\n   367→  // Update manifest with copied image paths\n   368→  const copiedImagePaths = Array.from(copyResult.pathMapping.values());\n   369→  await stateMachine.updateAssets({ images: copiedImagePaths });\n   370→}\n   371→\n   372→/**\n   373→ * Execute audio generation stage.\n   374→ * Generates audio using the configured TTS provider and persists the manifest.\n   375→ */\n   376→async function executeAudioGeneration(\n   377→  stateMachine: BuildStateMachine,\n   378→  costTracker: CostTracker,\n   379→  outputDir: string\n   380→): Promise<void> {\n   381→  const manifest = stateMachine.getManifest();\n   382→  const audioDir = join(outputDir, 'audio');\n   383→  await mkdir(audioDir, { recursive: true });\n   384→\n   385→  // Load parsed talk track\n   386→  const talkTrackPath = join(outputDir, 'talktrack.json');\n   387→  const talkTrackJson = JSON.parse(await readFile(talkTrackPath, 'utf-8'));\n   388→  const talkTrack = deserializeTalkTrack(talkTrackJson);\n   389→\n   390→  // Get slides array from the slideContent Map\n   391→  const slides = Array.from(talkTrack.slideContent.values());\n   392→\n   393→  // Generate audio based on provider\n   394→  let kokoroManifest: KokoroAudioManifest;\n   395→\n   396→  if (manifest.audioProvider === 'kokoro') {\n   397→    kokoroManifest = await generateKokoroAudio(slides, {\n   398→      outputDir: audioDir,\n   399→      voice: manifest.voice,\n   400→    });\n   401→    costTracker.trackKokoroUsage(kokoroManifest.totalCharacters, 'TTS generation');\n   402→  } else {\n   403→    // ElevenLabs path (future implementation)\n   404→    throw new Error('ElevenLabs audio provider not yet implemented');\n   405→  }\n   406→\n   407→  // Persist audio manifest (Kokoro format for storage)\n   408→  const audioManifestPath = join(outputDir, 'audio-manifest.json');\n   409→  await writeFile(audioManifestPath, JSON.stringify(kokoroManifest, null, 2));\n   410→\n   411→  // Update manifest with audio paths\n   412→  const audioPaths = kokoroManifest.slides\n   413→    .map((s) => s.audioPath)\n   414→    .filter((p): p is string => !!p && p.length > 0);\n   415→  await stateMachine.updateAssets({ audio: audioPaths });\n   416→}\n   417→\n   418→/**\n   419→ * Execute timeline building stage.\n   420→ * Builds a synchronized timeline from talk track and audio manifest.\n   421→ */\n   422→async function executeTimelineBuilding(\n   423→  stateMachine: BuildStateMachine,\n   424→  outputDir: string\n   425→): Promise<void> {\n   426→  const manifest = stateMachine.getManifest();\n   427→\n   428→  // Load parsed data\n   429→  const talkTrackPath = join(outputDir, 'talktrack.json');\n   430→  const audioManifestPath = join(outputDir, 'audio-manifest.json');\n   431→\n   432→  const talkTrackJson = JSON.parse(await readFile(talkTrackPath, 'utf-8'));\n   433→  const talkTrack = deserializeTalkTrack(talkTrackJson);\n   434→\n   435→  const kokoroManifest: KokoroAudioManifest = JSON.parse(\n   436→    await readFile(audioManifestPath, 'utf-8')\n   437→  );\n   438→\n   439→  // Convert Kokoro manifest to Timeline manifest format\n   440→  // Normalizes absolute audio paths to relative paths\n   441→  const timelineAudioManifest = convertToTimelineAudioManifest(\n   442→    kokoroManifest,\n   443→    manifest.voice,\n   444→    outputDir\n   445→  );\n   446→\n   447→  // Build timeline\n   448→  const timeline = buildTimeline(talkTrack, timelineAudioManifest);\n   449→\n   450→  // Persist timeline\n   451→  const timelinePath = join(outputDir, 'timeline.json');\n   452→  await writeFile(timelinePath, JSON.stringify(timeline, null, 2));\n   453→\n   454→  await stateMachine.updateOutputs({ timeline: timelinePath });\n   455→}\n   456→\n   457→/**\n   458→ * Execute rendering stages (html, video, notes).\n   459→ */\n   460→async function executeRenderingStages(\n   461→  stateMachine: BuildStateMachine,\n   462→  costTracker: CostTracker,\n   463→  outputDir: string\n   464→): Promise<void> {\n   465→  const manifest = stateMachine.getManifest();\n   466→\n   467→  // Render HTML if requested\n   468→  if (manifest.requestedOutputs.includes('html')) {\n   469→    if (stateMachine.canTransitionTo('rendering_html')) {\n   470→      await stateMachine.transitionTo('rendering_html');\n   471→      await executeHtmlRendering(stateMachine, outputDir);\n   472→    }\n   473→  }\n   474→\n   475→  // Render video if requested\n   476→  if (manifest.requestedOutputs.includes('video')) {\n   477→    if (stateMachine.canTransitionTo('rendering_video')) {\n   478→      await stateMachine.transitionTo('rendering_video');\n   479→      await executeVideoRendering(stateMachine, costTracker, outputDir);\n   480→    }\n   481→  }\n   482→\n   483→  // Render notes if requested\n   484→  if (manifest.requestedOutputs.includes('notes')) {\n   485→    if (stateMachine.canTransitionTo('rendering_notes')) {\n   486→      await stateMachine.transitionTo('rendering_notes');\n   487→      await executeNotesRendering(stateMachine, outputDir);\n   488→    }\n   489→  }\n   490→}\n   491→\n   492→/**\n   493→ * Execute HTML rendering stage.\n   494→ * Generates an interactive HTML presentation.\n   495→ */\n   496→async function executeHtmlRendering(\n   497→  stateMachine: BuildStateMachine,\n   498→  outputDir: string\n   499→): Promise<void> {\n   500→  // Load data\n   501→  const talkTrackPath = join(outputDir, 'talktrack.json');\n   502→  const timelinePath = join(outputDir, 'timeline.json');\n   503→\n   504→  const talkTrackJson = JSON.parse(await readFile(talkTrackPath, 'utf-8'));\n   505→  const talkTrack = deserializeTalkTrack(talkTrackJson);\n   506→\n   507→  const timeline: Timeline = JSON.parse(await readFile(timelinePath, 'utf-8'));\n   508→\n   509→  // Render HTML\n   510→  const htmlPath = join(outputDir, 'presentation.html');\n   511→  await renderHtmlPresentation(talkTrack, timeline, htmlPath, {\n   512→    primaryColor: talkTrack.branding?.primary,\n   513→  });\n   514→\n   515→  await stateMachine.updateOutputs({ html: htmlPath });\n   516→}\n   517→\n   518→/**\n   519→ * Execute video rendering stage.\n   520→ * Renders the presentation timeline to a video file using Remotion.\n   521→ */\n   522→async function executeVideoRendering(\n   523→  stateMachine: BuildStateMachine,\n   524→  costTracker: CostTracker,\n   525→  outputDir: string\n   526→): Promise<void> {\n   527→  const manifest = stateMachine.getManifest();\n   528→\n   529→  // Load timeline\n   530→  const timelinePath = join(outputDir, 'timeline.json');\n   531→  const timeline: Timeline = JSON.parse(await readFile(timelinePath, 'utf-8'));\n   532→\n   533→  // Render video\n   534→  const videoPath = join(outputDir, 'presentation.mp4');\n   535→  const startTime = Date.now();\n   536→\n   537→  await renderVideo(timeline, outputDir, {\n   538→    outputPath: videoPath,\n   539→    quality: manifest.videoQuality || '1080p',\n   540→    codec: 'h264',\n   541→    crf: 23,\n   542→  });\n   543→\n   544→  const renderSeconds = (Date.now() - startTime) / 1000;\n   545→  costTracker.trackRemotionRender(renderSeconds, 'Video rendering');\n   546→\n   547→  await stateMachine.updateOutputs({ video: videoPath });\n   548→}\n   549→\n   550→/**\n   551→ * Execute notes rendering stage.\n   552→ * Generates printable speaker notes HTML.\n   553→ */\n   554→async function executeNotesRendering(\n   555→  stateMachine: BuildStateMachine,\n   556→  outputDir: string\n   557→): Promise<void> {\n   558→  // Load talk track\n   559→  const talkTrackPath = join(outputDir, 'talktrack.json');\n   560→  const talkTrackJson = JSON.parse(await readFile(talkTrackPath, 'utf-8'));\n   561→  const talkTrack = deserializeTalkTrack(talkTrackJson);\n   562→\n   563→  // Render notes\n   564→  const notesPath = join(outputDir, 'speaker-notes.html');\n   565→  await renderSpeakerNotes(talkTrack, notesPath);\n   566→\n   567→  await stateMachine.updateOutputs({ notes: notesPath });\n   568→}\n   569→"}]},"parent_tool_use_id":"toolu_01XA55g9NLmhU434Jouh7cmK","session_id":"f896ae46-0735-4a4a-b213-fcf63f97824a","uuid":"729fd40e-5cfb-4dbe-bbea-0cad9f417a42"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01BAk6VGrebpCjmGkwquN5zm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01A6nM4S1pT35e3RgqEvmWnH","name":"Read","input":{"file_path":"/Users/leegonzales/Projects/leegonzales/PresentationKit/.worktrees/eslint-config/src/parsers/talk-track.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":483,"cache_read_input_tokens":50417,"cache_creation":{"ephemeral_5m_input_tokens":483,"ephemeral_1h_input_tokens":0},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01XA55g9NLmhU434Jouh7cmK","session_id":"f896ae46-0735-4a4a-b213-fcf63f97824a","uuid":"7fd3f1b8-5f63-428a-a414-76c316c249a9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A6nM4S1pT35e3RgqEvmWnH","type":"tool_result","content":"     1→/**\n     2→ * Talk Track v5 Parser\n     3→ *\n     4→ * Parses Talk Track v5 markdown files into structured data for\n     5→ * presentation and audio generation.\n     6→ */\n     7→\n     8→import YAML from 'yaml';\n     9→import { z } from 'zod';\n    10→import type {\n    11→  TalkTrackV5,\n    12→  Section,\n    13→  SlideDefinition,\n    14→  SlideContent,\n    15→  SemanticTag,\n    16→  SemanticTagType,\n    17→  BrandConfig,\n    18→  RawFrontmatter,\n    19→} from './types.js';\n    20→import {\n    21→  validateSlug,\n    22→  validateSection,\n    23→  validateImagePath,\n    24→  validateHexColor,\n    25→  findDuplicateSlugs,\n    26→} from './validators.js';\n    27→\n    28→// -----------------------------------------------------------------------------\n    29→// Zod Schemas\n    30→// -----------------------------------------------------------------------------\n    31→\n    32→const SectionSchema = z.object({\n    33→  id: z.string().min(1),\n    34→  name: z.string().min(1),\n    35→  color: z.string().regex(/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/, 'Invalid hex color'),\n    36→});\n    37→\n    38→const BrandConfigSchema = z.object({\n    39→  primary: z.string().optional(),\n    40→  background: z.string().optional(),\n    41→  text: z.string().optional(),\n    42→});\n    43→\n    44→const FrontmatterSchema = z.object({\n    45→  version: z.union([z.literal(5), z.literal(6)]),\n    46→  title: z.string().min(1),\n    47→  subtitle: z.string().optional(),\n    48→  author: z.string().min(1),\n    49→  event: z.string().optional(),\n    50→  date: z.string().optional(),\n    51→  target_minutes: z.number().int().positive(),\n    52→  audio_voice: z.string().default('af_heart'),\n    53→  branding: z.union([z.string(), BrandConfigSchema]).optional(),\n    54→  show_speakers: z.boolean().optional(),\n    55→  sections: z.array(SectionSchema).min(1),\n    56→});\n    57→\n    58→// -----------------------------------------------------------------------------\n    59→// Parser Error\n    60→// -----------------------------------------------------------------------------\n    61→\n    62→export class TalkTrackParseError extends Error {\n    63→  constructor(\n    64→    message: string,\n    65→    public readonly errors: string[] = [],\n    66→  ) {\n    67→    super(message);\n    68→    this.name = 'TalkTrackParseError';\n    69→  }\n    70→}\n    71→\n    72→// -----------------------------------------------------------------------------\n    73→// Frontmatter Parsing\n    74→// -----------------------------------------------------------------------------\n    75→\n    76→/**\n    77→ * Extracts and parses YAML frontmatter from markdown content.\n    78→ */\n    79→function parseFrontmatter(content: string): RawFrontmatter {\n    80→  const frontmatterMatch = content.match(/^---\\n([\\s\\S]*?)\\n---/);\n    81→  if (!frontmatterMatch) {\n    82→    throw new TalkTrackParseError('Missing YAML frontmatter (must start with ---)');\n    83→  }\n    84→\n    85→  const yamlContent = frontmatterMatch[1];\n    86→  let parsed: unknown;\n    87→\n    88→  try {\n    89→    parsed = YAML.parse(yamlContent);\n    90→  } catch (e) {\n    91→    const message = e instanceof Error ? e.message : 'Unknown error';\n    92→    throw new TalkTrackParseError(`Invalid YAML frontmatter: ${message}`);\n    93→  }\n    94→\n    95→  const result = FrontmatterSchema.safeParse(parsed);\n    96→  if (!result.success) {\n    97→    const errors = result.error.errors.map(\n    98→      (err) => `${err.path.join('.')}: ${err.message}`,\n    99→    );\n   100→    throw new TalkTrackParseError('Frontmatter validation failed', errors);\n   101→  }\n   102→\n   103→  return result.data as RawFrontmatter;\n   104→}\n   105→\n   106→// -----------------------------------------------------------------------------\n   107→// Slides Table Parsing\n   108→// -----------------------------------------------------------------------------\n   109→\n   110→/**\n   111→ * Parses the slides table from markdown content.\n   112→ */\n   113→function parseSlidesTable(content: string, sections: Section[]): SlideDefinition[] {\n   114→  // Find the ## Slides section\n   115→  const slidesMatch = content.match(/## Slides\\s*\\n\\n([\\s\\S]*?)(?=\\n## \\[|$)/);\n   116→  if (!slidesMatch) {\n   117→    throw new TalkTrackParseError('Missing ## Slides section');\n   118→  }\n   119→\n   120→  const tableContent = slidesMatch[1].trim();\n   121→  // Filter empty lines and markdown separators (---)\n   122→  const lines = tableContent.split('\\n').filter((line) => {\n   123→    const trimmed = line.trim();\n   124→    return trimmed && !trimmed.match(/^-{3,}$/);\n   125→  });\n   126→\n   127→  // Validate table structure\n   128→  if (lines.length < 3) {\n   129→    throw new TalkTrackParseError('Slides table must have header, separator, and at least one row');\n   130→  }\n   131→\n   132→  // Parse header to understand column order\n   133→  const headerLine = lines[0];\n   134→  const headers = headerLine\n   135→    .split('|')\n   136→    .map((h) => h.trim().toLowerCase())\n   137→    .filter((h) => h);\n   138→\n   139→  const expectedHeaders = ['#', 'slug', 'title', 'image', 'section'];\n   140→  const headerMap: Record<string, number> = {};\n   141→\n   142→  for (const expected of expectedHeaders) {\n   143→    const index = headers.findIndex((h) => h === expected || h.includes(expected));\n   144→    if (index === -1) {\n   145→      throw new TalkTrackParseError(`Slides table missing \"${expected}\" column`);\n   146→    }\n   147→    headerMap[expected] = index;\n   148→  }\n   149→\n   150→  // Skip header and separator lines\n   151→  const dataLines = lines.slice(2);\n   152→  const slides: SlideDefinition[] = [];\n   153→  const errors: string[] = [];\n   154→\n   155→  for (let i = 0; i < dataLines.length; i++) {\n   156→    const line = dataLines[i];\n   157→    const cells = line\n   158→      .split('|')\n   159→      .map((c) => c.trim())\n   160→      .filter((c, idx, arr) => idx > 0 && idx < arr.length - 1 || c);\n   161→\n   162→    // Handle edge case of leading/trailing pipes\n   163→    const values = line\n   164→      .split('|')\n   165→      .slice(1, -1)\n   166→      .map((c) => c.trim());\n   167→\n   168→    if (values.length < expectedHeaders.length) {\n   169→      errors.push(`Row ${i + 1}: Not enough columns (expected ${expectedHeaders.length})`);\n   170→      continue;\n   171→    }\n   172→\n   173→    const position = values[headerMap['#']];\n   174→    const slug = values[headerMap['slug']];\n   175→    const title = values[headerMap['title']];\n   176→    const image = values[headerMap['image']];\n   177→    const section = values[headerMap['section']];\n   178→\n   179→    // Validate fields\n   180→    if (!validateSlug(slug)) {\n   181→      errors.push(`Row ${i + 1}: Invalid slug \"${slug}\" (must be lowercase-kebab-case)`);\n   182→    }\n   183→\n   184→    if (!validateSection(section, sections)) {\n   185→      errors.push(`Row ${i + 1}: Unknown section \"${section}\"`);\n   186→    }\n   187→\n   188→    if (!validateImagePath(image)) {\n   189→      errors.push(`Row ${i + 1}: Invalid image path \"${image}\"`);\n   190→    }\n   191→\n   192→    // Normalize image path to ensure consistent images/ prefix\n   193→    const normalizedImage = normalizeImagePath(image);\n   194→    slides.push({ position, slug, title, image: normalizedImage, section });\n   195→  }\n   196→\n   197→  // Check for duplicate slugs\n   198→  const duplicates = findDuplicateSlugs(slides.map((s) => s.slug));\n   199→  if (duplicates.length > 0) {\n   200→    errors.push(`Duplicate slugs found: ${duplicates.join(', ')}`);\n   201→  }\n   202→\n   203→  if (errors.length > 0) {\n   204→    throw new TalkTrackParseError('Slides table validation failed', errors);\n   205→  }\n   206→\n   207→  return slides;\n   208→}\n   209→\n   210→// -----------------------------------------------------------------------------\n   211→// Semantic Tag Parsing\n   212→// -----------------------------------------------------------------------------\n   213→\n   214→const SEMANTIC_TAG_TYPES: SemanticTagType[] = [\n   215→  'HOOK',\n   216→  'KEY_POINT',\n   217→  'EVIDENCE',\n   218→  'STORY',\n   219→  'TRANSITION',\n   220→  'CALLBACK',\n   221→  'LANDING',\n   222→  'CTA',\n   223→  'PAUSE',\n   224→];\n   225→\n   226→/**\n   227→ * Parses semantic tags from audio text content.\n   228→ */\n   229→function parseSemanticTags(audioText: string): SemanticTag[] {\n   230→  const tags: SemanticTag[] = [];\n   231→\n   232→  // Match tags like [HOOK], [KEY_POINT], [PAUSE], [PAUSE:500]\n   233→  const tagPattern = /\\[(HOOK|KEY_POINT|EVIDENCE|STORY|TRANSITION|CALLBACK|LANDING|CTA|PAUSE)(?::(\\d+))?\\]/gi;\n   234→\n   235→  let match;\n   236→  while ((match = tagPattern.exec(audioText)) !== null) {\n   237→    const type = match[1].toUpperCase() as SemanticTagType;\n   238→    const duration = match[2] ? parseInt(match[2], 10) : undefined;\n   239→\n   240→    const tag: SemanticTag = { type };\n   241→\n   242→    if (type === 'PAUSE' && duration !== undefined) {\n   243→      tag.duration = duration;\n   244→    }\n   245→\n   246→    // For content tags, try to extract the following content\n   247→    if (type !== 'PAUSE') {\n   248→      const afterTag = audioText.slice(match.index + match[0].length);\n   249→      const contentMatch = afterTag.match(/^\\s*(.+?)(?=\\n\\n|\\[|$)/s);\n   250→      if (contentMatch) {\n   251→        tag.content = contentMatch[1].trim();\n   252→      }\n   253→    }\n   254→\n   255→    tags.push(tag);\n   256→  }\n   257→\n   258→  return tags;\n   259→}\n   260→\n   261→/**\n   262→ * Extracts speaker name from audio text.\n   263→ * Matches **[NAME]** or *[NAME]* at the start of audio text.\n   264→ */\n   265→export function parseSpeakerLabel(audioText: string): string | undefined {\n   266→  const match = audioText.match(/^\\s*\\*{1,2}\\[([A-Z_]+)\\]\\*{1,2}/);\n   267→  return match ? match[1] : undefined;\n   268→}\n   269→\n   270→/**\n   271→ * Strips speaker label from audio text for clean TTS input.\n   272→ */\n   273→export function stripSpeakerLabel(audioText: string): string {\n   274→  return audioText.replace(/^\\s*\\*{1,2}\\[([A-Z_]+)\\]\\*{1,2}\\s*/m, '').trim();\n   275→}\n   276→\n   277→/**\n   278→ * Strips semantic tags from audio text for clean TTS input.\n   279→ */\n   280→export function stripSemanticTags(audioText: string): string {\n   281→  return audioText\n   282→    .replace(/\\[(HOOK|KEY_POINT|EVIDENCE|STORY|TRANSITION|CALLBACK|LANDING|CTA|PAUSE)(?::\\d+)?\\]/gi, '')\n   283→    .replace(/\\n{3,}/g, '\\n\\n')\n   284→    .trim();\n   285→}\n   286→\n   287→// -----------------------------------------------------------------------------\n   288→// Image Path Normalization\n   289→// -----------------------------------------------------------------------------\n   290→\n   291→/**\n   292→ * Normalizes an image path to ensure consistent `images/` prefix.\n   293→ * Handles various input formats:\n   294→ *   - `slide.png` → `images/slide.png`\n   295→ *   - `images/slide.png` → `images/slide.png` (unchanged)\n   296→ *   - `./images/slide.png` → `images/slide.png`\n   297→ *   - `../assets/slide.png` → `../assets/slide.png` (external paths unchanged)\n   298→ */\n   299→function normalizeImagePath(imagePath: string): string {\n   300→  if (!imagePath) return imagePath;\n   301→\n   302→  // Already has images/ prefix\n   303→  if (imagePath.startsWith('images/')) {\n   304→    return imagePath;\n   305→  }\n   306→\n   307→  // Has ./images/ prefix - normalize\n   308→  if (imagePath.startsWith('./images/')) {\n   309→    return imagePath.slice(2); // Remove './'\n   310→  }\n   311→\n   312→  // External/relative paths (../, /, http://, etc.) - leave unchanged\n   313→  if (imagePath.startsWith('../') || imagePath.startsWith('/') || imagePath.includes('://')) {\n   314→    return imagePath;\n   315→  }\n   316→\n   317→  // Plain filename or other relative path - add images/ prefix\n   318→  return `images/${imagePath}`;\n   319→}\n   320→\n   321→// -----------------------------------------------------------------------------\n   322→// Slide Content Parsing\n   323→// -----------------------------------------------------------------------------\n   324→\n   325→/**\n   326→ * Parses individual slide content sections.\n   327→ */\n   328→function parseSlideContent(content: string, slides: SlideDefinition[]): Map<string, SlideContent> {\n   329→  const slideContent = new Map<string, SlideContent>();\n   330→  const errors: string[] = [];\n   331→\n   332→  // Match slide sections: ## [slug] Title\n   333→  const slidePattern = /## \\[([^\\]]+)\\] ([^\\n]+)\\n([\\s\\S]*?)(?=\\n## \\[|$)/g;\n   334→\n   335→  let match;\n   336→  while ((match = slidePattern.exec(content)) !== null) {\n   337→    const slug = match[1];\n   338→    const title = match[2].trim();\n   339→    const sectionContent = match[3];\n   340→\n   341→    // Check if slug exists in slides table\n   342→    // If not, silently skip (allows extra content sections like appendix)\n   343→    const slideDef = slides.find((s) => s.slug === slug);\n   344→    if (!slideDef) {\n   345→      // Lenient mode: skip content sections not in slides table\n   346→      continue;\n   347→    }\n   348→\n   349→    // Extract image and normalize path to ensure consistent images/ prefix\n   350→    const imageMatch = sectionContent.match(/!\\[.*?\\]\\((.*?)\\)/);\n   351→    const rawImagePath = imageMatch ? imageMatch[1] : slideDef.image;\n   352→    const imagePath = normalizeImagePath(rawImagePath);\n   353→\n   354→    // Extract audio block\n   355→    const audioMatch = sectionContent.match(/<!-- AUDIO -->\\n?([\\s\\S]*?)\\n?<!-- \\/AUDIO -->/);\n   356→    const rawAudioText = audioMatch ? audioMatch[1].trim() : '';\n   357→\n   358→    if (!audioMatch) {\n   359→      errors.push(`Slide \"${slug}\": Missing <!-- AUDIO --> block`);\n   360→    }\n   361→\n   362→    // Extract speaker label (e.g., **[JORDAN]**) before stripping\n   363→    const speaker = parseSpeakerLabel(rawAudioText);\n   364→    const audioText = speaker ? stripSpeakerLabel(rawAudioText) : rawAudioText;\n   365→\n   366→    // Extract speaker notes\n   367→    const notesMatch = sectionContent.match(/\\*\\*Speaker Notes:\\*\\*\\s*\\n?([\\s\\S]*?)(?=\\n---|\\n## |$)/);\n   368→    const speakerNotes = notesMatch ? notesMatch[1].trim() : undefined;\n   369→\n   370→    // Parse semantic tags\n   371→    const semanticTags = parseSemanticTags(audioText);\n   372→\n   373→    slideContent.set(slug, {\n   374→      slug,\n   375→      title,\n   376→      imagePath,\n   377→      audioText,\n   378→      speakerNotes,\n   379→      semanticTags,\n   380→      speaker,\n   381→    });\n   382→  }\n   383→\n   384→  // Check that all slides have content\n   385→  for (const slide of slides) {\n   386→    if (!slideContent.has(slide.slug)) {\n   387→      errors.push(`Missing content section for slide: \"${slide.slug}\"`);\n   388→    }\n   389→  }\n   390→\n   391→  if (errors.length > 0) {\n   392→    throw new TalkTrackParseError('Slide content validation failed', errors);\n   393→  }\n   394→\n   395→  return slideContent;\n   396→}\n   397→\n   398→// -----------------------------------------------------------------------------\n   399→// Branding Parsing\n   400→// -----------------------------------------------------------------------------\n   401→\n   402→/**\n   403→ * Parses branding configuration from frontmatter.\n   404→ */\n   405→function parseBranding(branding: string | BrandConfig | undefined): BrandConfig | undefined {\n   406→  if (!branding) {\n   407→    return undefined;\n   408→  }\n   409→\n   410→  if (typeof branding === 'string') {\n   411→    // String branding is a theme identifier - convert to config\n   412→    // This is a placeholder; actual theme mapping would be implemented elsewhere\n   413→    return { primary: branding };\n   414→  }\n   415→\n   416→  // Validate colors if present\n   417→  const errors: string[] = [];\n   418→  if (branding.primary && !validateHexColor(branding.primary)) {\n   419→    errors.push(`Invalid primary color: ${branding.primary}`);\n   420→  }\n   421→  if (branding.background && !validateHexColor(branding.background)) {\n   422→    errors.push(`Invalid background color: ${branding.background}`);\n   423→  }\n   424→  if (branding.text && !validateHexColor(branding.text)) {\n   425→    errors.push(`Invalid text color: ${branding.text}`);\n   426→  }\n   427→\n   428→  if (errors.length > 0) {\n   429→    throw new TalkTrackParseError('Branding validation failed', errors);\n   430→  }\n   431→\n   432→  return branding;\n   433→}\n   434→\n   435→// -----------------------------------------------------------------------------\n   436→// Main Parser\n   437→// -----------------------------------------------------------------------------\n   438→\n   439→/**\n   440→ * Parses a Talk Track v5 markdown document into structured data.\n   441→ *\n   442→ * @param content - The full markdown content of the talk track file\n   443→ * @returns Parsed TalkTrackV5 object\n   444→ * @throws TalkTrackParseError if parsing fails\n   445→ *\n   446→ * @example\n   447→ * ```typescript\n   448→ * import { parseTalkTrack } from './parsers/talk-track.js';\n   449→ * import { readFileSync } from 'fs';\n   450→ *\n   451→ * const content = readFileSync('talk-track.md', 'utf-8');\n   452→ * const talkTrack = parseTalkTrack(content);\n   453→ *\n   454→ * console.log(talkTrack.title);\n   455→ * console.log(talkTrack.slides.length);\n   456→ *\n   457→ * for (const [slug, slide] of talkTrack.slideContent) {\n   458→ *   console.log(`${slug}: ${slide.audioText.length} chars of audio`);\n   459→ * }\n   460→ * ```\n   461→ */\n   462→export function parseTalkTrack(content: string): TalkTrackV5 {\n   463→  // Step 1: Parse frontmatter\n   464→  const frontmatter = parseFrontmatter(content);\n   465→\n   466→  // Step 2: Parse slides table\n   467→  const slides = parseSlidesTable(content, frontmatter.sections);\n   468→\n   469→  // Step 3: Parse slide content\n   470→  const slideContent = parseSlideContent(content, slides);\n   471→\n   472→  // Step 4: Parse branding\n   473→  const branding = parseBranding(frontmatter.branding);\n   474→\n   475→  // Step 5: Construct final object\n   476→  const talkTrack: TalkTrackV5 = {\n   477→    version: 5,\n   478→    title: frontmatter.title,\n   479→    subtitle: frontmatter.subtitle,\n   480→    author: frontmatter.author,\n   481→    event: frontmatter.event,\n   482→    date: frontmatter.date,\n   483→    targetMinutes: frontmatter.target_minutes,\n   484→    audioVoice: frontmatter.audio_voice ?? 'af_heart',\n   485→    branding,\n   486→    showSpeakers: frontmatter.show_speakers,\n   487→    sections: frontmatter.sections,\n   488→    slides,\n   489→    slideContent,\n   490→  };\n   491→\n   492→  return talkTrack;\n   493→}\n   494→\n   495→/**\n   496→ * Safely parses a Talk Track v5 document, returning errors instead of throwing.\n   497→ *\n   498→ * @param content - The full markdown content\n   499→ * @returns Object with success flag, data, and errors\n   500→ */\n   501→export function safeParseTalkTrack(content: string): {\n   502→  success: boolean;\n   503→  data?: TalkTrackV5;\n   504→  errors?: string[];\n   505→} {\n   506→  try {\n   507→    const data = parseTalkTrack(content);\n   508→    return { success: true, data };\n   509→  } catch (e) {\n   510→    if (e instanceof TalkTrackParseError) {\n   511→      return {\n   512→        success: false,\n   513→        errors: e.errors.length > 0 ? e.errors : [e.message],\n   514→      };\n   515→    }\n   516→    const message = e instanceof Error ? e.message : 'Unknown error';\n   517→    return { success: false, errors: [message] };\n   518→  }\n   519→}\n   520→\n   521→/**\n   522→ * Extracts only the frontmatter from a Talk Track document.\n   523→ * Useful for quick metadata inspection without full parsing.\n   524→ */\n   525→export function extractFrontmatter(content: string): RawFrontmatter {\n   526→  return parseFrontmatter(content);\n   527→}\n   528→\n   529→/**\n   530→ * Validates a Talk Track document without fully parsing it.\n   531→ * Returns a list of validation errors.\n   532→ */\n   533→export function validateTalkTrack(content: string): string[] {\n   534→  const result = safeParseTalkTrack(content);\n   535→  return result.errors ?? [];\n   536→}\n   537→"}]},"parent_tool_use_id":"toolu_01XA55g9NLmhU434Jouh7cmK","session_id":"f896ae46-0735-4a4a-b213-fcf63f97824a","uuid":"229021b3-b6a3-488a-9e74-9036af0d752a"}
