{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016vvkTRXniWFE8PSBamDxDn","type":"tool_result","content":"     1→/**\n     2→ * Speaker Notes Renderer\n     3→ *\n     4→ * Generates printable speaker notes HTML from Talk Track v5 documents.\n     5→ * Output is a single HTML file optimized for printing to PDF or paper.\n     6→ *\n     7→ * Features:\n     8→ * - Cover page with presentation metadata\n     9→ * - Table of contents with section links\n    10→ * - One slide per page with thumbnail and talk track\n    11→ * - Timing estimates based on word count\n    12→ * - Print-friendly CSS with proper page breaks\n    13→ *\n    14→ * @example\n    15→ * ```typescript\n    16→ * import { renderSpeakerNotes } from './renderers/notes/index.js';\n    17→ * import { parseTalkTrack } from './parsers/talk-track.js';\n    18→ * import { readFileSync } from 'fs';\n    19→ *\n    20→ * const content = readFileSync('talk-track.md', 'utf-8');\n    21→ * const talkTrack = parseTalkTrack(content);\n    22→ *\n    23→ * await renderSpeakerNotes(talkTrack, './output/speaker-notes.html', {\n    24→ *   includeThumbnails: true,\n    25→ *   wordsPerMinute: 150,\n    26→ * });\n    27→ * ```\n    28→ */\n    29→\n    30→import { writeFile, mkdir } from 'fs/promises';\n    31→import { dirname } from 'path';\n    32→import type { TalkTrackV5, SlideDefinition } from '../../parsers/types.js';\n    33→import type { NotesOptions, PreparedSlide, PreparedMetadata } from './types.js';\n    34→import { DEFAULT_NOTES_OPTIONS } from './types.js';\n    35→import { generateSpeakerNotesHtml } from './template.js';\n    36→\n    37→// Re-export types for convenience\n    38→export type { NotesOptions, PreparedSlide, PreparedMetadata } from './types.js';\n    39→export { DEFAULT_NOTES_OPTIONS } from './types.js';\n    40→\n    41→/**\n    42→ * Strips semantic tags from audio text for clean display.\n    43→ * Removes tags like [HOOK], [KEY_POINT], [PAUSE:500], etc.\n    44→ */\n    45→function stripSemanticTags(audioText: string): string {\n    46→  return audioText\n    47→    .replace(/\\[(HOOK|KEY_POINT|EVIDENCE|STORY|TRANSITION|CALLBACK|LANDING|CTA|PAUSE)(?::\\d+)?\\]/gi, '')\n    48→    .replace(/\\n{3,}/g, '\\n\\n')\n    49→    .replace(/\\s+/g, ' ')\n    50→    .trim();\n    51→}\n    52→\n    53→/**\n    54→ * Calculates word count from text.\n    55→ */\n    56→function countWords(text: string): number {\n    57→  if (!text || text.trim().length === 0) {\n    58→    return 0;\n    59→  }\n    60→  return text.trim().split(/\\s+/).length;\n    61→}\n    62→\n    63→/**\n    64→ * Estimates speaking duration in seconds based on word count.\n    65→ *\n    66→ * @param wordCount - Number of words\n    67→ * @param wordsPerMinute - Speaking rate (default: 150)\n    68→ * @returns Duration in seconds\n    69→ */\n    70→function estimateDuration(wordCount: number, wordsPerMinute: number): number {\n    71→  return Math.round((wordCount / wordsPerMinute) * 60);\n    72→}\n    73→\n    74→/**\n    75→ * Formats a date string or Date object for display.\n    76→ *\n    77→ * @param date - ISO date string (YYYY-MM-DD) or undefined\n    78→ * @returns Formatted date string (e.g., \"January 19, 2026\")\n    79→ */\n    80→function formatDate(date?: string): string {\n    81→  if (!date) {\n    82→    return new Date().toLocaleDateString('en-US', {\n    83→      year: 'numeric',\n    84→      month: 'long',\n    85→      day: 'numeric',\n    86→    });\n    87→  }\n    88→\n    89→  try {\n    90→    const parsed = new Date(date + 'T00:00:00');\n    91→    return parsed.toLocaleDateString('en-US', {\n    92→      year: 'numeric',\n    93→      month: 'long',\n    94→      day: 'numeric',\n    95→    });\n    96→  } catch {\n    97→    return date;\n    98→  }\n    99→}\n   100→\n   101→/**\n   102→ * Prepares slide data for rendering.\n   103→ *\n   104→ * @param talkTrack - Parsed Talk Track v5 document\n   105→ * @param options - Rendering options\n   106→ * @returns Array of prepared slide data\n   107→ */\n   108→function prepareSlides(\n   109→  talkTrack: TalkTrackV5,\n   110→  options: Required<NotesOptions>,\n   111→): PreparedSlide[] {\n   112→  const slides: PreparedSlide[] = [];\n   113→\n   114→  for (const slideDef of talkTrack.slides) {\n   115→    const content = talkTrack.slideContent.get(slideDef.slug);\n   116→    if (!content) {\n   117→      continue;\n   118→    }\n   119→\n   120→    // Clean audio text\n   121→    const cleanedAudioText = stripSemanticTags(content.audioText);\n   122→    if (!cleanedAudioText) {\n   123→      continue;\n   124→    }\n   125→\n   126→    const wordCount = countWords(cleanedAudioText);\n   127→    const isAppendix = slideDef.section.toLowerCase() === 'appendix' ||\n   128→                       slideDef.position.toUpperCase().startsWith('A');\n   129→\n   130→    slides.push({\n   131→      position: slideDef.position,\n   132→      slug: slideDef.slug,\n   133→      title: slideDef.title,\n   134→      imagePath: slideDef.image,\n   135→      section: slideDef.section,\n   136→      audioText: cleanedAudioText,\n   137→      speakerNotes: content.speakerNotes,\n   138→      wordCount,\n   139→      estimatedDuration: estimateDuration(wordCount, options.wordsPerMinute),\n   140→      isAppendix,\n   141→    });\n   142→  }\n   143→\n   144→  return slides;\n   145→}\n   146→\n   147→/**\n   148→ * Prepares presentation metadata for rendering.\n   149→ *\n   150→ * @param talkTrack - Parsed Talk Track v5 document\n   151→ * @param slides - Prepared slide data\n   152→ * @returns Prepared metadata object\n   153→ */\n   154→function prepareMetadata(\n   155→  talkTrack: TalkTrackV5,\n   156→  slides: PreparedSlide[],\n   157→): PreparedMetadata {\n   158→  const totalWords = slides.reduce((sum, slide) => sum + slide.wordCount, 0);\n   159→  const totalDurationSeconds = slides.reduce((sum, slide) => sum + slide.estimatedDuration, 0);\n   160→\n   161→  return {\n   162→    title: talkTrack.title,\n   163→    subtitle: talkTrack.subtitle,\n   164→    author: talkTrack.author,\n   165→    event: talkTrack.event,\n   166→    dateFormatted: formatDate(talkTrack.date),\n   167→    totalSlides: slides.length,\n   168→    totalWords,\n   169→    totalDurationMinutes: Math.round(totalDurationSeconds / 60),\n   170→    generatedAt: new Date().toLocaleString('en-US', {\n   171→      year: 'numeric',\n   172→      month: 'long',\n   173→      day: 'numeric',\n   174→      hour: 'numeric',\n   175→      minute: '2-digit',\n   176→      hour12: true,\n   177→    }),\n   178→  };\n   179→}\n   180→\n   181→/**\n   182→ * Renders speaker notes HTML from a Talk Track v5 document.\n   183→ *\n   184→ * @param talkTrack - Parsed Talk Track v5 document\n   185→ * @param outputPath - Path to write the HTML file\n   186→ * @param options - Optional rendering configuration\n   187→ * @throws Error if writing fails\n   188→ *\n   189→ * @example\n   190→ * ```typescript\n   191→ * import { renderSpeakerNotes } from './renderers/notes/index.js';\n   192→ *\n   193→ * await renderSpeakerNotes(talkTrack, './output/speaker-notes.html');\n   194→ *\n   195→ * // With options\n   196→ * await renderSpeakerNotes(talkTrack, './output/notes.html', {\n   197→ *   includeThumbnails: false,\n   198→ *   wordsPerMinute: 140,\n   199→ *   primaryColor: '#2563eb',\n   200→ * });\n   201→ * ```\n   202→ */\n   203→export async function renderSpeakerNotes(\n   204→  talkTrack: TalkTrackV5,\n   205→  outputPath: string,\n   206→  options?: NotesOptions,\n   207→): Promise<void> {\n   208→  const opts: Required<NotesOptions> = { ...DEFAULT_NOTES_OPTIONS, ...options };\n   209→\n   210→  // Prepare data\n   211→  const slides = prepareSlides(talkTrack, opts);\n   212→  const metadata = prepareMetadata(talkTrack, slides);\n   213→\n   214→  // Generate HTML\n   215→  const html = generateSpeakerNotesHtml(metadata, slides, opts);\n   216→\n   217→  // Ensure output directory exists\n   218→  const outputDir = dirname(outputPath);\n   219→  await mkdir(outputDir, { recursive: true });\n   220→\n   221→  // Write file\n   222→  await writeFile(outputPath, html, 'utf-8');\n   223→}\n   224→\n   225→/**\n   226→ * Generates speaker notes HTML as a string without writing to disk.\n   227→ * Useful for preview or streaming scenarios.\n   228→ *\n   229→ * @param talkTrack - Parsed Talk Track v5 document\n   230→ * @param options - Optional rendering configuration\n   231→ * @returns HTML string\n   232→ */\n   233→export function renderSpeakerNotesToString(\n   234→  talkTrack: TalkTrackV5,\n   235→  options?: NotesOptions,\n   236→): string {\n   237→  const opts: Required<NotesOptions> = { ...DEFAULT_NOTES_OPTIONS, ...options };\n   238→\n   239→  const slides = prepareSlides(talkTrack, opts);\n   240→  const metadata = prepareMetadata(talkTrack, slides);\n   241→\n   242→  return generateSpeakerNotesHtml(metadata, slides, opts);\n   243→}\n   244→\n   245→/**\n   246→ * Gets summary statistics for speaker notes.\n   247→ * Useful for CLI output or validation.\n   248→ *\n   249→ * @param talkTrack - Parsed Talk Track v5 document\n   250→ * @param options - Optional rendering configuration\n   251→ * @returns Summary statistics\n   252→ */\n   253→export function getSpeakerNotesSummary(\n   254→  talkTrack: TalkTrackV5,\n   255→  options?: NotesOptions,\n   256→): {\n   257→  title: string;\n   258→  slideCount: number;\n   259→  mainSlideCount: number;\n   260→  appendixSlideCount: number;\n   261→  totalWords: number;\n   262→  estimatedMinutes: number;\n   263→  slidesWithNotes: number;\n   264→} {\n   265→  const opts: Required<NotesOptions> = { ...DEFAULT_NOTES_OPTIONS, ...options };\n   266→  const slides = prepareSlides(talkTrack, opts);\n   267→\n   268→  const mainSlides = slides.filter((s) => !s.isAppendix);\n   269→  const appendixSlides = slides.filter((s) => s.isAppendix);\n   270→  const slidesWithNotes = slides.filter((s) => s.speakerNotes).length;\n   271→  const totalWords = slides.reduce((sum, s) => sum + s.wordCount, 0);\n   272→  const totalSeconds = slides.reduce((sum, s) => sum + s.estimatedDuration, 0);\n   273→\n   274→  return {\n   275→    title: talkTrack.title,\n   276→    slideCount: slides.length,\n   277→    mainSlideCount: mainSlides.length,\n   278→    appendixSlideCount: appendixSlides.length,\n   279→    totalWords,\n   280→    estimatedMinutes: Math.round(totalSeconds / 60),\n   281→    slidesWithNotes,\n   282→  };\n   283→}\n   284→"}]},"parent_tool_use_id":"toolu_01XA55g9NLmhU434Jouh7cmK","session_id":"f896ae46-0735-4a4a-b213-fcf63f97824a","uuid":"85e7d564-9c7e-4799-afe4-8b6ce1ac7955"}
