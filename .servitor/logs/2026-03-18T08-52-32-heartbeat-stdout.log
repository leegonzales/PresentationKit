{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014Pgn9feQ3ymegiAYENjdLm","type":"tool_result","content":"     1→/**\n     2→ * Asset Copier\n     3→ *\n     4→ * Copies presentation assets (images) from source directories to the output\n     5→ * directory, resolving relative paths from the talk track location.\n     6→ */\n     7→\n     8→import { copyFile, mkdir, access, readdir, stat } from 'node:fs/promises';\n     9→import { join, dirname, basename, resolve, isAbsolute, extname } from 'node:path';\n    10→import { createHash } from 'node:crypto';\n    11→\n    12→/**\n    13→ * Result of copying assets.\n    14→ */\n    15→export interface AssetCopyResult {\n    16→  /** Number of images copied */\n    17→  imagesCopied: number;\n    18→  /** Mapping from original paths to new paths in output directory */\n    19→  pathMapping: Map<string, string>;\n    20→  /** Any errors encountered (non-fatal) */\n    21→  warnings: string[];\n    22→}\n    23→\n    24→/**\n    25→ * Options for asset copying.\n    26→ */\n    27→export interface AssetCopyOptions {\n    28→  /** Whether to overwrite existing files (default: true) */\n    29→  overwrite?: boolean;\n    30→}\n    31→\n    32→/**\n    33→ * Checks if a file exists.\n    34→ */\n    35→async function fileExists(path: string): Promise<boolean> {\n    36→  try {\n    37→    await access(path);\n    38→    return true;\n    39→  } catch {\n    40→    return false;\n    41→  }\n    42→}\n    43→\n    44→/**\n    45→ * Resolves an image path relative to the source directory.\n    46→ *\n    47→ * Handles various path formats:\n    48→ * - Relative paths: \"images/slide.png\" -> sourceDir/images/slide.png\n    49→ * - Absolute paths: \"/Users/.../slide.png\" -> as-is\n    50→ * - Paths with ./ prefix: \"./images/slide.png\" -> sourceDir/images/slide.png\n    51→ */\n    52→export function resolveImagePath(imagePath: string, sourceDir: string): string {\n    53→  if (isAbsolute(imagePath)) {\n    54→    return imagePath;\n    55→  }\n    56→\n    57→  // Remove ./ prefix if present\n    58→  const cleanPath = imagePath.startsWith('./') ? imagePath.slice(2) : imagePath;\n    59→\n    60→  return resolve(sourceDir, cleanPath);\n    61→}\n    62→\n    63→/**\n    64→ * Copies images from source locations to the output directory.\n    65→ *\n    66→ * @param imagePaths - Array of image paths (may be relative or absolute)\n    67→ * @param sourceDir - Directory containing the talk track (used to resolve relative paths)\n    68→ * @param outputDir - Destination directory (images go to outputDir/images/)\n    69→ * @param options - Copy options\n    70→ * @returns Result containing mapping of old paths to new paths\n    71→ *\n    72→ * @example\n    73→ * ```typescript\n    74→ * const result = await copyAssets(\n    75→ *   ['images/slide-01.png', 'images/slide-02.png'],\n    76→ *   '/path/to/talk-track-dir',\n    77→ *   '/path/to/output'\n    78→ * );\n    79→ *\n    80→ * // result.pathMapping: Map {\n    81→ * //   'images/slide-01.png' => 'images/slide-01.png',\n    82→ * //   'images/slide-02.png' => 'images/slide-02.png',\n    83→ * // }\n    84→ * ```\n    85→ */\n    86→export async function copyAssets(\n    87→  imagePaths: string[],\n    88→  sourceDir: string,\n    89→  outputDir: string,\n    90→  options: AssetCopyOptions = {}\n    91→): Promise<AssetCopyResult> {\n    92→  const { overwrite = true } = options;\n    93→\n    94→  const imagesOutputDir = join(outputDir, 'images');\n    95→  await mkdir(imagesOutputDir, { recursive: true });\n    96→\n    97→  const pathMapping = new Map<string, string>();\n    98→  const warnings: string[] = [];\n    99→  let imagesCopied = 0;\n   100→\n   101→  // Process unique paths only\n   102→  const uniquePaths = [...new Set(imagePaths)];\n   103→\n   104→  for (const imagePath of uniquePaths) {\n   105→    if (!imagePath) {\n   106→      continue;\n   107→    }\n   108→\n   109→    try {\n   110→      // Resolve the source file location\n   111→      const sourcePath = resolveImagePath(imagePath, sourceDir);\n   112→\n   113→      // Check if source exists\n   114→      if (!(await fileExists(sourcePath))) {\n   115→        warnings.push(`Image not found: ${sourcePath}`);\n   116→        continue;\n   117→      }\n   118→\n   119→      // Generate unique filename using hash of original path to prevent collisions\n   120→      // e.g., section-1/diagram.png and section-2/diagram.png get unique names\n   121→      const ext = extname(sourcePath);\n   122→      const originalFilename = basename(sourcePath, ext);\n   123→      const pathHash = createHash('md5').update(imagePath).digest('hex').slice(0, 8);\n   124→      const uniqueFilename = `${originalFilename}-${pathHash}${ext}`;\n   125→      const destPath = join(imagesOutputDir, uniqueFilename);\n   126→      const relativePath = `images/${uniqueFilename}`;\n   127→\n   128→      // Check if destination exists\n   129→      const destExists = await fileExists(destPath);\n   130→      if (destExists && !overwrite) {\n   131→        // Use existing file, still add to mapping\n   132→        pathMapping.set(imagePath, relativePath);\n   133→        continue;\n   134→      }\n   135→\n   136→      // Copy the file\n   137→      await copyFile(sourcePath, destPath);\n   138→      pathMapping.set(imagePath, relativePath);\n   139→      imagesCopied++;\n   140→    } catch (error) {\n   141→      const message = error instanceof Error ? error.message : String(error);\n   142→      warnings.push(`Failed to copy ${imagePath}: ${message}`);\n   143→    }\n   144→  }\n   145→\n   146→  return {\n   147→    imagesCopied,\n   148→    pathMapping,\n   149→    warnings,\n   150→  };\n   151→}\n   152→\n   153→/**\n   154→ * Copies all image files from a directory (non-recursive).\n   155→ *\n   156→ * Useful for copying an entire images folder.\n   157→ *\n   158→ * @param sourceImagesDir - Source images directory\n   159→ * @param outputDir - Destination output directory\n   160→ * @returns Result of the copy operation\n   161→ */\n   162→export async function copyImagesDirectory(\n   163→  sourceImagesDir: string,\n   164→  outputDir: string\n   165→): Promise<AssetCopyResult> {\n   166→  const warnings: string[] = [];\n   167→\n   168→  // Check if source directory exists\n   169→  if (!(await fileExists(sourceImagesDir))) {\n   170→    return {\n   171→      imagesCopied: 0,\n   172→      pathMapping: new Map(),\n   173→      warnings: [`Source directory not found: ${sourceImagesDir}`],\n   174→    };\n   175→  }\n   176→\n   177→  // List files in the directory\n   178→  const entries = await readdir(sourceImagesDir);\n   179→  const imageExtensions = ['.png', '.jpg', '.jpeg', '.gif', '.webp', '.svg'];\n   180→\n   181→  const imagePaths: string[] = [];\n   182→\n   183→  for (const entry of entries) {\n   184→    const ext = entry.toLowerCase().slice(entry.lastIndexOf('.'));\n   185→    if (imageExtensions.includes(ext)) {\n   186→      imagePaths.push(join(sourceImagesDir, entry));\n   187→    }\n   188→  }\n   189→\n   190→  // Use copyAssets with the source directory being the images directory\n   191→  return copyAssets(\n   192→    imagePaths.map((p) => basename(p)),\n   193→    sourceImagesDir,\n   194→    outputDir\n   195→  );\n   196→}\n   197→\n   198→/**\n   199→ * Updates image paths in a timeline to use the new relative paths.\n   200→ *\n   201→ * @param slides - Timeline slides with original image paths\n   202→ * @param pathMapping - Mapping from original to new paths\n   203→ * @returns Updated slides with new paths\n   204→ */\n   205→export function updateTimelinePaths<T extends { imagePath: string }>(\n   206→  slides: T[],\n   207→  pathMapping: Map<string, string>\n   208→): T[] {\n   209→  return slides.map((slide) => {\n   210→    const newPath = pathMapping.get(slide.imagePath);\n   211→    if (newPath) {\n   212→      return { ...slide, imagePath: newPath };\n   213→    }\n   214→    return slide;\n   215→  });\n   216→}\n   217→"}]},"parent_tool_use_id":"toolu_01XA55g9NLmhU434Jouh7cmK","session_id":"f896ae46-0735-4a4a-b213-fcf63f97824a","uuid":"ea0a6f9d-c8a8-4725-a88d-22f9cb988d30"}
