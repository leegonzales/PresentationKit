{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MSBxm9d4QhnYT3XWzQSzJ7","type":"tool_result","content":"     1→/**\n     2→ * ElevenLabs Audio Generator\n     3→ *\n     4→ * High-quality TTS synthesis with word-level timestamps for caption synchronization.\n     5→ * Uses the ElevenLabs API with eleven_multilingual_v2 model for precise alignment data.\n     6→ */\n     7→\n     8→import got, { type Got, HTTPError } from 'got';\n     9→import { writeFile, mkdir } from 'node:fs/promises';\n    10→import { join } from 'node:path';\n    11→import type { SlideContent } from '../../parsers/types.js';\n    12→import type {\n    13→  AudioGeneratorOptions,\n    14→  AudioManifestWithTimings,\n    15→  AudioResultWithTimings,\n    16→  WordTiming,\n    17→} from './types.js';\n    18→\n    19→/**\n    20→ * ElevenLabs-specific options.\n    21→ */\n    22→export interface ElevenLabsOptions extends AudioGeneratorOptions {\n    23→  /** ElevenLabs API key */\n    24→  apiKey: string;\n    25→  /** Voice ID to use for synthesis */\n    26→  voiceId: string;\n    27→  /** Model ID (default: eleven_multilingual_v2) */\n    28→  model?: string;\n    29→  /** Voice stability (0.0-1.0, default: 0.5) */\n    30→  stability?: number;\n    31→  /** Voice similarity boost (0.0-1.0, default: 0.75) */\n    32→  similarityBoost?: number;\n    33→  /** Voice style (0.0-1.0, default: 0.0) */\n    34→  style?: number;\n    35→  /** Enable speaker boost (default: true) */\n    36→  useSpeakerBoost?: boolean;\n    37→  /** Maximum characters per API call (default: 900) */\n    38→  maxChunkSize?: number;\n    39→  /** Maximum retry attempts (default: 3) */\n    40→  maxRetries?: number;\n    41→  /** Base delay for exponential backoff in ms (default: 1000) */\n    42→  retryDelay?: number;\n    43→}\n    44→\n    45→/**\n    46→ * ElevenLabs API response for text-to-speech with timestamps.\n    47→ */\n    48→interface ElevenLabsTimestampResponse {\n    49→  audio_base64: string;\n    50→  alignment: {\n    51→    characters: string[];\n    52→    character_start_times_seconds: number[];\n    53→    character_end_times_seconds: number[];\n    54→  };\n    55→}\n    56→\n    57→/**\n    58→ * Rate limit error for retry logic.\n    59→ */\n    60→class RateLimitError extends Error {\n    61→  retryAfter: number;\n    62→\n    63→  constructor(retryAfter: number) {\n    64→    super(`Rate limited. Retry after ${retryAfter}ms`);\n    65→    this.name = 'RateLimitError';\n    66→    this.retryAfter = retryAfter;\n    67→  }\n    68→}\n    69→\n    70→/**\n    71→ * Generate audio for all slides using ElevenLabs TTS.\n    72→ *\n    73→ * @param slides - Array of slide content to synthesize\n    74→ * @param options - ElevenLabs configuration options\n    75→ * @returns Audio manifest with paths, durations, and word timings\n    76→ */\n    77→export async function generateElevenLabsAudio(\n    78→  slides: SlideContent[],\n    79→  options: ElevenLabsOptions\n    80→): Promise<AudioManifestWithTimings> {\n    81→  const {\n    82→    apiKey,\n    83→    voiceId,\n    84→    outputDir,\n    85→    model = 'eleven_multilingual_v2',\n    86→    format = 'mp3',\n    87→    stability = 0.5,\n    88→    similarityBoost = 0.75,\n    89→    style = 0.0,\n    90→    useSpeakerBoost = true,\n    91→    maxChunkSize = 900,\n    92→    maxRetries = 3,\n    93→    retryDelay = 1000,\n    94→  } = options;\n    95→\n    96→  // Ensure output directory exists\n    97→  await mkdir(outputDir, { recursive: true });\n    98→\n    99→  // Create HTTP client with base configuration\n   100→  const client = got.extend({\n   101→    prefixUrl: 'https://api.elevenlabs.io/v1',\n   102→    headers: {\n   103→      'xi-api-key': apiKey,\n   104→      'Content-Type': 'application/json',\n   105→    },\n   106→    responseType: 'json',\n   107→    timeout: {\n   108→      request: 120000, // 2 minute timeout for long audio\n   109→    },\n   110→  });\n   111→\n   112→  const results: AudioResultWithTimings[] = [];\n   113→  let totalCharacters = 0;\n   114→  let totalDurationSecs = 0;\n   115→\n   116→  // Process each slide sequentially to respect rate limits\n   117→  for (const slide of slides) {\n   118→    if (!slide.audioText || slide.audioText.trim().length === 0) {\n   119→      // Skip slides with no audio content\n   120→      continue;\n   121→    }\n   122→\n   123→    const cleanText = cleanTextForSynthesis(slide.audioText);\n   124→    const characterCount = cleanText.length;\n   125→    totalCharacters += characterCount;\n   126→\n   127→    let audioBuffer: Buffer;\n   128→    let wordTimings: WordTiming[];\n   129→    let durationSecs: number;\n   130→\n   131→    if (cleanText.length <= maxChunkSize) {\n   132→      // Single chunk synthesis\n   133→      const result = await synthesizeWithRetry(\n   134→        client,\n   135→        voiceId,\n   136→        cleanText,\n   137→        {\n   138→          model,\n   139→          stability,\n   140→          similarityBoost,\n   141→          style,\n   142→          useSpeakerBoost,\n   143→        },\n   144→        maxRetries,\n   145→        retryDelay\n   146→      );\n   147→      audioBuffer = result.audioBuffer;\n   148→      wordTimings = result.wordTimings;\n   149→      durationSecs = result.durationSecs;\n   150→    } else {\n   151→      // Multi-chunk synthesis for long text\n   152→      const chunkedResult = await synthesizeChunkedText(\n   153→        client,\n   154→        voiceId,\n   155→        cleanText,\n   156→        {\n   157→          model,\n   158→          stability,\n   159→          similarityBoost,\n   160→          style,\n   161→          useSpeakerBoost,\n   162→          maxChunkSize,\n   163→          maxRetries,\n   164→          retryDelay,\n   165→        }\n   166→      );\n   167→      audioBuffer = chunkedResult.audioBuffer;\n   168→      wordTimings = chunkedResult.wordTimings;\n   169→      durationSecs = chunkedResult.durationSecs;\n   170→    }\n   171→\n   172→    // Write audio file\n   173→    const audioFilename = `${slide.slug}.${format}`;\n   174→    const audioPath = join(outputDir, audioFilename);\n   175→    await writeFile(audioPath, audioBuffer);\n   176→\n   177→    totalDurationSecs += durationSecs;\n   178→\n   179→    results.push({\n   180→      slideSlug: slide.slug,\n   181→      audioPath,\n   182→      durationSecs,\n   183→      characterCount,\n   184→      wordTimings,\n   185→    });\n   186→  }\n   187→\n   188→  return {\n   189→    totalDurationSecs,\n   190→    totalCharacters,\n   191→    slides: results,\n   192→  };\n   193→}\n   194→\n   195→/**\n   196→ * Synthesize text with automatic retry on rate limiting.\n   197→ */\n   198→async function synthesizeWithRetry(\n   199→  client: Got,\n   200→  voiceId: string,\n   201→  text: string,\n   202→  settings: {\n   203→    model: string;\n   204→    stability: number;\n   205→    similarityBoost: number;\n   206→    style: number;\n   207→    useSpeakerBoost: boolean;\n   208→  },\n   209→  maxRetries: number,\n   210→  baseDelay: number\n   211→): Promise<{\n   212→  audioBuffer: Buffer;\n   213→  wordTimings: WordTiming[];\n   214→  durationSecs: number;\n   215→}> {\n   216→  let lastError: Error | null = null;\n   217→\n   218→  for (let attempt = 0; attempt <= maxRetries; attempt++) {\n   219→    try {\n   220→      const response = await client.post<ElevenLabsTimestampResponse>(\n   221→        `text-to-speech/${voiceId}/with-timestamps`,\n   222→        {\n   223→          json: {\n   224→            text,\n   225→            model_id: settings.model,\n   226→            voice_settings: {\n   227→              stability: settings.stability,\n   228→              similarity_boost: settings.similarityBoost,\n   229→              style: settings.style,\n   230→              use_speaker_boost: settings.useSpeakerBoost,\n   231→            },\n   232→          },\n   233→        }\n   234→      );\n   235→\n   236→      const data = response.body;\n   237→      const audioBuffer = Buffer.from(data.audio_base64, 'base64');\n   238→\n   239→      // Parse word timings from character-level alignment\n   240→      const wordTimings = parseWordTimestamps(\n   241→        data.alignment.characters,\n   242→        data.alignment.character_start_times_seconds,\n   243→        data.alignment.character_end_times_seconds\n   244→      );\n   245→\n   246→      // Calculate duration from word timings or estimate from buffer\n   247→      const durationSecs =\n   248→        wordTimings.length > 0\n   249→          ? wordTimings[wordTimings.length - 1].end\n   250→          : estimateDurationFromBuffer(audioBuffer);\n   251→\n   252→      return { audioBuffer, wordTimings, durationSecs };\n   253→    } catch (error) {\n   254→      lastError = error as Error;\n   255→\n   256→      if (error instanceof HTTPError) {\n   257→        const statusCode = error.response.statusCode;\n   258→\n   259→        // Handle rate limiting (429)\n   260→        if (statusCode === 429) {\n   261→          const retryAfter = parseRetryAfter(error.response.headers['retry-after']);\n   262→          const delay = retryAfter || baseDelay * Math.pow(2, attempt);\n   263→\n   264→          if (attempt < maxRetries) {\n   265→            console.warn(\n   266→              `ElevenLabs rate limited. Retry ${attempt + 1}/${maxRetries} after ${delay}ms`\n   267→            );\n   268→            await sleep(delay);\n   269→            continue;\n   270→          }\n   271→        }\n   272→\n   273→        // Handle server errors (5xx) with retry\n   274→        if (statusCode >= 500 && attempt < maxRetries) {\n   275→          const delay = baseDelay * Math.pow(2, attempt);\n   276→          console.warn(\n   277→            `ElevenLabs server error (${statusCode}). Retry ${attempt + 1}/${maxRetries} after ${delay}ms`\n   278→          );\n   279→          await sleep(delay);\n   280→          continue;\n   281→        }\n   282→      }\n   283→\n   284→      // Non-retryable error\n   285→      throw error;\n   286→    }\n   287→  }\n   288→\n   289→  throw lastError || new Error('Max retries exceeded');\n   290→}\n   291→\n   292→/**\n   293→ * Synthesize long text by splitting into chunks.\n   294→ */\n   295→async function synthesizeChunkedText(\n   296→  client: Got,\n   297→  voiceId: string,\n   298→  text: string,\n   299→  settings: {\n   300→    model: string;\n   301→    stability: number;\n   302→    similarityBoost: number;\n   303→    style: number;\n   304→    useSpeakerBoost: boolean;\n   305→    maxChunkSize: number;\n   306→    maxRetries: number;\n   307→    retryDelay: number;\n   308→  }\n   309→): Promise<{\n   310→  audioBuffer: Buffer;\n   311→  wordTimings: WordTiming[];\n   312→  durationSecs: number;\n   313→}> {\n   314→  const chunks = splitIntoChunks(text, settings.maxChunkSize);\n   315→  const audioBuffers: Buffer[] = [];\n   316→  const allWordTimings: WordTiming[] = [];\n   317→  let currentTimeOffset = 0;\n   318→  const SILENCE_GAP = 0.3; // 300ms gap between chunks\n   319→\n   320→  for (let i = 0; i < chunks.length; i++) {\n   321→    const result = await synthesizeWithRetry(\n   322→      client,\n   323→      voiceId,\n   324→      chunks[i],\n   325→      {\n   326→        model: settings.model,\n   327→        stability: settings.stability,\n   328→        similarityBoost: settings.similarityBoost,\n   329→        style: settings.style,\n   330→        useSpeakerBoost: settings.useSpeakerBoost,\n   331→      },\n   332→      settings.maxRetries,\n   333→      settings.retryDelay\n   334→    );\n   335→\n   336→    audioBuffers.push(result.audioBuffer);\n   337→\n   338→    // Adjust word timings with current offset\n   339→    const adjustedTimings = result.wordTimings.map((wt) => ({\n   340→      word: wt.word,\n   341→      start: wt.start + currentTimeOffset,\n   342→      end: wt.end + currentTimeOffset,\n   343→    }));\n   344→    allWordTimings.push(...adjustedTimings);\n   345→\n   346→    // Update offset for next chunk\n   347→    if (result.wordTimings.length > 0) {\n   348→      const lastTiming = adjustedTimings[adjustedTimings.length - 1];\n   349→      currentTimeOffset = lastTiming.end + SILENCE_GAP;\n   350→    }\n   351→\n   352→    // Add silence between chunks\n   353→    if (i < chunks.length - 1) {\n   354→      audioBuffers.push(createSilenceBuffer(SILENCE_GAP));\n   355→    }\n   356→  }\n   357→\n   358→  return {\n   359→    audioBuffer: Buffer.concat(audioBuffers),\n   360→    wordTimings: allWordTimings,\n   361→    durationSecs: currentTimeOffset,\n   362→  };\n   363→}\n   364→\n   365→/**\n   366→ * Clean text for TTS synthesis.\n   367→ * Removes markdown formatting and graphic cues but preserves emotion tags.\n   368→ */\n   369→function cleanTextForSynthesis(text: string): string {\n   370→  return text\n   371→    // Remove graphic cues\n   372→    .replace(/\\[GRAPHIC:[^\\]]+\\]/g, '')\n   373→    // Remove semantic tags like [HOOK], [KEY_POINT], etc.\n   374→    .replace(/\\[(HOOK|KEY_POINT|EVIDENCE|STORY|TRANSITION|CALLBACK|LANDING|CTA)\\]/g, '')\n   375→    // Extract pause durations but remove the tags (TTS handles natural pauses)\n   376→    .replace(/\\[PAUSE:\\d+\\]/g, ' ')\n   377→    // Remove word count metadata\n   378→    .replace(/\\*\\*Word Count:.*$/gim, '')\n   379→    .replace(/\\*\\*.*Word.*Count.*\\*\\*/gi, '')\n   380→    // Remove emphasis markers but keep the text\n   381→    .replace(/\\*([^*]+)\\*/g, '$1')\n   382→    // Remove markdown headers\n   383→    .replace(/^#.*$/gm, '')\n   384→    // Remove horizontal rules\n   385→    .replace(/^---+$/gm, '')\n   386→    // Collapse multiple newlines\n   387→    .replace(/\\n{3,}/g, '\\n\\n')\n   388→    // Normalize whitespace\n   389→    .replace(/\\s+/g, ' ')\n   390→    .trim();\n   391→}\n   392→\n   393→/**\n   394→ * Split text into chunks on sentence boundaries.\n   395→ */\n   396→function splitIntoChunks(text: string, maxChunkSize: number): string[] {\n   397→  const chunks: string[] = [];\n   398→  const sentences = text.match(/[^.!?]+[.!?]+[\\s\\n]*|[^.!?]+$/g) || [text];\n   399→\n   400→  let currentChunk = '';\n   401→\n   402→  for (const sentence of sentences) {\n   403→    if (sentence.length > maxChunkSize) {\n   404→      // Handle very long sentences by splitting on commas\n   405→      if (currentChunk.length > 0) {\n   406→        chunks.push(currentChunk.trim());\n   407→        currentChunk = '';\n   408→      }\n   409→\n   410→      const parts = sentence.split(/,\\s*/);\n   411→      for (const part of parts) {\n   412→        if (currentChunk.length + part.length + 2 > maxChunkSize) {\n   413→          if (currentChunk.length > 0) {\n   414→            chunks.push(currentChunk.trim());\n   415→          }\n   416→          currentChunk = part;\n   417→        } else {\n   418→          currentChunk += (currentChunk.length > 0 ? ', ' : '') + part;\n   419→        }\n   420→      }\n   421→    } else if (currentChunk.length + sentence.length > maxChunkSize) {\n   422→      chunks.push(currentChunk.trim());\n   423→      currentChunk = sentence;\n   424→    } else {\n   425→      currentChunk += sentence;\n   426→    }\n   427→  }\n   428→\n   429→  if (currentChunk.trim().length > 0) {\n   430→    chunks.push(currentChunk.trim());\n   431→  }\n   432→\n   433→  return chunks.length > 0 ? chunks : [text];\n   434→}\n   435→\n   436→/**\n   437→ * Parse character-level timestamps into word-level timestamps.\n   438→ */\n   439→function parseWordTimestamps(\n   440→  characters: string[],\n   441→  startTimes: number[],\n   442→  endTimes: number[]\n   443→): WordTiming[] {\n   444→  const words: WordTiming[] = [];\n   445→  let currentWord = '';\n   446→  let wordStart = 0;\n   447→\n   448→  for (let i = 0; i < characters.length; i++) {\n   449→    const char = characters[i];\n   450→\n   451→    if (char === ' ' || char === '\\n' || char === '\\t') {\n   452→      if (currentWord.trim().length > 0) {\n   453→        words.push({\n   454→          word: currentWord.trim(),\n   455→          start: wordStart,\n   456→          end: endTimes[i - 1],\n   457→        });\n   458→      }\n   459→      currentWord = '';\n   460→      if (i + 1 < startTimes.length) {\n   461→        wordStart = startTimes[i + 1];\n   462→      }\n   463→    } else {\n   464→      if (currentWord.length === 0) {\n   465→        wordStart = startTimes[i];\n   466→      }\n   467→      currentWord += char;\n   468→    }\n   469→  }\n   470→\n   471→  // Handle last word\n   472→  if (currentWord.trim().length > 0) {\n   473→    words.push({\n   474→      word: currentWord.trim(),\n   475→      start: wordStart,\n   476→      end: endTimes[endTimes.length - 1],\n   477→    });\n   478→  }\n   479→\n   480→  return words;\n   481→}\n   482→\n   483→/**\n   484→ * Estimate audio duration from MP3 buffer size.\n   485→ * Assumes ~128kbps MP3 encoding (16KB per second).\n   486→ */\n   487→function estimateDurationFromBuffer(buffer: Buffer): number {\n   488→  return buffer.length / 16000;\n   489→}\n   490→\n   491→/**\n   492→ * Create a silence buffer for gaps between chunks.\n   493→ * Generates minimal valid MP3 frames of silence.\n   494→ */\n   495→function createSilenceBuffer(durationSeconds: number): Buffer {\n   496→  // Each MP3 frame is ~26ms at 128kbps\n   497→  const frameCount = Math.max(1, Math.floor(durationSeconds / 0.026));\n   498→\n   499→  // Minimal valid MP3 frame (silence)\n   500→  const silenceFrame = Buffer.from([\n   501→    0xff, 0xfb, 0x90, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00,\n   502→    0x00, 0x00, 0x00, 0x00, 0x00, 0x00,\n   503→  ]);\n   504→\n   505→  const frames: Buffer[] = [];\n   506→  for (let i = 0; i < frameCount; i++) {\n   507→    frames.push(silenceFrame);\n   508→  }\n   509→\n   510→  return Buffer.concat(frames);\n   511→}\n   512→\n   513→/**\n   514→ * Parse Retry-After header value.\n   515→ */\n   516→function parseRetryAfter(value: string | string[] | undefined): number | null {\n   517→  if (!value) return null;\n   518→  const str = Array.isArray(value) ? value[0] : value;\n   519→  const seconds = parseInt(str, 10);\n   520→  return isNaN(seconds) ? null : seconds * 1000;\n   521→}\n   522→\n   523→/**\n   524→ * Sleep for specified milliseconds.\n   525→ */\n   526→function sleep(ms: number): Promise<void> {\n   527→  return new Promise((resolve) => setTimeout(resolve, ms));\n   528→}\n   529→\n   530→/**\n   531→ * Get available voices from ElevenLabs.\n   532→ *\n   533→ * @param apiKey - ElevenLabs API key\n   534→ * @returns Array of available voices\n   535→ */\n   536→export async function getElevenLabsVoices(\n   537→  apiKey: string\n   538→): Promise<Array<{ id: string; name: string; category?: string }>> {\n   539→  const response = await got.get<{\n   540→    voices: Array<{ voice_id: string; name: string; category?: string }>;\n   541→  }>('https://api.elevenlabs.io/v1/voices', {\n   542→    headers: {\n   543→      'xi-api-key': apiKey,\n   544→    },\n   545→    responseType: 'json',\n   546→  });\n   547→\n   548→  return response.body.voices.map((voice) => ({\n   549→    id: voice.voice_id,\n   550→    name: voice.name,\n   551→    category: voice.category,\n   552→  }));\n   553→}\n   554→"}]},"parent_tool_use_id":"toolu_01XA55g9NLmhU434Jouh7cmK","session_id":"f896ae46-0735-4a4a-b213-fcf63f97824a","uuid":"a8bd1a6c-96fa-429f-bc1c-3662b6129535"}
