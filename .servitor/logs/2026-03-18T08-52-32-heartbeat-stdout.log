{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019pxxpJaBjmQe2xPteop8K6","type":"tool_result","content":"     1→/**\n     2→ * Resume Command\n     3→ *\n     4→ * Resume a failed or interrupted build from its last checkpoint.\n     5→ */\n     6→\n     7→import { Command } from 'commander';\n     8→import { resolve, join } from 'node:path';\n     9→import { stat } from 'node:fs/promises';\n    10→\n    11→import { resumeBuild, BuildStateMachine } from '../../orchestrator/index.js';\n    12→import {\n    13→  ProgressSpinner,\n    14→  printHeader,\n    15→  printSuccess,\n    16→  printError,\n    17→  printKeyValue,\n    18→  printSection,\n    19→  printWarning,\n    20→  printManifestSummary,\n    21→  createProgressCallback,\n    22→  formatDuration,\n    23→} from '../progress.js';\n    24→\n    25→interface ResumeOptions {\n    26→  verbose?: boolean;\n    27→}\n    28→\n    29→/**\n    30→ * Register the resume command with the program.\n    31→ */\n    32→export function registerResumeCommand(program: Command): void {\n    33→  program\n    34→    .command('resume')\n    35→    .description('Resume a failed or interrupted build')\n    36→    .argument('<output-dir>', 'Path to output directory with manifest.json')\n    37→    .option('-v, --verbose', 'Enable verbose output')\n    38→    .action(resumeAction);\n    39→}\n    40→\n    41→/**\n    42→ * Resume command action handler.\n    43→ */\n    44→async function resumeAction(\n    45→  outputDirPath: string,\n    46→  options: ResumeOptions\n    47→): Promise<void> {\n    48→  const startTime = Date.now();\n    49→  const spinner = new ProgressSpinner({ verbose: options.verbose });\n    50→\n    51→  printHeader('PresentationKit Resume Build');\n    52→\n    53→  try {\n    54→    // Resolve output directory\n    55→    const absoluteDir = resolve(outputDirPath);\n    56→    const manifestPath = join(absoluteDir, 'manifest.json');\n    57→\n    58→    // Check manifest exists\n    59→    try {\n    60→      await stat(manifestPath);\n    61→    } catch {\n    62→      throw new Error(\n    63→        `Manifest not found at ${manifestPath}. ` +\n    64→        'This directory may not contain a PresentationKit build.'\n    65→      );\n    66→    }\n    67→\n    68→    // Load existing manifest to show status\n    69→    spinner.start('Loading build manifest...');\n    70→    const stateMachine = await BuildStateMachine.fromManifestPath(manifestPath);\n    71→    const manifest = stateMachine.getManifest();\n    72→    spinner.stop();\n    73→\n    74→    // Display current build status\n    75→    printSection('Current Build Status');\n    76→    printManifestSummary(manifest);\n    77→\n    78→    // Check if resumable\n    79→    const resumeState = stateMachine.getResumeState();\n    80→\n    81→    if (manifest.state === 'complete') {\n    82→      printWarning('Build is already complete. Nothing to resume.');\n    83→      return;\n    84→    }\n    85→\n    86→    if (!resumeState) {\n    87→      throw new Error(\n    88→        `Cannot resume from state: ${manifest.state}. ` +\n    89→        'Build may be in a non-resumable state.'\n    90→      );\n    91→    }\n    92→\n    93→    console.log(`Resuming from state: ${resumeState}`);\n    94→    console.log();\n    95→\n    96→    // Confirm resume\n    97→    spinner.start('Resuming build...');\n    98→\n    99→    // Resume the build\n   100→    const updatedManifest = await resumeBuild(manifestPath);\n   101→\n   102→    spinner.succeed('Build resumed successfully!');\n   103→\n   104→    const elapsed = Date.now() - startTime;\n   105→\n   106→    printSection('Resume Results');\n   107→    printKeyValue('Final State', updatedManifest.state);\n   108→    printKeyValue('Resume Duration', formatDuration(elapsed));\n   109→\n   110→    if (updatedManifest.outputs.html) {\n   111→      printKeyValue('HTML', updatedManifest.outputs.html);\n   112→    }\n   113→    if (updatedManifest.outputs.video) {\n   114→      printKeyValue('Video', updatedManifest.outputs.video);\n   115→    }\n   116→    if (updatedManifest.outputs.notes) {\n   117→      printKeyValue('Notes', updatedManifest.outputs.notes);\n   118→    }\n   119→\n   120→    if (updatedManifest.state === 'complete') {\n   121→      printSuccess('Build completed successfully!');\n   122→    } else if (updatedManifest.state === 'failed') {\n   123→      printError('Build failed during resume', updatedManifest.error);\n   124→      process.exit(1);\n   125→    }\n   126→  } catch (error) {\n   127→    spinner.fail('Resume failed');\n   128→    const message = error instanceof Error ? error.message : String(error);\n   129→    printError(message);\n   130→\n   131→    if (options.verbose && error instanceof Error && error.stack) {\n   132→      console.error('\\nStack trace:');\n   133→      console.error(error.stack);\n   134→    }\n   135→\n   136→    process.exit(1);\n   137→  }\n   138→}\n   139→"}]},"parent_tool_use_id":"toolu_01XA55g9NLmhU434Jouh7cmK","session_id":"f896ae46-0735-4a4a-b213-fcf63f97824a","uuid":"17ce216e-821c-4574-be9b-bbee1fc8b697"}
