{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016ApLRcQGFeGraAssfqoD2k","type":"tool_result","content":"     1→/**\n     2→ * Timeline Types\n     3→ *\n     4→ * Type definitions for the presentation timeline that synchronizes\n     5→ * slides, audio, and captions for video rendering.\n     6→ */\n     7→\n     8→/**\n     9→ * Word-level timing information from TTS providers like ElevenLabs.\n    10→ */\n    11→export interface WordTiming {\n    12→  /** The word text */\n    13→  word: string;\n    14→  /** Start time in seconds relative to slide audio start */\n    15→  start: number;\n    16→  /** End time in seconds relative to slide audio start */\n    17→  end: number;\n    18→}\n    19→\n    20→/**\n    21→ * Caption segment with timing information.\n    22→ * Represents a sentence or phrase to display as a caption.\n    23→ */\n    24→export interface Caption {\n    25→  /** Caption text (typically a sentence or phrase) */\n    26→  text: string;\n    27→  /** Start time in seconds relative to slide start */\n    28→  startTime: number;\n    29→  /** End time in seconds relative to slide start */\n    30→  endTime: number;\n    31→  /** Word-level timings for animated captions (optional) */\n    32→  words?: WordTiming[];\n    33→}\n    34→\n    35→/**\n    36→ * Timeline data for a single slide.\n    37→ */\n    38→export interface TimelineSlide {\n    39→  /** Unique slide identifier */\n    40→  slug: string;\n    41→  /** Slide title */\n    42→  title: string;\n    43→  /** Section ID this slide belongs to */\n    44→  section: string;\n    45→  /** Section color for visual theming */\n    46→  sectionColor: string;\n    47→  /** Slide start time in seconds from video start */\n    48→  startTime: number;\n    49→  /** Slide end time in seconds from video start */\n    50→  endTime: number;\n    51→  /** Slide duration in seconds (endTime - startTime) */\n    52→  duration: number;\n    53→  /** Path to slide image file */\n    54→  imagePath: string;\n    55→  /** Path to generated audio file */\n    56→  audioPath: string;\n    57→  /** Audio duration in seconds (excluding transition padding) */\n    58→  audioDuration: number;\n    59→  /** Caption segments for this slide */\n    60→  captions: Caption[];\n    61→}\n    62→\n    63→/**\n    64→ * Complete timeline for video rendering.\n    65→ */\n    66→export interface Timeline {\n    67→  /** Frames per second for video rendering */\n    68→  fps: number;\n    69→  /** Video width in pixels */\n    70→  width: number;\n    71→  /** Video height in pixels */\n    72→  height: number;\n    73→  /** Total video duration in seconds */\n    74→  totalDuration: number;\n    75→  /** Slide timeline entries */\n    76→  slides: TimelineSlide[];\n    77→}\n    78→\n    79→/**\n    80→ * Options for timeline generation.\n    81→ */\n    82→export interface TimelineOptions {\n    83→  /** Frames per second (default: 30) */\n    84→  fps?: number;\n    85→  /** Video width in pixels (default: 1920) */\n    86→  width?: number;\n    87→  /** Video height in pixels (default: 1080) */\n    88→  height?: number;\n    89→  /** Transition padding between slides in seconds (default: 0.3) */\n    90→  transitionPadding?: number;\n    91→}\n    92→\n    93→/**\n    94→ * Audio manifest entry for a single slide.\n    95→ * Contains path and metadata about generated audio.\n    96→ */\n    97→export interface AudioManifestEntry {\n    98→  /** Slide slug */\n    99→  slug: string;\n   100→  /** Path to the audio file */\n   101→  path: string;\n   102→  /** Audio duration in seconds */\n   103→  duration: number;\n   104→  /** TTS provider used */\n   105→  provider: 'kokoro' | 'elevenlabs';\n   106→  /** Word-level timings (ElevenLabs only) */\n   107→  wordTimings?: WordTiming[];\n   108→}\n   109→\n   110→/**\n   111→ * Complete audio manifest from audio generation phase.\n   112→ */\n   113→export interface AudioManifest {\n   114→  /** Voice ID used for generation */\n   115→  voice: string;\n   116→  /** TTS provider */\n   117→  provider: 'kokoro' | 'elevenlabs';\n   118→  /** Audio entries indexed by slug */\n   119→  entries: Map<string, AudioManifestEntry>;\n   120→}\n   121→"}]},"parent_tool_use_id":"toolu_01NSueNmmedTxDHb613XuvtJ","session_id":"fae97709-6dbb-4c53-abde-6088a81b1e30","uuid":"29f8738d-ead2-4071-85b1-165ab6ebf1c2"}
