{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019MGnepDWBaXjz4kXSdMsqg","type":"tool_result","content":"     1→/**\n     2→ * Talk Track v5 Parser\n     3→ *\n     4→ * Parses Talk Track v5 markdown files into structured data for\n     5→ * presentation and audio generation.\n     6→ */\n     7→\n     8→import YAML from 'yaml';\n     9→import { z } from 'zod';\n    10→import type {\n    11→  TalkTrackV5,\n    12→  Section,\n    13→  SlideDefinition,\n    14→  SlideContent,\n    15→  SemanticTag,\n    16→  SemanticTagType,\n    17→  BrandConfig,\n    18→  RawFrontmatter,\n    19→} from './types.js';\n    20→import {\n    21→  validateSlug,\n    22→  validateSection,\n    23→  validateImagePath,\n    24→  validateHexColor,\n    25→  findDuplicateSlugs,\n    26→} from './validators.js';\n    27→\n    28→// -----------------------------------------------------------------------------\n    29→// Zod Schemas\n    30→// -----------------------------------------------------------------------------\n    31→\n    32→const SectionSchema = z.object({\n    33→  id: z.string().min(1),\n    34→  name: z.string().min(1),\n    35→  color: z.string().regex(/^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/, 'Invalid hex color'),\n    36→});\n    37→\n    38→const BrandConfigSchema = z.object({\n    39→  primary: z.string().optional(),\n    40→  background: z.string().optional(),\n    41→  text: z.string().optional(),\n    42→});\n    43→\n    44→const FrontmatterSchema = z.object({\n    45→  version: z.union([z.literal(5), z.literal(6)]),\n    46→  title: z.string().min(1),\n    47→  subtitle: z.string().optional(),\n    48→  author: z.string().min(1),\n    49→  event: z.string().optional(),\n    50→  date: z.string().optional(),\n    51→  target_minutes: z.number().int().positive(),\n    52→  audio_voice: z.string().default('af_heart'),\n    53→  branding: z.union([z.string(), BrandConfigSchema]).optional(),\n    54→  show_speakers: z.boolean().optional(),\n    55→  sections: z.array(SectionSchema).min(1),\n    56→});\n    57→\n    58→// -----------------------------------------------------------------------------\n    59→// Parser Error\n    60→// -----------------------------------------------------------------------------\n    61→\n    62→export class TalkTrackParseError extends Error {\n    63→  constructor(\n    64→    message: string,\n    65→    public readonly errors: string[] = [],\n    66→  ) {\n    67→    super(message);\n    68→    this.name = 'TalkTrackParseError';\n    69→  }\n    70→}\n    71→\n    72→// -----------------------------------------------------------------------------\n    73→// Frontmatter Parsing\n    74→// -----------------------------------------------------------------------------\n    75→\n    76→/**\n    77→ * Extracts and parses YAML frontmatter from markdown content.\n    78→ */\n    79→function parseFrontmatter(content: string): RawFrontmatter {\n    80→  const frontmatterMatch = content.match(/^---\\n([\\s\\S]*?)\\n---/);\n    81→  if (!frontmatterMatch) {\n    82→    throw new TalkTrackParseError('Missing YAML frontmatter (must start with ---)');\n    83→  }\n    84→\n    85→  const yamlContent = frontmatterMatch[1];\n    86→  let parsed: unknown;\n    87→\n    88→  try {\n    89→    parsed = YAML.parse(yamlContent);\n    90→  } catch (e) {\n    91→    const message = e instanceof Error ? e.message : 'Unknown error';\n    92→    throw new TalkTrackParseError(`Invalid YAML frontmatter: ${message}`);\n    93→  }\n    94→\n    95→  const result = FrontmatterSchema.safeParse(parsed);\n    96→  if (!result.success) {\n    97→    const errors = result.error.errors.map(\n    98→      (err) => `${err.path.join('.')}: ${err.message}`,\n    99→    );\n   100→    throw new TalkTrackParseError('Frontmatter validation failed', errors);\n   101→  }\n   102→\n   103→  return result.data as RawFrontmatter;\n   104→}\n   105→\n   106→// -----------------------------------------------------------------------------\n   107→// Slides Table Parsing\n   108→// -----------------------------------------------------------------------------\n   109→\n   110→/**\n   111→ * Parses the slides table from markdown content.\n   112→ */\n   113→function parseSlidesTable(content: string, sections: Section[]): SlideDefinition[] {\n   114→  // Find the ## Slides section\n   115→  const slidesMatch = content.match(/## Slides\\s*\\n\\n([\\s\\S]*?)(?=\\n## \\[|$)/);\n   116→  if (!slidesMatch) {\n   117→    throw new TalkTrackParseError('Missing ## Slides section');\n   118→  }\n   119→\n   120→  const tableContent = slidesMatch[1].trim();\n   121→  // Filter empty lines and markdown separators (---)\n   122→  const lines = tableContent.split('\\n').filter((line) => {\n   123→    const trimmed = line.trim();\n   124→    return trimmed && !trimmed.match(/^-{3,}$/);\n   125→  });\n   126→\n   127→  // Validate table structure\n   128→  if (lines.length < 3) {\n   129→    throw new TalkTrackParseError('Slides table must have header, separator, and at least one row');\n   130→  }\n   131→\n   132→  // Parse header to understand column order\n   133→  const headerLine = lines[0];\n   134→  const headers = headerLine\n   135→    .split('|')\n   136→    .map((h) => h.trim().toLowerCase())\n   137→    .filter((h) => h);\n   138→\n   139→  const expectedHeaders = ['#', 'slug', 'title', 'image', 'section'];\n   140→  const headerMap: Record<string, number> = {};\n   141→\n   142→  for (const expected of expectedHeaders) {\n   143→    const index = headers.findIndex((h) => h === expected || h.includes(expected));\n   144→    if (index === -1) {\n   145→      throw new TalkTrackParseError(`Slides table missing \"${expected}\" column`);\n   146→    }\n   147→    headerMap[expected] = index;\n   148→  }\n   149→\n   150→  // Skip header and separator lines\n   151→  const dataLines = lines.slice(2);\n   152→  const slides: SlideDefinition[] = [];\n   153→  const errors: string[] = [];\n   154→\n   155→  for (let i = 0; i < dataLines.length; i++) {\n   156→    const line = dataLines[i];\n   157→    const cells = line\n   158→      .split('|')\n   159→      .map((c) => c.trim())\n   160→      .filter((c, idx, arr) => idx > 0 && idx < arr.length - 1 || c);\n   161→\n   162→    // Handle edge case of leading/trailing pipes\n   163→    const values = line\n   164→      .split('|')\n   165→      .slice(1, -1)\n   166→      .map((c) => c.trim());\n   167→\n   168→    if (values.length < expectedHeaders.length) {\n   169→      errors.push(`Row ${i + 1}: Not enough columns (expected ${expectedHeaders.length})`);\n   170→      continue;\n   171→    }\n   172→\n   173→    const position = values[headerMap['#']];\n   174→    const slug = values[headerMap['slug']];\n   175→    const title = values[headerMap['title']];\n   176→    const image = values[headerMap['image']];\n   177→    const section = values[headerMap['section']];\n   178→\n   179→    // Validate fields\n   180→    if (!validateSlug(slug)) {\n   181→      errors.push(`Row ${i + 1}: Invalid slug \"${slug}\" (must be lowercase-kebab-case)`);\n   182→    }\n   183→\n   184→    if (!validateSection(section, sections)) {\n   185→      errors.push(`Row ${i + 1}: Unknown section \"${section}\"`);\n   186→    }\n   187→\n   188→    if (!validateImagePath(image)) {\n   189→      errors.push(`Row ${i + 1}: Invalid image path \"${image}\"`);\n   190→    }\n   191→\n   192→    // Normalize image path to ensure consistent images/ prefix\n   193→    const normalizedImage = normalizeImagePath(image);\n   194→    slides.push({ position, slug, title, image: normalizedImage, section });\n   195→  }\n   196→\n   197→  // Check for duplicate slugs\n   198→  const duplicates = findDuplicateSlugs(slides.map((s) => s.slug));\n   199→  if (duplicates.length > 0) {\n   200→    errors.push(`Duplicate slugs found: ${duplicates.join(', ')}`);\n   201→  }\n   202→\n   203→  if (errors.length > 0) {\n   204→    throw new TalkTrackParseError('Slides table validation failed', errors);\n   205→  }\n   206→\n   207→  return slides;\n   208→}\n   209→\n   210→// -----------------------------------------------------------------------------\n   211→// Semantic Tag Parsing\n   212→// -----------------------------------------------------------------------------\n   213→\n   214→const SEMANTIC_TAG_TYPES: SemanticTagType[] = [\n   215→  'HOOK',\n   216→  'KEY_POINT',\n   217→  'EVIDENCE',\n   218→  'STORY',\n   219→  'TRANSITION',\n   220→  'CALLBACK',\n   221→  'LANDING',\n   222→  'CTA',\n   223→  'PAUSE',\n   224→];\n   225→\n   226→/**\n   227→ * Parses semantic tags from audio text content.\n   228→ */\n   229→function parseSemanticTags(audioText: string): SemanticTag[] {\n   230→  const tags: SemanticTag[] = [];\n   231→\n   232→  // Match tags like [HOOK], [KEY_POINT], [PAUSE], [PAUSE:500]\n   233→  const tagPattern = /\\[(HOOK|KEY_POINT|EVIDENCE|STORY|TRANSITION|CALLBACK|LANDING|CTA|PAUSE)(?::(\\d+))?\\]/gi;\n   234→\n   235→  let match;\n   236→  while ((match = tagPattern.exec(audioText)) !== null) {\n   237→    const type = match[1].toUpperCase() as SemanticTagType;\n   238→    const duration = match[2] ? parseInt(match[2], 10) : undefined;\n   239→\n   240→    const tag: SemanticTag = { type };\n   241→\n   242→    if (type === 'PAUSE' && duration !== undefined) {\n   243→      tag.duration = duration;\n   244→    }\n   245→\n   246→    // For content tags, try to extract the following content\n   247→    if (type !== 'PAUSE') {\n   248→      const afterTag = audioText.slice(match.index + match[0].length);\n   249→      const contentMatch = afterTag.match(/^\\s*(.+?)(?=\\n\\n|\\[|$)/s);\n   250→      if (contentMatch) {\n   251→        tag.content = contentMatch[1].trim();\n   252→      }\n   253→    }\n   254→\n   255→    tags.push(tag);\n   256→  }\n   257→\n   258→  return tags;\n   259→}\n   260→\n   261→/**\n   262→ * Extracts speaker name from audio text.\n   263→ * Matches **[NAME]** or *[NAME]* at the start of audio text.\n   264→ */\n   265→export function parseSpeakerLabel(audioText: string): string | undefined {\n   266→  const match = audioText.match(/^\\s*\\*{1,2}\\[([A-Z_]+)\\]\\*{1,2}/);\n   267→  return match ? match[1] : undefined;\n   268→}\n   269→\n   270→/**\n   271→ * Strips speaker label from audio text for clean TTS input.\n   272→ */\n   273→export function stripSpeakerLabel(audioText: string): string {\n   274→  return audioText.replace(/^\\s*\\*{1,2}\\[([A-Z_]+)\\]\\*{1,2}\\s*/m, '').trim();\n   275→}\n   276→\n   277→/**\n   278→ * Strips semantic tags from audio text for clean TTS input.\n   279→ */\n   280→export function stripSemanticTags(audioText: string): string {\n   281→  return audioText\n   282→    .replace(/\\[(HOOK|KEY_POINT|EVIDENCE|STORY|TRANSITION|CALLBACK|LANDING|CTA|PAUSE)(?::\\d+)?\\]/gi, '')\n   283→    .replace(/\\n{3,}/g, '\\n\\n')\n   284→    .trim();\n   285→}\n   286→\n   287→// -----------------------------------------------------------------------------\n   288→// Image Path Normalization\n   289→// -----------------------------------------------------------------------------\n   290→\n   291→/**\n   292→ * Normalizes an image path to ensure consistent `images/` prefix.\n   293→ * Handles various input formats:\n   294→ *   - `slide.png` → `images/slide.png`\n   295→ *   - `images/slide.png` → `images/slide.png` (unchanged)\n   296→ *   - `./images/slide.png` → `images/slide.png`\n   297→ *   - `../assets/slide.png` → `../assets/slide.png` (external paths unchanged)\n   298→ */\n   299→function normalizeImagePath(imagePath: string): string {\n   300→  if (!imagePath) return imagePath;\n   301→\n   302→  // Already has images/ prefix\n   303→  if (imagePath.startsWith('images/')) {\n   304→    return imagePath;\n   305→  }\n   306→\n   307→  // Has ./images/ prefix - normalize\n   308→  if (imagePath.startsWith('./images/')) {\n   309→    return imagePath.slice(2); // Remove './'\n   310→  }\n   311→\n   312→  // External/relative paths (../, /, http://, etc.) - leave unchanged\n   313→  if (imagePath.startsWith('../') || imagePath.startsWith('/') || imagePath.includes('://')) {\n   314→    return imagePath;\n   315→  }\n   316→\n   317→  // Plain filename or other relative path - add images/ prefix\n   318→  return `images/${imagePath}`;\n   319→}\n   320→\n   321→// -----------------------------------------------------------------------------\n   322→// Slide Content Parsing\n   323→// -----------------------------------------------------------------------------\n   324→\n   325→/**\n   326→ * Parses individual slide content sections.\n   327→ */\n   328→function parseSlideContent(content: string, slides: SlideDefinition[]): Map<string, SlideContent> {\n   329→  const slideContent = new Map<string, SlideContent>();\n   330→  const errors: string[] = [];\n   331→\n   332→  // Match slide sections: ## [slug] Title\n   333→  const slidePattern = /## \\[([^\\]]+)\\] ([^\\n]+)\\n([\\s\\S]*?)(?=\\n## \\[|$)/g;\n   334→\n   335→  let match;\n   336→  while ((match = slidePattern.exec(content)) !== null) {\n   337→    const slug = match[1];\n   338→    const title = match[2].trim();\n   339→    const sectionContent = match[3];\n   340→\n   341→    // Check if slug exists in slides table\n   342→    // If not, silently skip (allows extra content sections like appendix)\n   343→    const slideDef = slides.find((s) => s.slug === slug);\n   344→    if (!slideDef) {\n   345→      // Lenient mode: skip content sections not in slides table\n   346→      continue;\n   347→    }\n   348→\n   349→    // Extract image and normalize path to ensure consistent images/ prefix\n   350→    const imageMatch = sectionContent.match(/!\\[.*?\\]\\((.*?)\\)/);\n   351→    const rawImagePath = imageMatch ? imageMatch[1] : slideDef.image;\n   352→    const imagePath = normalizeImagePath(rawImagePath);\n   353→\n   354→    // Extract audio block\n   355→    const audioMatch = sectionContent.match(/<!-- AUDIO -->\\n?([\\s\\S]*?)\\n?<!-- \\/AUDIO -->/);\n   356→    const rawAudioText = audioMatch ? audioMatch[1].trim() : '';\n   357→\n   358→    if (!audioMatch) {\n   359→      errors.push(`Slide \"${slug}\": Missing <!-- AUDIO --> block`);\n   360→    }\n   361→\n   362→    // Extract speaker label (e.g., **[JORDAN]**) before stripping\n   363→    const speaker = parseSpeakerLabel(rawAudioText);\n   364→    const audioText = speaker ? stripSpeakerLabel(rawAudioText) : rawAudioText;\n   365→\n   366→    // Extract speaker notes\n   367→    const notesMatch = sectionContent.match(/\\*\\*Speaker Notes:\\*\\*\\s*\\n?([\\s\\S]*?)(?=\\n---|\\n## |$)/);\n   368→    const speakerNotes = notesMatch ? notesMatch[1].trim() : undefined;\n   369→\n   370→    // Parse semantic tags\n   371→    const semanticTags = parseSemanticTags(audioText);\n   372→\n   373→    slideContent.set(slug, {\n   374→      slug,\n   375→      title,\n   376→      imagePath,\n   377→      audioText,\n   378→      speakerNotes,\n   379→      semanticTags,\n   380→      speaker,\n   381→    });\n   382→  }\n   383→\n   384→  // Check that all slides have content\n   385→  for (const slide of slides) {\n   386→    if (!slideContent.has(slide.slug)) {\n   387→      errors.push(`Missing content section for slide: \"${slide.slug}\"`);\n   388→    }\n   389→  }\n   390→\n   391→  if (errors.length > 0) {\n   392→    throw new TalkTrackParseError('Slide content validation failed', errors);\n   393→  }\n   394→\n   395→  return slideContent;\n   396→}\n   397→\n   398→// -----------------------------------------------------------------------------\n   399→// Branding Parsing\n   400→// -----------------------------------------------------------------------------\n   401→\n   402→/**\n   403→ * Parses branding configuration from frontmatter.\n   404→ */\n   405→function parseBranding(branding: string | BrandConfig | undefined): BrandConfig | undefined {\n   406→  if (!branding) {\n   407→    return undefined;\n   408→  }\n   409→\n   410→  if (typeof branding === 'string') {\n   411→    // String branding is a theme identifier - convert to config\n   412→    // This is a placeholder; actual theme mapping would be implemented elsewhere\n   413→    return { primary: branding };\n   414→  }\n   415→\n   416→  // Validate colors if present\n   417→  const errors: string[] = [];\n   418→  if (branding.primary && !validateHexColor(branding.primary)) {\n   419→    errors.push(`Invalid primary color: ${branding.primary}`);\n   420→  }\n   421→  if (branding.background && !validateHexColor(branding.background)) {\n   422→    errors.push(`Invalid background color: ${branding.background}`);\n   423→  }\n   424→  if (branding.text && !validateHexColor(branding.text)) {\n   425→    errors.push(`Invalid text color: ${branding.text}`);\n   426→  }\n   427→\n   428→  if (errors.length > 0) {\n   429→    throw new TalkTrackParseError('Branding validation failed', errors);\n   430→  }\n   431→\n   432→  return branding;\n   433→}\n   434→\n   435→// -----------------------------------------------------------------------------\n   436→// Main Parser\n   437→// -----------------------------------------------------------------------------\n   438→\n   439→/**\n   440→ * Parses a Talk Track v5 markdown document into structured data.\n   441→ *\n   442→ * @param content - The full markdown content of the talk track file\n   443→ * @returns Parsed TalkTrackV5 object\n   444→ * @throws TalkTrackParseError if parsing fails\n   445→ *\n   446→ * @example\n   447→ * ```typescript\n   448→ * import { parseTalkTrack } from './parsers/talk-track.js';\n   449→ * import { readFileSync } from 'fs';\n   450→ *\n   451→ * const content = readFileSync('talk-track.md', 'utf-8');\n   452→ * const talkTrack = parseTalkTrack(content);\n   453→ *\n   454→ * console.log(talkTrack.title);\n   455→ * console.log(talkTrack.slides.length);\n   456→ *\n   457→ * for (const [slug, slide] of talkTrack.slideContent) {\n   458→ *   console.log(`${slug}: ${slide.audioText.length} chars of audio`);\n   459→ * }\n   460→ * ```\n   461→ */\n   462→export function parseTalkTrack(content: string): TalkTrackV5 {\n   463→  // Step 1: Parse frontmatter\n   464→  const frontmatter = parseFrontmatter(content);\n   465→\n   466→  // Step 2: Parse slides table\n   467→  const slides = parseSlidesTable(content, frontmatter.sections);\n   468→\n   469→  // Step 3: Parse slide content\n   470→  const slideContent = parseSlideContent(content, slides);\n   471→\n   472→  // Step 4: Parse branding\n   473→  const branding = parseBranding(frontmatter.branding);\n   474→\n   475→  // Step 5: Construct final object\n   476→  const talkTrack: TalkTrackV5 = {\n   477→    version: 5,\n   478→    title: frontmatter.title,\n   479→    subtitle: frontmatter.subtitle,\n   480→    author: frontmatter.author,\n   481→    event: frontmatter.event,\n   482→    date: frontmatter.date,\n   483→    targetMinutes: frontmatter.target_minutes,\n   484→    audioVoice: frontmatter.audio_voice ?? 'af_heart',\n   485→    branding,\n   486→    showSpeakers: frontmatter.show_speakers,\n   487→    sections: frontmatter.sections,\n   488→    slides,\n   489→    slideContent,\n   490→  };\n   491→\n   492→  return talkTrack;\n   493→}\n   494→\n   495→/**\n   496→ * Safely parses a Talk Track v5 document, returning errors instead of throwing.\n   497→ *\n   498→ * @param content - The full markdown content\n   499→ * @returns Object with success flag, data, and errors\n   500→ */\n   501→export function safeParseTalkTrack(content: string): {\n   502→  success: boolean;\n   503→  data?: TalkTrackV5;\n   504→  errors?: string[];\n   505→} {\n   506→  try {\n   507→    const data = parseTalkTrack(content);\n   508→    return { success: true, data };\n   509→  } catch (e) {\n   510→    if (e instanceof TalkTrackParseError) {\n   511→      return {\n   512→        success: false,\n   513→        errors: e.errors.length > 0 ? e.errors : [e.message],\n   514→      };\n   515→    }\n   516→    const message = e instanceof Error ? e.message : 'Unknown error';\n   517→    return { success: false, errors: [message] };\n   518→  }\n   519→}\n   520→\n   521→/**\n   522→ * Extracts only the frontmatter from a Talk Track document.\n   523→ * Useful for quick metadata inspection without full parsing.\n   524→ */\n   525→export function extractFrontmatter(content: string): RawFrontmatter {\n   526→  return parseFrontmatter(content);\n   527→}\n   528→\n   529→/**\n   530→ * Validates a Talk Track document without fully parsing it.\n   531→ * Returns a list of validation errors.\n   532→ */\n   533→export function validateTalkTrack(content: string): string[] {\n   534→  const result = safeParseTalkTrack(content);\n   535→  return result.errors ?? [];\n   536→}\n   537→"}]},"parent_tool_use_id":"toolu_01Hv4DasBDFoVNnhH6QmfxmU","session_id":"fae97709-6dbb-4c53-abde-6088a81b1e30","uuid":"6bd9bfb5-8972-4216-b579-62061b721632"}
