{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RawpKtuXmkAkn9H4B3Qdh5","type":"tool_result","content":"     1→/**\n     2→ * HTML Renderer Integration Tests\n     3→ *\n     4→ * Integration tests for the HTML presentation renderer.\n     5→ * Tests HTML output structure, content, and navigation elements.\n     6→ */\n     7→\n     8→import { describe, it, expect, beforeAll } from 'vitest';\n     9→import { readFileSync } from 'fs';\n    10→import { join, dirname } from 'path';\n    11→import { fileURLToPath } from 'url';\n    12→import { parseTalkTrack, stripSemanticTags } from '../../src/parsers/index.js';\n    13→import { buildTimeline } from '../../src/generators/timeline/index.js';\n    14→import {\n    15→  renderHtmlPresentationToString,\n    16→  getHtmlPresentationSummary,\n    17→  DEFAULT_HTML_OPTIONS,\n    18→} from '../../src/renderers/html/index.js';\n    19→import type { TalkTrackV5 } from '../../src/parsers/types.js';\n    20→import type { AudioManifest, AudioManifestEntry, Timeline } from '../../src/generators/timeline/types.js';\n    21→\n    22→// Get the directory of this test file\n    23→const __filename = fileURLToPath(import.meta.url);\n    24→const __dirname = dirname(__filename);\n    25→\n    26→// Path to the sample talk track fixture\n    27→const FIXTURE_PATH = join(__dirname, '../fixtures/sample-talk-track.md');\n    28→\n    29→// Test data\n    30→let fixtureContent: string;\n    31→let parsedTalkTrack: TalkTrackV5;\n    32→let mockAudioManifest: AudioManifest;\n    33→let timeline: Timeline;\n    34→let htmlOutputWithTimeline: string;\n    35→let htmlOutputWithoutTimeline: string;\n    36→\n    37→/**\n    38→ * Creates a mock audio manifest for testing.\n    39→ */\n    40→function createMockAudioManifest(talkTrack: TalkTrackV5): AudioManifest {\n    41→  const entries = new Map<string, AudioManifestEntry>();\n    42→\n    43→  for (const slide of talkTrack.slides) {\n    44→    const content = talkTrack.slideContent.get(slide.slug);\n    45→    if (!content) continue;\n    46→\n    47→    const cleanText = stripSemanticTags(content.audioText);\n    48→    const wordCount = cleanText.split(/\\s+/).filter((w) => w).length;\n    49→    const duration = Math.max(2, wordCount / 2.5);\n    50→\n    51→    entries.set(slide.slug, {\n    52→      slug: slide.slug,\n    53→      path: `audio/${slide.slug}.mp3`,\n    54→      duration,\n    55→      provider: 'kokoro',\n    56→    });\n    57→  }\n    58→\n    59→  return {\n    60→    voice: 'af_heart',\n    61→    provider: 'kokoro',\n    62→    entries,\n    63→  };\n    64→}\n    65→\n    66→beforeAll(() => {\n    67→  fixtureContent = readFileSync(FIXTURE_PATH, 'utf-8');\n    68→  parsedTalkTrack = parseTalkTrack(fixtureContent);\n    69→  mockAudioManifest = createMockAudioManifest(parsedTalkTrack);\n    70→  timeline = buildTimeline(parsedTalkTrack, mockAudioManifest);\n    71→\n    72→  // Generate HTML with and without timeline\n    73→  htmlOutputWithTimeline = renderHtmlPresentationToString(parsedTalkTrack, timeline);\n    74→  htmlOutputWithoutTimeline = renderHtmlPresentationToString(parsedTalkTrack, null);\n    75→});\n    76→\n    77→// -----------------------------------------------------------------------------\n    78→// Basic HTML Structure Tests\n    79→// -----------------------------------------------------------------------------\n    80→\n    81→describe('HTML Renderer Integration: Basic Structure', () => {\n    82→  it('should generate valid HTML document', () => {\n    83→    expect(htmlOutputWithTimeline).toContain('<!DOCTYPE html>');\n    84→    expect(htmlOutputWithTimeline).toContain('<html');\n    85→    expect(htmlOutputWithTimeline).toContain('</html>');\n    86→    expect(htmlOutputWithTimeline).toContain('<head>');\n    87→    expect(htmlOutputWithTimeline).toContain('</head>');\n    88→    expect(htmlOutputWithTimeline).toContain('<body>');\n    89→    expect(htmlOutputWithTimeline).toContain('</body>');\n    90→  });\n    91→\n    92→  it('should include document title', () => {\n    93→    expect(htmlOutputWithTimeline).toContain('<title>');\n    94→    expect(htmlOutputWithTimeline).toContain(parsedTalkTrack.title);\n    95→  });\n    96→\n    97→  it('should include CSS styles', () => {\n    98→    expect(htmlOutputWithTimeline).toContain('<style>');\n    99→    expect(htmlOutputWithTimeline).toContain('</style>');\n   100→  });\n   101→\n   102→  it('should include JavaScript', () => {\n   103→    expect(htmlOutputWithTimeline).toContain('<script>');\n   104→    expect(htmlOutputWithTimeline).toContain('</script>');\n   105→  });\n   106→\n   107→  it('should be a self-contained HTML file', () => {\n   108→    // Should not have external stylesheet links\n   109→    expect(htmlOutputWithTimeline).not.toMatch(/<link[^>]+rel=[\"']stylesheet[\"'][^>]+href=/);\n   110→    // Should not have external script sources (except for data/inline)\n   111→    expect(htmlOutputWithTimeline).not.toMatch(/<script[^>]+src=[\"']https?:\\/\\//);\n   112→  });\n   113→});\n   114→\n   115→// -----------------------------------------------------------------------------\n   116→// Slide Content Tests\n   117→// -----------------------------------------------------------------------------\n   118→\n   119→describe('HTML Renderer Integration: Slide Content', () => {\n   120→  it('should include all slides', () => {\n   121→    for (const slide of parsedTalkTrack.slides) {\n   122→      expect(htmlOutputWithTimeline).toContain(slide.slug);\n   123→    }\n   124→  });\n   125→\n   126→  it('should include slide titles', () => {\n   127→    for (const slide of parsedTalkTrack.slides) {\n   128→      expect(htmlOutputWithTimeline).toContain(slide.title);\n   129→    }\n   130→  });\n   131→\n   132→  it('should include slide images', () => {\n   133→    for (const slide of parsedTalkTrack.slides) {\n   134→      // Image filename should be referenced\n   135→      expect(htmlOutputWithTimeline).toContain(slide.image);\n   136→    }\n   137→  });\n   138→\n   139→  it('should render correct number of slides in JavaScript data', () => {\n   140→    // Count slide entries in the JavaScript slides array\n   141→    // Slides are stored as JavaScript objects with slug property\n   142→    const slideMatches = htmlOutputWithTimeline.match(/slug:\\s*'/g);\n   143→    expect(slideMatches?.length).toBe(parsedTalkTrack.slides.length);\n   144→  });\n   145→\n   146→  it('should include speaker notes as data', () => {\n   147→    // Speaker notes should be present somewhere in the HTML\n   148→    const titleContent = parsedTalkTrack.slideContent.get('title-slide');\n   149→    if (titleContent?.speakerNotes) {\n   150→      expect(htmlOutputWithTimeline).toContain('Make eye contact');\n   151→    }\n   152→  });\n   153→});\n   154→\n   155→// -----------------------------------------------------------------------------\n   156→// Navigation Elements Tests\n   157→// -----------------------------------------------------------------------------\n   158→\n   159→describe('HTML Renderer Integration: Navigation', () => {\n   160→  it('should include progress bar element', () => {\n   161→    // Look for progress bar by class or id\n   162→    expect(htmlOutputWithTimeline).toMatch(/progress/i);\n   163→  });\n   164→\n   165→  it('should include slide counter', () => {\n   166→    // Slide counter showing current/total\n   167→    const totalSlides = parsedTalkTrack.slides.length.toString();\n   168→    expect(htmlOutputWithTimeline).toContain(totalSlides);\n   169→  });\n   170→\n   171→  it('should include keyboard navigation JavaScript', () => {\n   172→    // Should have keydown event listener\n   173→    expect(htmlOutputWithTimeline).toContain('keydown');\n   174→    // Should handle arrow keys or specific navigation keys\n   175→    expect(htmlOutputWithTimeline).toMatch(/Arrow(Left|Right)|key/i);\n   176→  });\n   177→\n   178→  it('should include section information', () => {\n   179→    // Section names should appear\n   180→    expect(htmlOutputWithTimeline).toContain('Opening');\n   181→    expect(htmlOutputWithTimeline).toContain('The Problem');\n   182→    expect(htmlOutputWithTimeline).toContain('Our Solution');\n   183→  });\n   184→});\n   185→\n   186→// -----------------------------------------------------------------------------\n   187→// Metadata and Branding Tests\n   188→// -----------------------------------------------------------------------------\n   189→\n   190→describe('HTML Renderer Integration: Metadata', () => {\n   191→  it('should include presentation title', () => {\n   192→    expect(htmlOutputWithTimeline).toContain('AI-Native Software Development');\n   193→  });\n   194→\n   195→  it('should include author name', () => {\n   196→    expect(htmlOutputWithTimeline).toContain('Jane Developer');\n   197→  });\n   198→\n   199→  it('should include metadata in JavaScript', () => {\n   200→    // Metadata is embedded in the JavaScript, not as visible HTML\n   201→    expect(htmlOutputWithTimeline).toContain(\"title: 'AI-Native Software Development'\");\n   202→  });\n   203→\n   204→  it('should apply branding colors from talk track', () => {\n   205→    // Primary color should be in styles\n   206→    expect(htmlOutputWithTimeline).toContain('#2563eb');\n   207→  });\n   208→\n   209→  it('should include section colors', () => {\n   210→    expect(htmlOutputWithTimeline).toContain('#557373'); // Opening section\n   211→    expect(htmlOutputWithTimeline).toContain('#6B4C4C'); // Problem section\n   212→  });\n   213→});\n   214→\n   215→// -----------------------------------------------------------------------------\n   216→// Timeline Integration Tests\n   217→// -----------------------------------------------------------------------------\n   218→\n   219→describe('HTML Renderer Integration: Timeline Data', () => {\n   220→  it('should include audio paths when timeline provided', () => {\n   221→    // Audio paths should be present\n   222→    expect(htmlOutputWithTimeline).toContain('audio/');\n   223→    expect(htmlOutputWithTimeline).toMatch(/audio\\/[a-z-]+\\.mp3/);\n   224→  });\n   225→\n   226→  it('should work without timeline', () => {\n   227→    expect(htmlOutputWithoutTimeline).toContain('<!DOCTYPE html>');\n   228→    expect(htmlOutputWithoutTimeline).toContain(parsedTalkTrack.title);\n   229→    expect(htmlOutputWithoutTimeline).toContain('title-slide');\n   230→  });\n   231→\n   232→  it('should not include audio paths when no timeline', () => {\n   233→    // The exact behavior depends on implementation\n   234→    // But slides should still be present\n   235→    for (const slide of parsedTalkTrack.slides) {\n   236→      expect(htmlOutputWithoutTimeline).toContain(slide.slug);\n   237→    }\n   238→  });\n   239→});\n   240→\n   241→// -----------------------------------------------------------------------------\n   242→// Custom Options Tests\n   243→// -----------------------------------------------------------------------------\n   244→\n   245→describe('HTML Renderer Integration: Custom Options', () => {\n   246→  it('should apply custom primary color', () => {\n   247→    const customHtml = renderHtmlPresentationToString(parsedTalkTrack, timeline, {\n   248→      primaryColor: '#ff5722',\n   249→    });\n   250→    expect(customHtml).toContain('#ff5722');\n   251→  });\n   252→\n   253→  it('should apply custom background color', () => {\n   254→    const customHtml = renderHtmlPresentationToString(parsedTalkTrack, timeline, {\n   255→      backgroundColor: '#121212',\n   256→    });\n   257→    expect(customHtml).toContain('#121212');\n   258→  });\n   259→\n   260→  it('should use default options when not specified', () => {\n   261→    // Default primary color should be used if no branding\n   262→    const minimalTalkTrack: TalkTrackV5 = {\n   263→      ...parsedTalkTrack,\n   264→      branding: undefined,\n   265→    };\n   266→    const html = renderHtmlPresentationToString(minimalTalkTrack, null);\n   267→    expect(html).toContain(DEFAULT_HTML_OPTIONS.primaryColor);\n   268→  });\n   269→});\n   270→\n   271→// -----------------------------------------------------------------------------\n   272→// Summary Function Tests\n   273→// -----------------------------------------------------------------------------\n   274→\n   275→describe('HTML Renderer Integration: Summary', () => {\n   276→  it('should return correct summary statistics', () => {\n   277→    const summary = getHtmlPresentationSummary(parsedTalkTrack, timeline);\n   278→\n   279→    expect(summary.title).toBe('AI-Native Software Development');\n   280→    expect(summary.slideCount).toBe(7);\n   281→    expect(summary.sectionCount).toBe(5);\n   282→  });\n   283→\n   284→  it('should identify main and appendix slides', () => {\n   285→    const summary = getHtmlPresentationSummary(parsedTalkTrack, timeline);\n   286→\n   287→    expect(summary.mainSlideCount).toBe(6);\n   288→    expect(summary.appendixSlideCount).toBe(1);\n   289→  });\n   290→\n   291→  it('should detect audio presence', () => {\n   292→    const summaryWithAudio = getHtmlPresentationSummary(parsedTalkTrack, timeline);\n   293→    expect(summaryWithAudio.hasAudio).toBe(true);\n   294→\n   295→    const summaryNoAudio = getHtmlPresentationSummary(parsedTalkTrack, null);\n   296→    expect(summaryNoAudio.hasAudio).toBe(false);\n   297→  });\n   298→\n   299→  it('should include audio duration when timeline present', () => {\n   300→    const summary = getHtmlPresentationSummary(parsedTalkTrack, timeline);\n   301→    expect(summary.totalAudioDuration).toBeGreaterThan(0);\n   302→  });\n   303→\n   304→  it('should include target minutes', () => {\n   305→    const summary = getHtmlPresentationSummary(parsedTalkTrack, timeline);\n   306→    expect(summary.targetMinutes).toBe(15);\n   307→  });\n   308→});\n   309→\n   310→// -----------------------------------------------------------------------------\n   311→// Appendix Handling Tests\n   312→// -----------------------------------------------------------------------------\n   313→\n   314→describe('HTML Renderer Integration: Appendix Slides', () => {\n   315→  it('should include appendix slides in output', () => {\n   316→    expect(htmlOutputWithTimeline).toContain('appendix-resources');\n   317→    expect(htmlOutputWithTimeline).toContain('Additional Resources');\n   318→  });\n   319→\n   320→  it('should mark appendix slides appropriately', () => {\n   321→    // Appendix slides might have special data attributes or classes\n   322→    expect(htmlOutputWithTimeline).toContain('appendix');\n   323→  });\n   324→});\n   325→\n   326→// -----------------------------------------------------------------------------\n   327→// Accessibility Tests\n   328→// -----------------------------------------------------------------------------\n   329→\n   330→describe('HTML Renderer Integration: Accessibility', () => {\n   331→  it('should include language attribute', () => {\n   332→    expect(htmlOutputWithTimeline).toMatch(/<html[^>]+lang=/);\n   333→  });\n   334→\n   335→  it('should include viewport meta tag', () => {\n   336→    expect(htmlOutputWithTimeline).toContain('viewport');\n   337→  });\n   338→\n   339→  it('should include alt text for images', () => {\n   340→    // Images should have alt attributes\n   341→    const imgTags = htmlOutputWithTimeline.match(/<img[^>]+>/g) || [];\n   342→    for (const img of imgTags) {\n   343→      expect(img).toContain('alt=');\n   344→    }\n   345→  });\n   346→});\n   347→\n   348→// -----------------------------------------------------------------------------\n   349→// Print Support Tests\n   350→// -----------------------------------------------------------------------------\n   351→\n   352→describe('HTML Renderer Integration: Print Support', () => {\n   353→  it('should include print-related CSS', () => {\n   354→    expect(htmlOutputWithTimeline).toMatch(/@media\\s+print/);\n   355→  });\n   356→});\n   357→\n   358→// -----------------------------------------------------------------------------\n   359→// Data Integrity Tests\n   360→// -----------------------------------------------------------------------------\n   361→\n   362→describe('HTML Renderer Integration: Data Integrity', () => {\n   363→  it('should preserve slide order', () => {\n   364→    const slugs = parsedTalkTrack.slides.map((s) => s.slug);\n   365→\n   366→    // Find positions of each slug in the HTML\n   367→    const positions = slugs.map((slug) => htmlOutputWithTimeline.indexOf(slug));\n   368→\n   369→    // Each position should be greater than the previous (maintaining order)\n   370→    for (let i = 1; i < positions.length; i++) {\n   371→      expect(positions[i]).toBeGreaterThan(positions[i - 1]);\n   372→    }\n   373→  });\n   374→\n   375→  it('should not include raw semantic tags in output', () => {\n   376→    // Semantic tags should be stripped from visible content\n   377→    expect(htmlOutputWithTimeline).not.toMatch(/\\[HOOK\\]/);\n   378→    expect(htmlOutputWithTimeline).not.toMatch(/\\[KEY_POINT\\]/);\n   379→    expect(htmlOutputWithTimeline).not.toMatch(/\\[PAUSE:\\d+\\]/);\n   380→  });\n   381→\n   382→  it('should escape special HTML characters in content', () => {\n   383→    // Create talk track with special characters\n   384→    const contentWithSpecialChars = fixtureContent.replace(\n   385→      'Welcome everyone',\n   386→      'Welcome <everyone> & \"friends\"'\n   387→    );\n   388→\n   389→    try {\n   390→      const trackWithSpecialChars = parseTalkTrack(contentWithSpecialChars);\n   391→      const html = renderHtmlPresentationToString(trackWithSpecialChars, null);\n   392→\n   393→      // Special characters should be escaped\n   394→      expect(html).not.toContain('<everyone>');\n   395→      expect(html).toMatch(/&lt;everyone&gt;|&amp;/);\n   396→    } catch {\n   397→      // If parsing fails due to modification, skip this test\n   398→      expect(true).toBe(true);\n   399→    }\n   400→  });\n   401→});\n   402→\n   403→// -----------------------------------------------------------------------------\n   404→// Edge Cases Tests\n   405→// -----------------------------------------------------------------------------\n   406→\n   407→describe('HTML Renderer Integration: Edge Cases', () => {\n   408→  it('should handle slides without speaker notes', () => {\n   409→    // Some slides may not have speaker notes - should not error\n   410→    const html = renderHtmlPresentationToString(parsedTalkTrack, null);\n   411→    expect(html).toBeDefined();\n   412→    expect(html.length).toBeGreaterThan(0);\n   413→  });\n   414→\n   415→  it('should handle empty subtitle', () => {\n   416→    const trackNoSubtitle: TalkTrackV5 = {\n   417→      ...parsedTalkTrack,\n   418→      subtitle: undefined,\n   419→    };\n   420→    const html = renderHtmlPresentationToString(trackNoSubtitle, null);\n   421→    expect(html).toBeDefined();\n   422→    expect(html).toContain(parsedTalkTrack.title);\n   423→  });\n   424→\n   425→  it('should handle empty event', () => {\n   426→    const trackNoEvent: TalkTrackV5 = {\n   427→      ...parsedTalkTrack,\n   428→      event: undefined,\n   429→    };\n   430→    const html = renderHtmlPresentationToString(trackNoEvent, null);\n   431→    expect(html).toBeDefined();\n   432→  });\n   433→});\n   434→"}]},"parent_tool_use_id":"toolu_01CxjStoqz4pfoTiMxyQouKJ","session_id":"fae97709-6dbb-4c53-abde-6088a81b1e30","uuid":"628d46ae-2717-412f-849d-6e6e60f4b5f6"}
