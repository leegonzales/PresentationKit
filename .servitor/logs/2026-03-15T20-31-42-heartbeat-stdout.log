{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WXXSgSbuWZTvAeNKP3unXV","type":"tool_result","content":"     1→/**\n     2→ * Timeline Integration Tests\n     3→ *\n     4→ * Integration tests for the timeline builder, including caption sync\n     5→ * and slide timing calculations.\n     6→ */\n     7→\n     8→import { describe, it, expect, beforeAll } from 'vitest';\n     9→import { readFileSync } from 'fs';\n    10→import { join, dirname } from 'path';\n    11→import { fileURLToPath } from 'url';\n    12→import { parseTalkTrack, stripSemanticTags } from '../../src/parsers/index.js';\n    13→import {\n    14→  buildTimeline,\n    15→  calculateTotalFrames,\n    16→  getSlideAtTime,\n    17→  getSlideAtFrame,\n    18→  getCaptionAtTime,\n    19→  formatDuration,\n    20→  summarizeTimeline,\n    21→  splitIntoSentences,\n    22→  estimateCaptionTimings,\n    23→  scaleCaptionsToAudioDuration,\n    24→  TimelineBuildError,\n    25→} from '../../src/generators/timeline/index.js';\n    26→import type { TalkTrackV5 } from '../../src/parsers/types.js';\n    27→import type {\n    28→  AudioManifest,\n    29→  AudioManifestEntry,\n    30→  Timeline,\n    31→  TimelineSlide,\n    32→} from '../../src/generators/timeline/types.js';\n    33→\n    34→// Get the directory of this test file\n    35→const __filename = fileURLToPath(import.meta.url);\n    36→const __dirname = dirname(__filename);\n    37→\n    38→// Path to the sample talk track fixture\n    39→const FIXTURE_PATH = join(__dirname, '../fixtures/sample-talk-track.md');\n    40→\n    41→// Test data\n    42→let fixtureContent: string;\n    43→let parsedTalkTrack: TalkTrackV5;\n    44→let mockAudioManifest: AudioManifest;\n    45→let timeline: Timeline;\n    46→\n    47→/**\n    48→ * Creates a mock audio manifest for testing.\n    49→ * Simulates audio generation without actual TTS calls.\n    50→ */\n    51→function createMockAudioManifest(talkTrack: TalkTrackV5): AudioManifest {\n    52→  const entries = new Map<string, AudioManifestEntry>();\n    53→\n    54→  for (const slide of talkTrack.slides) {\n    55→    const content = talkTrack.slideContent.get(slide.slug);\n    56→    if (!content) continue;\n    57→\n    58→    // Estimate duration based on word count (150 WPM = 2.5 words/second)\n    59→    const cleanText = stripSemanticTags(content.audioText);\n    60→    const wordCount = cleanText.split(/\\s+/).filter((w) => w).length;\n    61→    const duration = Math.max(2, wordCount / 2.5); // Minimum 2 seconds\n    62→\n    63→    entries.set(slide.slug, {\n    64→      slug: slide.slug,\n    65→      path: `audio/${slide.slug}.mp3`,\n    66→      duration,\n    67→      provider: 'kokoro',\n    68→    });\n    69→  }\n    70→\n    71→  return {\n    72→    voice: 'af_heart',\n    73→    provider: 'kokoro',\n    74→    entries,\n    75→  };\n    76→}\n    77→\n    78→beforeAll(() => {\n    79→  fixtureContent = readFileSync(FIXTURE_PATH, 'utf-8');\n    80→  parsedTalkTrack = parseTalkTrack(fixtureContent);\n    81→  mockAudioManifest = createMockAudioManifest(parsedTalkTrack);\n    82→  timeline = buildTimeline(parsedTalkTrack, mockAudioManifest);\n    83→});\n    84→\n    85→// -----------------------------------------------------------------------------\n    86→// Timeline Building Tests\n    87→// -----------------------------------------------------------------------------\n    88→\n    89→describe('Timeline Integration: Basic Building', () => {\n    90→  it('should build timeline from talk track and audio manifest', () => {\n    91→    expect(timeline).toBeDefined();\n    92→    expect(timeline.slides).toHaveLength(parsedTalkTrack.slides.length);\n    93→  });\n    94→\n    95→  it('should set default timeline options', () => {\n    96→    expect(timeline.fps).toBe(30);\n    97→    expect(timeline.width).toBe(1920);\n    98→    expect(timeline.height).toBe(1080);\n    99→  });\n   100→\n   101→  it('should respect custom timeline options', () => {\n   102→    const customTimeline = buildTimeline(parsedTalkTrack, mockAudioManifest, {\n   103→      fps: 60,\n   104→      width: 3840,\n   105→      height: 2160,\n   106→      transitionPadding: 0.5,\n   107→    });\n   108→\n   109→    expect(customTimeline.fps).toBe(60);\n   110→    expect(customTimeline.width).toBe(3840);\n   111→    expect(customTimeline.height).toBe(2160);\n   112→  });\n   113→\n   114→  it('should calculate total duration', () => {\n   115→    expect(timeline.totalDuration).toBeGreaterThan(0);\n   116→    // Total should be sum of all slide durations\n   117→    const sumDurations = timeline.slides.reduce((sum, slide) => sum + slide.duration, 0);\n   118→    expect(timeline.totalDuration).toBeCloseTo(sumDurations, 2);\n   119→  });\n   120→});\n   121→\n   122→// -----------------------------------------------------------------------------\n   123→// Slide Timing Tests\n   124→// -----------------------------------------------------------------------------\n   125→\n   126→describe('Timeline Integration: Slide Timing', () => {\n   127→  it('should calculate sequential start times', () => {\n   128→    let expectedStartTime = 0;\n   129→    for (const slide of timeline.slides) {\n   130→      expect(slide.startTime).toBeCloseTo(expectedStartTime, 2);\n   131→      expectedStartTime = slide.endTime;\n   132→    }\n   133→  });\n   134→\n   135→  it('should set end time = start time + duration', () => {\n   136→    for (const slide of timeline.slides) {\n   137→      expect(slide.endTime).toBeCloseTo(slide.startTime + slide.duration, 2);\n   138→    }\n   139→  });\n   140→\n   141→  it('should include transition padding in duration', () => {\n   142→    // Default transition padding is 0.3 seconds\n   143→    for (const slide of timeline.slides) {\n   144→      expect(slide.duration).toBeGreaterThan(slide.audioDuration);\n   145→      expect(slide.duration).toBeCloseTo(slide.audioDuration + 0.3, 2);\n   146→    }\n   147→  });\n   148→\n   149→  it('should preserve slide metadata', () => {\n   150→    const firstSlide = timeline.slides[0];\n   151→    expect(firstSlide.slug).toBe('title-slide');\n   152→    expect(firstSlide.title).toBe('Welcome to AI-Native Dev');\n   153→    expect(firstSlide.section).toBe('opening');\n   154→  });\n   155→\n   156→  it('should include section color from sections definition', () => {\n   157→    const firstSlide = timeline.slides[0];\n   158→    expect(firstSlide.sectionColor).toBe('#557373'); // Opening section color\n   159→  });\n   160→\n   161→  it('should include audio path and duration', () => {\n   162→    for (const slide of timeline.slides) {\n   163→      expect(slide.audioPath).toMatch(/^audio\\/.+\\.mp3$/);\n   164→      expect(slide.audioDuration).toBeGreaterThan(0);\n   165→    }\n   166→  });\n   167→});\n   168→\n   169→// -----------------------------------------------------------------------------\n   170→// Caption Sync Tests\n   171→// -----------------------------------------------------------------------------\n   172→\n   173→describe('Timeline Integration: Caption Sync', () => {\n   174→  it('should generate captions for each slide', () => {\n   175→    for (const slide of timeline.slides) {\n   176→      expect(slide.captions).toBeDefined();\n   177→      expect(Array.isArray(slide.captions)).toBe(true);\n   178→    }\n   179→  });\n   180→\n   181→  it('should have captions with proper timing', () => {\n   182→    const slideWithCaptions = timeline.slides.find((s) => s.captions.length > 0);\n   183→    expect(slideWithCaptions).toBeDefined();\n   184→\n   185→    if (slideWithCaptions) {\n   186→      for (const caption of slideWithCaptions.captions) {\n   187→        expect(caption.startTime).toBeDefined();\n   188→        expect(caption.endTime).toBeDefined();\n   189→        expect(caption.endTime).toBeGreaterThan(caption.startTime);\n   190→        expect(caption.text).toBeTruthy();\n   191→      }\n   192→    }\n   193→  });\n   194→\n   195→  it('should have sequential caption timings', () => {\n   196→    for (const slide of timeline.slides) {\n   197→      let lastEndTime = 0;\n   198→      for (const caption of slide.captions) {\n   199→        expect(caption.startTime).toBeGreaterThanOrEqual(lastEndTime - 0.01); // Allow tiny overlap\n   200→        lastEndTime = caption.endTime;\n   201→      }\n   202→    }\n   203→  });\n   204→\n   205→  it('should scale captions to match audio duration', () => {\n   206→    for (const slide of timeline.slides) {\n   207→      if (slide.captions.length > 0) {\n   208→        const lastCaption = slide.captions[slide.captions.length - 1];\n   209→        // Caption end time should be close to audio duration\n   210→        expect(lastCaption.endTime).toBeLessThanOrEqual(slide.audioDuration + 0.5);\n   211→      }\n   212→    }\n   213→  });\n   214→});\n   215→\n   216→// -----------------------------------------------------------------------------\n   217→// Caption Utility Tests\n   218→// -----------------------------------------------------------------------------\n   219→\n   220→describe('Timeline Integration: Caption Utilities', () => {\n   221→  it('splitIntoSentences should split on sentence boundaries', () => {\n   222→    const text = 'Hello world. How are you? I am fine!';\n   223→    const sentences = splitIntoSentences(text);\n   224→\n   225→    expect(sentences).toHaveLength(3);\n   226→    expect(sentences[0]).toBe('Hello world.');\n   227→    expect(sentences[1]).toBe('How are you?');\n   228→    expect(sentences[2]).toBe('I am fine!');\n   229→  });\n   230→\n   231→  it('splitIntoSentences should handle empty text', () => {\n   232→    expect(splitIntoSentences('')).toEqual([]);\n   233→    expect(splitIntoSentences('   ')).toEqual([]);\n   234→  });\n   235→\n   236→  it('splitIntoSentences should normalize whitespace', () => {\n   237→    const text = 'Hello   world.    How are   you?';\n   238→    const sentences = splitIntoSentences(text);\n   239→\n   240→    expect(sentences[0]).toBe('Hello world.');\n   241→    expect(sentences[1]).toBe('How are you?');\n   242→  });\n   243→\n   244→  it('estimateCaptionTimings should create timed captions', () => {\n   245→    const text = 'First sentence. Second sentence.';\n   246→    const captions = estimateCaptionTimings(text, 0);\n   247→\n   248→    expect(captions).toHaveLength(2);\n   249→    expect(captions[0].text).toBe('First sentence.');\n   250→    expect(captions[0].startTime).toBe(0);\n   251→    expect(captions[1].startTime).toBeGreaterThan(captions[0].endTime - 0.01);\n   252→  });\n   253→\n   254→  it('estimateCaptionTimings should respect start offset', () => {\n   255→    const text = 'A sentence.';\n   256→    const captions = estimateCaptionTimings(text, 5.0);\n   257→\n   258→    expect(captions[0].startTime).toBeGreaterThanOrEqual(5.0);\n   259→  });\n   260→\n   261→  it('scaleCaptionsToAudioDuration should scale to target duration', () => {\n   262→    const captions = estimateCaptionTimings('First. Second. Third.', 0);\n   263→    const originalDuration = captions[captions.length - 1].endTime;\n   264→\n   265→    const targetDuration = 10;\n   266→    const scaled = scaleCaptionsToAudioDuration(captions, targetDuration);\n   267→\n   268→    const scaledDuration = scaled[scaled.length - 1].endTime;\n   269→    expect(scaledDuration).toBeCloseTo(targetDuration, 1);\n   270→  });\n   271→});\n   272→\n   273→// -----------------------------------------------------------------------------\n   274→// Timeline Query Functions Tests\n   275→// -----------------------------------------------------------------------------\n   276→\n   277→describe('Timeline Integration: Query Functions', () => {\n   278→  it('calculateTotalFrames should return correct frame count', () => {\n   279→    const frames = calculateTotalFrames(timeline);\n   280→    const expectedFrames = Math.ceil(timeline.totalDuration * timeline.fps);\n   281→    expect(frames).toBe(expectedFrames);\n   282→  });\n   283→\n   284→  it('getSlideAtTime should return correct slide', () => {\n   285→    const firstSlide = timeline.slides[0];\n   286→    const slide = getSlideAtTime(timeline, firstSlide.startTime + 0.5);\n   287→\n   288→    expect(slide).toBeDefined();\n   289→    expect(slide?.slug).toBe(firstSlide.slug);\n   290→  });\n   291→\n   292→  it('getSlideAtTime should return undefined for time past end', () => {\n   293→    const slide = getSlideAtTime(timeline, timeline.totalDuration + 10);\n   294→    expect(slide).toBeUndefined();\n   295→  });\n   296→\n   297→  it('getSlideAtFrame should return correct slide', () => {\n   298→    const firstSlide = timeline.slides[0];\n   299→    const frameInFirstSlide = Math.floor((firstSlide.startTime + 0.5) * timeline.fps);\n   300→    const slide = getSlideAtFrame(timeline, frameInFirstSlide);\n   301→\n   302→    expect(slide).toBeDefined();\n   303→    expect(slide?.slug).toBe(firstSlide.slug);\n   304→  });\n   305→\n   306→  it('getCaptionAtTime should return active caption', () => {\n   307→    const slideWithCaptions = timeline.slides.find((s) => s.captions.length > 0);\n   308→    if (!slideWithCaptions) return;\n   309→\n   310→    const firstCaption = slideWithCaptions.captions[0];\n   311→    const absoluteTime = slideWithCaptions.startTime + firstCaption.startTime + 0.1;\n   312→    const caption = getCaptionAtTime(slideWithCaptions, absoluteTime);\n   313→\n   314→    expect(caption).toBeDefined();\n   315→    expect(caption?.text).toBe(firstCaption.text);\n   316→  });\n   317→\n   318→  it('getCaptionAtTime should return undefined when no caption active', () => {\n   319→    const slideWithCaptions = timeline.slides.find((s) => s.captions.length > 0);\n   320→    if (!slideWithCaptions) return;\n   321→\n   322→    // Query time after all captions\n   323→    const lastCaption = slideWithCaptions.captions[slideWithCaptions.captions.length - 1];\n   324→    const timeAfterCaptions = slideWithCaptions.startTime + lastCaption.endTime + 10;\n   325→    const caption = getCaptionAtTime(slideWithCaptions, timeAfterCaptions);\n   326→\n   327→    expect(caption).toBeUndefined();\n   328→  });\n   329→});\n   330→\n   331→// -----------------------------------------------------------------------------\n   332→// Formatting Functions Tests\n   333→// -----------------------------------------------------------------------------\n   334→\n   335→describe('Timeline Integration: Formatting', () => {\n   336→  it('formatDuration should format seconds as MM:SS', () => {\n   337→    expect(formatDuration(0)).toBe('0:00');\n   338→    expect(formatDuration(30)).toBe('0:30');\n   339→    expect(formatDuration(60)).toBe('1:00');\n   340→    expect(formatDuration(90)).toBe('1:30');\n   341→    expect(formatDuration(125)).toBe('2:05');\n   342→  });\n   343→\n   344→  it('formatDuration should format hours as HH:MM:SS', () => {\n   345→    expect(formatDuration(3600)).toBe('1:00:00');\n   346→    expect(formatDuration(3661)).toBe('1:01:01');\n   347→    expect(formatDuration(7200)).toBe('2:00:00');\n   348→  });\n   349→\n   350→  it('summarizeTimeline should return readable summary', () => {\n   351→    const summary = summarizeTimeline(timeline);\n   352→\n   353→    expect(summary).toContain('Timeline Summary');\n   354→    expect(summary).toContain(`${timeline.width}x${timeline.height}`);\n   355→    expect(summary).toContain(`${timeline.fps}fps`);\n   356→    expect(summary).toContain(`Total Slides: ${timeline.slides.length}`);\n   357→    expect(summary).toContain('title-slide');\n   358→  });\n   359→});\n   360→\n   361→// -----------------------------------------------------------------------------\n   362→// Error Handling Tests\n   363→// -----------------------------------------------------------------------------\n   364→\n   365→describe('Timeline Integration: Error Handling', () => {\n   366→  it('should throw TimelineBuildError for missing slide content', () => {\n   367→    const invalidManifest: AudioManifest = {\n   368→      voice: 'af_heart',\n   369→      provider: 'kokoro',\n   370→      entries: new Map([\n   371→        ['nonexistent-slide', {\n   372→          slug: 'nonexistent-slide',\n   373→          path: 'audio/test.mp3',\n   374→          duration: 5,\n   375→          provider: 'kokoro',\n   376→        }],\n   377→      ]),\n   378→    };\n   379→\n   380→    // Create a talk track with mismatched content\n   381→    const modifiedTalkTrack = { ...parsedTalkTrack };\n   382→    modifiedTalkTrack.slides = [\n   383→      {\n   384→        position: '1',\n   385→        slug: 'missing-content',\n   386→        title: 'Missing',\n   387→        image: 'missing.png',\n   388→        section: 'opening',\n   389→      },\n   390→    ];\n   391→\n   392→    expect(() => buildTimeline(modifiedTalkTrack, invalidManifest)).toThrow(TimelineBuildError);\n   393→  });\n   394→\n   395→  it('should throw TimelineBuildError for missing audio entry', () => {\n   396→    const emptyManifest: AudioManifest = {\n   397→      voice: 'af_heart',\n   398→      provider: 'kokoro',\n   399→      entries: new Map(),\n   400→    };\n   401→\n   402→    expect(() => buildTimeline(parsedTalkTrack, emptyManifest)).toThrow(TimelineBuildError);\n   403→  });\n   404→});\n   405→\n   406→// -----------------------------------------------------------------------------\n   407→// Complex Scenario Tests\n   408→// -----------------------------------------------------------------------------\n   409→\n   410→describe('Timeline Integration: Complex Scenarios', () => {\n   411→  it('should handle talk track with varying slide durations', () => {\n   412→    // Slides should have different durations based on audio length\n   413→    const durations = timeline.slides.map((s) => s.audioDuration);\n   414→    const uniqueDurations = new Set(durations.map((d) => Math.round(d * 10) / 10));\n   415→\n   416→    // With different word counts, we expect different durations\n   417→    expect(uniqueDurations.size).toBeGreaterThan(1);\n   418→  });\n   419→\n   420→  it('should correctly sequence all slides', () => {\n   421→    let previousEndTime = 0;\n   422→    for (let i = 0; i < timeline.slides.length; i++) {\n   423→      const slide = timeline.slides[i];\n   424→      expect(slide.startTime).toBeCloseTo(previousEndTime, 2);\n   425→      previousEndTime = slide.endTime;\n   426→    }\n   427→    expect(timeline.totalDuration).toBeCloseTo(previousEndTime, 2);\n   428→  });\n   429→\n   430→  it('should maintain section color consistency', () => {\n   431→    const problemSlides = timeline.slides.filter((s) => s.section === 'problem');\n   432→    const colors = new Set(problemSlides.map((s) => s.sectionColor));\n   433→\n   434→    // All problem slides should have the same section color\n   435→    expect(colors.size).toBe(1);\n   436→    expect(problemSlides[0].sectionColor).toBe('#6B4C4C');\n   437→  });\n   438→});\n   439→"}]},"parent_tool_use_id":"toolu_01NSueNmmedTxDHb613XuvtJ","session_id":"fae97709-6dbb-4c53-abde-6088a81b1e30","uuid":"64ffcca2-3cce-4ea3-859e-7b84faf17e2b"}
