{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PjeGXm9FrFBA8kxoS77RV6","type":"tool_result","content":"     1→/**\n     2→ * Caption Synchronization\n     3→ *\n     4→ * Utilities for aligning captions with audio timing.\n     5→ * Handles both word-level timing (ElevenLabs) and estimation (Kokoro).\n     6→ */\n     7→\n     8→import type { Caption, WordTiming } from './types.js';\n     9→\n    10→/**\n    11→ * Default speaking rate in words per minute for estimation.\n    12→ * 150 WPM is a comfortable, clear speaking pace.\n    13→ */\n    14→const DEFAULT_WPM = 150;\n    15→\n    16→/**\n    17→ * Minimum caption duration in seconds.\n    18→ * Ensures captions are visible long enough to read.\n    19→ */\n    20→const MIN_CAPTION_DURATION = 0.5;\n    21→\n    22→/**\n    23→ * Maximum caption length in characters.\n    24→ * Longer sentences are split for readability.\n    25→ */\n    26→const MAX_CAPTION_LENGTH = 120;\n    27→\n    28→/**\n    29→ * Splits text into sentences for captioning.\n    30→ * Handles common sentence-ending punctuation and edge cases.\n    31→ *\n    32→ * @param text - Raw text to split into sentences\n    33→ * @returns Array of sentence strings\n    34→ *\n    35→ * @example\n    36→ * ```typescript\n    37→ * const sentences = splitIntoSentences(\"Hello world. How are you? I'm fine!\");\n    38→ * // [\"Hello world.\", \"How are you?\", \"I'm fine!\"]\n    39→ * ```\n    40→ */\n    41→export function splitIntoSentences(text: string): string[] {\n    42→  if (!text || !text.trim()) {\n    43→    return [];\n    44→  }\n    45→\n    46→  // Normalize whitespace\n    47→  const normalized = text.replace(/\\s+/g, ' ').trim();\n    48→\n    49→  // Split on sentence-ending punctuation, keeping the punctuation\n    50→  // Handles: . ! ? and their combinations with quotes/parentheses\n    51→  const sentencePattern = /[^.!?]*[.!?]+(?:\\s+|$)|[^.!?]+$/g;\n    52→  const rawSentences = normalized.match(sentencePattern) || [];\n    53→\n    54→  const sentences: string[] = [];\n    55→\n    56→  for (const raw of rawSentences) {\n    57→    const sentence = raw.trim();\n    58→    if (!sentence) continue;\n    59→\n    60→    // If sentence is too long, split on clauses\n    61→    if (sentence.length > MAX_CAPTION_LENGTH) {\n    62→      const clauses = splitOnClauses(sentence);\n    63→      sentences.push(...clauses);\n    64→    } else {\n    65→      sentences.push(sentence);\n    66→    }\n    67→  }\n    68→\n    69→  return sentences;\n    70→}\n    71→\n    72→/**\n    73→ * Splits a long sentence into smaller clauses.\n    74→ * Uses comma, semicolon, colon, and conjunctions as break points.\n    75→ */\n    76→function splitOnClauses(sentence: string): string[] {\n    77→  // Try splitting on common clause delimiters\n    78→  const clausePattern = /[,;:]\\s+|\\s+(?:and|but|or|because|although|while|when|if)\\s+/i;\n    79→\n    80→  if (!clausePattern.test(sentence)) {\n    81→    // No good split points - just return as is\n    82→    return [sentence];\n    83→  }\n    84→\n    85→  const parts: string[] = [];\n    86→  let remaining = sentence;\n    87→  let currentPart = '';\n    88→\n    89→  // Split while trying to keep parts under max length\n    90→  const words = sentence.split(/\\s+/);\n    91→  for (const word of words) {\n    92→    const test = currentPart ? `${currentPart} ${word}` : word;\n    93→\n    94→    if (test.length > MAX_CAPTION_LENGTH && currentPart) {\n    95→      parts.push(currentPart.trim());\n    96→      currentPart = word;\n    97→    } else {\n    98→      currentPart = test;\n    99→    }\n   100→  }\n   101→\n   102→  if (currentPart.trim()) {\n   103→    parts.push(currentPart.trim());\n   104→  }\n   105→\n   106→  return parts.filter((p) => p.length > 0);\n   107→}\n   108→\n   109→/**\n   110→ * Aligns captions to audio using word-level timing from ElevenLabs.\n   111→ * Creates caption segments that match sentence boundaries.\n   112→ *\n   113→ * @param text - Original text that was spoken\n   114→ * @param wordTimings - Word-level timing data from TTS provider\n   115→ * @returns Array of aligned captions\n   116→ *\n   117→ * @example\n   118→ * ```typescript\n   119→ * const captions = alignCaptionsToAudio(\n   120→ *   \"Hello world. How are you?\",\n   121→ *   [\n   122→ *     { word: \"Hello\", start: 0.0, end: 0.3 },\n   123→ *     { word: \"world.\", start: 0.4, end: 0.7 },\n   124→ *     { word: \"How\", start: 0.9, end: 1.1 },\n   125→ *     { word: \"are\", start: 1.2, end: 1.3 },\n   126→ *     { word: \"you?\", start: 1.4, end: 1.7 },\n   127→ *   ]\n   128→ * );\n   129→ * ```\n   130→ */\n   131→export function alignCaptionsToAudio(text: string, wordTimings: WordTiming[]): Caption[] {\n   132→  if (!wordTimings || wordTimings.length === 0) {\n   133→    // Fall back to estimation if no timings\n   134→    return estimateCaptionTimings(text, 0);\n   135→  }\n   136→\n   137→  const sentences = splitIntoSentences(text);\n   138→  if (sentences.length === 0) {\n   139→    return [];\n   140→  }\n   141→\n   142→  const captions: Caption[] = [];\n   143→  let timingIndex = 0;\n   144→\n   145→  for (const sentence of sentences) {\n   146→    const sentenceWords = sentence.split(/\\s+/).filter((w) => w);\n   147→    const captionWords: WordTiming[] = [];\n   148→    let startTime: number | null = null;\n   149→    let endTime = 0;\n   150→\n   151→    // Match words in sentence to word timings\n   152→    for (const sentenceWord of sentenceWords) {\n   153→      // Find matching word timing (fuzzy match to handle punctuation)\n   154→      const normalizedSentenceWord = normalizeWord(sentenceWord);\n   155→\n   156→      while (timingIndex < wordTimings.length) {\n   157→        const timing = wordTimings[timingIndex];\n   158→        const normalizedTimingWord = normalizeWord(timing.word);\n   159→\n   160→        if (normalizedTimingWord === normalizedSentenceWord ||\n   161→            normalizedTimingWord.includes(normalizedSentenceWord) ||\n   162→            normalizedSentenceWord.includes(normalizedTimingWord)) {\n   163→          if (startTime === null) {\n   164→            startTime = timing.start;\n   165→          }\n   166→          endTime = timing.end;\n   167→          captionWords.push({\n   168→            word: sentenceWord,\n   169→            start: timing.start,\n   170→            end: timing.end,\n   171→          });\n   172→          timingIndex++;\n   173→          break;\n   174→        }\n   175→\n   176→        timingIndex++;\n   177→      }\n   178→    }\n   179→\n   180→    // Create caption if we found timing data\n   181→    if (startTime !== null) {\n   182→      captions.push({\n   183→        text: sentence,\n   184→        startTime,\n   185→        endTime,\n   186→        words: captionWords,\n   187→      });\n   188→    }\n   189→  }\n   190→\n   191→  return captions;\n   192→}\n   193→\n   194→/**\n   195→ * Normalizes a word for fuzzy matching.\n   196→ * Removes punctuation and converts to lowercase.\n   197→ */\n   198→function normalizeWord(word: string): string {\n   199→  return word.toLowerCase().replace(/[^\\w]/g, '');\n   200→}\n   201→\n   202→/**\n   203→ * Estimates caption timings when word-level timing is unavailable.\n   204→ * Uses a fixed words-per-minute rate for estimation.\n   205→ *\n   206→ * @param text - Text to create captions for\n   207→ * @param startOffset - Starting time offset in seconds\n   208→ * @param wpm - Words per minute rate (default: 150)\n   209→ * @returns Array of estimated captions\n   210→ *\n   211→ * @example\n   212→ * ```typescript\n   213→ * // For Kokoro TTS which doesn't provide word timings\n   214→ * const captions = estimateCaptionTimings(\"Hello world. How are you?\", 0);\n   215→ * ```\n   216→ */\n   217→export function estimateCaptionTimings(\n   218→  text: string,\n   219→  startOffset: number = 0,\n   220→  wpm: number = DEFAULT_WPM,\n   221→): Caption[] {\n   222→  const sentences = splitIntoSentences(text);\n   223→  if (sentences.length === 0) {\n   224→    return [];\n   225→  }\n   226→\n   227→  const captions: Caption[] = [];\n   228→  let currentTime = startOffset;\n   229→\n   230→  // Seconds per word\n   231→  const secondsPerWord = 60 / wpm;\n   232→\n   233→  for (const sentence of sentences) {\n   234→    const wordCount = sentence.split(/\\s+/).filter((w) => w).length;\n   235→    const duration = Math.max(wordCount * secondsPerWord, MIN_CAPTION_DURATION);\n   236→\n   237→    captions.push({\n   238→      text: sentence,\n   239→      startTime: currentTime,\n   240→      endTime: currentTime + duration,\n   241→      // No word timings for estimated captions\n   242→    });\n   243→\n   244→    currentTime += duration;\n   245→  }\n   246→\n   247→  return captions;\n   248→}\n   249→\n   250→/**\n   251→ * Adjusts caption timings to fit within a specified duration.\n   252→ * Scales all timings proportionally to match the actual audio duration.\n   253→ *\n   254→ * @param captions - Original captions with estimated or actual timings\n   255→ * @param targetDuration - Actual audio duration in seconds\n   256→ * @returns Captions with adjusted timings\n   257→ */\n   258→export function scaleCaptionsToAudioDuration(\n   259→  captions: Caption[],\n   260→  targetDuration: number,\n   261→): Caption[] {\n   262→  if (captions.length === 0 || targetDuration <= 0) {\n   263→    return captions;\n   264→  }\n   265→\n   266→  // Calculate current total duration\n   267→  const lastCaption = captions[captions.length - 1];\n   268→  const currentDuration = lastCaption.endTime;\n   269→\n   270→  if (currentDuration <= 0) {\n   271→    return captions;\n   272→  }\n   273→\n   274→  // Calculate scale factor\n   275→  const scale = targetDuration / currentDuration;\n   276→\n   277→  return captions.map((caption) => ({\n   278→    ...caption,\n   279→    startTime: caption.startTime * scale,\n   280→    endTime: caption.endTime * scale,\n   281→    words: caption.words?.map((word) => ({\n   282→      ...word,\n   283→      start: word.start * scale,\n   284→      end: word.end * scale,\n   285→    })),\n   286→  }));\n   287→}\n   288→"}]},"parent_tool_use_id":"toolu_01NSueNmmedTxDHb613XuvtJ","session_id":"fae97709-6dbb-4c53-abde-6088a81b1e30","uuid":"a9f20554-2b99-459f-8b95-387619f842a7"}
