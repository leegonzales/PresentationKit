{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cjb2HHDqbo4HrWPGMmQnZE","type":"tool_result","content":"     1→/**\n     2→ * Timeline Builder\n     3→ *\n     4→ * Generates presentation timelines by synchronizing slides with audio\n     5→ * and captions. The timeline is used by video renderers to create\n     6→ * properly timed presentations.\n     7→ */\n     8→\n     9→import type { TalkTrackV5, SlideDefinition, Section } from '../../parsers/types.js';\n    10→import type {\n    11→  Timeline,\n    12→  TimelineSlide,\n    13→  TimelineOptions,\n    14→  AudioManifest,\n    15→  AudioManifestEntry,\n    16→  Caption,\n    17→  WordTiming,\n    18→} from './types.js';\n    19→import {\n    20→  alignCaptionsToAudio,\n    21→  estimateCaptionTimings,\n    22→  scaleCaptionsToAudioDuration,\n    23→} from './caption-sync.js';\n    24→import { stripSemanticTags } from '../../parsers/talk-track.js';\n    25→\n    26→// Re-export types\n    27→export type {\n    28→  Timeline,\n    29→  TimelineSlide,\n    30→  TimelineOptions,\n    31→  AudioManifest,\n    32→  AudioManifestEntry,\n    33→  Caption,\n    34→  WordTiming,\n    35→} from './types.js';\n    36→\n    37→// Re-export caption utilities\n    38→export {\n    39→  splitIntoSentences,\n    40→  alignCaptionsToAudio,\n    41→  estimateCaptionTimings,\n    42→  scaleCaptionsToAudioDuration,\n    43→} from './caption-sync.js';\n    44→\n    45→/**\n    46→ * Default timeline options.\n    47→ */\n    48→const DEFAULT_OPTIONS: Required<TimelineOptions> = {\n    49→  fps: 30,\n    50→  width: 1920,\n    51→  height: 1080,\n    52→  transitionPadding: 0.3,\n    53→};\n    54→\n    55→/**\n    56→ * Error thrown when timeline building fails.\n    57→ */\n    58→export class TimelineBuildError extends Error {\n    59→  constructor(\n    60→    message: string,\n    61→    public readonly errors: string[] = [],\n    62→  ) {\n    63→    super(message);\n    64→    this.name = 'TimelineBuildError';\n    65→  }\n    66→}\n    67→\n    68→/**\n    69→ * Builds a complete presentation timeline from talk track and audio manifest.\n    70→ *\n    71→ * The timeline synchronizes:\n    72→ * - Slide images with their display durations\n    73→ * - Audio playback with slide transitions\n    74→ * - Captions with audio (word-level if available)\n    75→ *\n    76→ * @param talkTrack - Parsed Talk Track v5 document\n    77→ * @param audioManifest - Generated audio manifest with durations\n    78→ * @param options - Timeline options (fps, dimensions, transition padding)\n    79→ * @returns Complete timeline for video rendering\n    80→ *\n    81→ * @example\n    82→ * ```typescript\n    83→ * import { parseTalkTrack } from '../parsers/talk-track.js';\n    84→ * import { buildTimeline } from '../generators/timeline/index.js';\n    85→ *\n    86→ * const talkTrack = parseTalkTrack(markdownContent);\n    87→ * const audioManifest = await generateAudio(talkTrack);\n    88→ *\n    89→ * const timeline = buildTimeline(talkTrack, audioManifest, {\n    90→ *   fps: 30,\n    91→ *   width: 1920,\n    92→ *   height: 1080,\n    93→ *   transitionPadding: 0.3,\n    94→ * });\n    95→ *\n    96→ * console.log(`Total duration: ${timeline.totalDuration}s`);\n    97→ * console.log(`Slides: ${timeline.slides.length}`);\n    98→ * ```\n    99→ */\n   100→export function buildTimeline(\n   101→  talkTrack: TalkTrackV5,\n   102→  audioManifest: AudioManifest,\n   103→  options?: TimelineOptions,\n   104→): Timeline {\n   105→  const opts = { ...DEFAULT_OPTIONS, ...options };\n   106→  const errors: string[] = [];\n   107→\n   108→  // Build section color lookup\n   109→  const sectionColors = new Map<string, string>();\n   110→  for (const section of talkTrack.sections) {\n   111→    sectionColors.set(section.id, section.color);\n   112→  }\n   113→\n   114→  // Build timeline slides\n   115→  const timelineSlides: TimelineSlide[] = [];\n   116→  let currentTime = 0;\n   117→\n   118→  for (const slideDef of talkTrack.slides) {\n   119→    const slideContent = talkTrack.slideContent.get(slideDef.slug);\n   120→    const audioEntry = audioManifest.entries.get(slideDef.slug);\n   121→\n   122→    // Validate required data\n   123→    if (!slideContent) {\n   124→      errors.push(`Missing slide content for slug: ${slideDef.slug}`);\n   125→      continue;\n   126→    }\n   127→\n   128→    if (!audioEntry) {\n   129→      errors.push(`Missing audio entry for slug: ${slideDef.slug}`);\n   130→      continue;\n   131→    }\n   132→\n   133→    // Get section color\n   134→    const sectionColor = sectionColors.get(slideDef.section) || '#666666';\n   135→\n   136→    // Calculate slide timing\n   137→    const audioDuration = audioEntry.duration;\n   138→    const slideDuration = audioDuration + opts.transitionPadding;\n   139→    const startTime = currentTime;\n   140→    const endTime = currentTime + slideDuration;\n   141→\n   142→    // Generate captions\n   143→    const cleanAudioText = stripSemanticTags(slideContent.audioText);\n   144→    const captions = buildCaptions(cleanAudioText, audioEntry);\n   145→\n   146→    // Create timeline slide entry\n   147→    const timelineSlide: TimelineSlide = {\n   148→      slug: slideDef.slug,\n   149→      title: slideDef.title,\n   150→      section: slideDef.section,\n   151→      sectionColor,\n   152→      startTime,\n   153→      endTime,\n   154→      duration: slideDuration,\n   155→      imagePath: slideContent.imagePath,\n   156→      audioPath: audioEntry.path,\n   157→      audioDuration,\n   158→      captions,\n   159→    };\n   160→\n   161→    timelineSlides.push(timelineSlide);\n   162→    currentTime = endTime;\n   163→  }\n   164→\n   165→  if (errors.length > 0) {\n   166→    throw new TimelineBuildError('Timeline build failed', errors);\n   167→  }\n   168→\n   169→  // Calculate total duration\n   170→  const totalDuration = timelineSlides.length > 0\n   171→    ? timelineSlides[timelineSlides.length - 1].endTime\n   172→    : 0;\n   173→\n   174→  return {\n   175→    fps: opts.fps,\n   176→    width: opts.width,\n   177→    height: opts.height,\n   178→    totalDuration,\n   179→    slides: timelineSlides,\n   180→  };\n   181→}\n   182→\n   183→/**\n   184→ * Builds captions directly from word timings (Whisper transcription).\n   185→ * Groups words into sentence-like segments based on punctuation.\n   186→ */\n   187→function buildCaptionsFromWordTimings(wordTimings: WordTiming[]): Caption[] {\n   188→  const captions: Caption[] = [];\n   189→  let currentWords: WordTiming[] = [];\n   190→  let sentenceStart = 0;\n   191→\n   192→  for (let i = 0; i < wordTimings.length; i++) {\n   193→    const word = wordTimings[i];\n   194→    currentWords.push(word);\n   195→\n   196→    // Check if this word ends a sentence (ends with . ! ?)\n   197→    const endsWithPunctuation = /[.!?]$/.test(word.word);\n   198→    const isLastWord = i === wordTimings.length - 1;\n   199→\n   200→    // Create caption if sentence ends or we have enough words (max ~15 words per caption)\n   201→    if (endsWithPunctuation || isLastWord || currentWords.length >= 15) {\n   202→      if (currentWords.length > 0) {\n   203→        const text = currentWords.map(w => w.word).join(' ');\n   204→        captions.push({\n   205→          text,\n   206→          startTime: sentenceStart,\n   207→          endTime: word.end,\n   208→          words: currentWords.map(w => ({\n   209→            word: w.word,\n   210→            start: w.start,\n   211→            end: w.end,\n   212→          })),\n   213→        });\n   214→\n   215→        // Reset for next sentence\n   216→        currentWords = [];\n   217→        sentenceStart = word.end;\n   218→      }\n   219→    }\n   220→  }\n   221→\n   222→  return captions;\n   223→}\n   224→\n   225→/**\n   226→ * Builds captions for a slide, using word timings if available.\n   227→ * Returns empty array if no word timings - Kokoro without Whisper gets no captions.\n   228→ */\n   229→function buildCaptions(text: string, audioEntry: AudioManifestEntry): Caption[] {\n   230→  if (audioEntry.wordTimings && audioEntry.wordTimings.length > 0) {\n   231→    // Use Whisper word timings directly - don't try to align with original text\n   232→    return buildCaptionsFromWordTimings(audioEntry.wordTimings);\n   233→  }\n   234→\n   235→  // No word timings (Kokoro without Whisper) - skip captions entirely\n   236→  return [];\n   237→}\n   238→\n   239→/**\n   240→ * Calculates the total frame count for a timeline.\n   241→ *\n   242→ * @param timeline - The timeline to calculate frames for\n   243→ * @returns Total number of frames\n   244→ */\n   245→export function calculateTotalFrames(timeline: Timeline): number {\n   246→  return Math.ceil(timeline.totalDuration * timeline.fps);\n   247→}\n   248→\n   249→/**\n   250→ * Gets the slide visible at a specific time.\n   251→ *\n   252→ * @param timeline - The timeline to search\n   253→ * @param time - Time in seconds from video start\n   254→ * @returns The slide at that time, or undefined if past end\n   255→ */\n   256→export function getSlideAtTime(timeline: Timeline, time: number): TimelineSlide | undefined {\n   257→  return timeline.slides.find(\n   258→    (slide) => time >= slide.startTime && time < slide.endTime,\n   259→  );\n   260→}\n   261→\n   262→/**\n   263→ * Gets the slide visible at a specific frame.\n   264→ *\n   265→ * @param timeline - The timeline to search\n   266→ * @param frame - Frame number (0-indexed)\n   267→ * @returns The slide at that frame, or undefined if past end\n   268→ */\n   269→export function getSlideAtFrame(timeline: Timeline, frame: number): TimelineSlide | undefined {\n   270→  const time = frame / timeline.fps;\n   271→  return getSlideAtTime(timeline, time);\n   272→}\n   273→\n   274→/**\n   275→ * Gets the active caption at a specific time within a slide.\n   276→ *\n   277→ * @param slide - The timeline slide\n   278→ * @param time - Time in seconds from video start\n   279→ * @returns The active caption, or undefined if none\n   280→ */\n   281→export function getCaptionAtTime(slide: TimelineSlide, time: number): Caption | undefined {\n   282→  // Convert absolute time to slide-relative time\n   283→  const relativeTime = time - slide.startTime;\n   284→\n   285→  return slide.captions.find(\n   286→    (caption) => relativeTime >= caption.startTime && relativeTime < caption.endTime,\n   287→  );\n   288→}\n   289→\n   290→/**\n   291→ * Formats a duration in seconds as MM:SS or HH:MM:SS.\n   292→ *\n   293→ * @param seconds - Duration in seconds\n   294→ * @returns Formatted duration string\n   295→ */\n   296→export function formatDuration(seconds: number): string {\n   297→  const hours = Math.floor(seconds / 3600);\n   298→  const minutes = Math.floor((seconds % 3600) / 60);\n   299→  const secs = Math.floor(seconds % 60);\n   300→\n   301→  if (hours > 0) {\n   302→    return `${hours}:${minutes.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;\n   303→  }\n   304→\n   305→  return `${minutes}:${secs.toString().padStart(2, '0')}`;\n   306→}\n   307→\n   308→/**\n   309→ * Generates a timeline summary for debugging/display.\n   310→ *\n   311→ * @param timeline - The timeline to summarize\n   312→ * @returns Human-readable summary string\n   313→ */\n   314→export function summarizeTimeline(timeline: Timeline): string {\n   315→  const lines: string[] = [\n   316→    `Timeline Summary`,\n   317→    `================`,\n   318→    `Resolution: ${timeline.width}x${timeline.height} @ ${timeline.fps}fps`,\n   319→    `Total Duration: ${formatDuration(timeline.totalDuration)}`,\n   320→    `Total Slides: ${timeline.slides.length}`,\n   321→    `Total Frames: ${calculateTotalFrames(timeline)}`,\n   322→    ``,\n   323→    `Slides:`,\n   324→  ];\n   325→\n   326→  for (const slide of timeline.slides) {\n   327→    const start = formatDuration(slide.startTime);\n   328→    const end = formatDuration(slide.endTime);\n   329→    lines.push(`  ${slide.slug}: ${start} - ${end} (${slide.duration.toFixed(1)}s)`);\n   330→  }\n   331→\n   332→  return lines.join('\\n');\n   333→}\n   334→"}]},"parent_tool_use_id":"toolu_01NSueNmmedTxDHb613XuvtJ","session_id":"fae97709-6dbb-4c53-abde-6088a81b1e30","uuid":"441fdbe5-0d00-4c9a-bee7-936a3e75d1c6"}
