{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UbS8riF7nXB1egAgqhv1jg","type":"tool_result","content":"     1→/**\n     2→ * Talk Track v5 Parser Tests\n     3→ */\n     4→\n     5→import { describe, it, expect } from 'vitest';\n     6→import {\n     7→  parseTalkTrack,\n     8→  safeParseTalkTrack,\n     9→  validateTalkTrack,\n    10→  stripSemanticTags,\n    11→  TalkTrackParseError,\n    12→} from '../src/parsers/talk-track.js';\n    13→import {\n    14→  validateSlug,\n    15→  validateSection,\n    16→  validateImagePath,\n    17→  validateHexColor,\n    18→  findDuplicateSlugs,\n    19→} from '../src/parsers/validators.js';\n    20→\n    21→// -----------------------------------------------------------------------------\n    22→// Sample Talk Track Content\n    23→// -----------------------------------------------------------------------------\n    24→\n    25→const VALID_TALK_TRACK = `---\n    26→version: 5\n    27→title: \"Test Presentation\"\n    28→subtitle: \"A Subtitle\"\n    29→author: \"Test Author\"\n    30→event: \"Test Event\"\n    31→date: \"2026-01-21\"\n    32→target_minutes: 30\n    33→audio_voice: \"af_heart\"\n    34→\n    35→sections:\n    36→  - id: opening\n    37→    name: \"Opening\"\n    38→    color: \"#557373\"\n    39→  - id: main\n    40→    name: \"Main Content\"\n    41→    color: \"#6B4C4C\"\n    42→---\n    43→\n    44→## Slides\n    45→\n    46→| # | Slug | Title | Image | Section |\n    47→|---|------|-------|-------|---------|\n    48→| 1 | title | Title Slide | slide-title.png | opening |\n    49→| 2 | intro | Introduction | slide-intro.png | opening |\n    50→| 3 | content | Main Content | slide-content.png | main |\n    51→\n    52→## [title] Title Slide\n    53→\n    54→![Title](images/slide-title.png)\n    55→\n    56→<!-- AUDIO -->\n    57→[HOOK] Welcome to my presentation.\n    58→\n    59→This is the opening slide.\n    60→<!-- /AUDIO -->\n    61→\n    62→**Speaker Notes:**\n    63→Remember to smile.\n    64→\n    65→---\n    66→\n    67→## [intro] Introduction\n    68→\n    69→![Intro](images/slide-intro.png)\n    70→\n    71→<!-- AUDIO -->\n    72→Let me introduce the topic.\n    73→\n    74→[KEY_POINT] The key insight is this.\n    75→\n    76→[PAUSE:500]\n    77→\n    78→Now let's continue.\n    79→<!-- /AUDIO -->\n    80→\n    81→---\n    82→\n    83→## [content] Main Content\n    84→\n    85→![Content](images/slide-content.png)\n    86→\n    87→<!-- AUDIO -->\n    88→[TRANSITION] Moving on to the main content.\n    89→\n    90→[EVIDENCE] Studies show this is true.\n    91→\n    92→Here's the explanation.\n    93→<!-- /AUDIO -->\n    94→\n    95→**Speaker Notes:**\n    96→- Point one\n    97→- Point two\n    98→`;\n    99→\n   100→const MINIMAL_TALK_TRACK = `---\n   101→version: 5\n   102→title: \"Minimal\"\n   103→author: \"Author\"\n   104→target_minutes: 10\n   105→\n   106→sections:\n   107→  - id: main\n   108→    name: \"Main\"\n   109→    color: \"#000000\"\n   110→---\n   111→\n   112→## Slides\n   113→\n   114→| # | Slug | Title | Image | Section |\n   115→|---|------|-------|-------|---------|\n   116→| 1 | slide1 | First | slide.png | main |\n   117→\n   118→## [slide1] First\n   119→\n   120→![First](images/slide.png)\n   121→\n   122→<!-- AUDIO -->\n   123→Content here.\n   124→<!-- /AUDIO -->\n   125→`;\n   126→\n   127→// -----------------------------------------------------------------------------\n   128→// Validator Tests\n   129→// -----------------------------------------------------------------------------\n   130→\n   131→describe('validators', () => {\n   132→  describe('validateSlug', () => {\n   133→    it('accepts valid slugs', () => {\n   134→      expect(validateSlug('title')).toBe(true);\n   135→      expect(validateSlug('my-slide')).toBe(true);\n   136→      expect(validateSlug('slide1')).toBe(true);\n   137→      expect(validateSlug('a1b2c3')).toBe(true);\n   138→      expect(validateSlug('intro-section-1')).toBe(true);\n   139→    });\n   140→\n   141→    it('rejects invalid slugs', () => {\n   142→      expect(validateSlug('MySlide')).toBe(false);\n   143→      expect(validateSlug('my_slide')).toBe(false);\n   144→      expect(validateSlug('1slide')).toBe(false);\n   145→      expect(validateSlug('-slide')).toBe(false);\n   146→      expect(validateSlug('slide-')).toBe(false);\n   147→      expect(validateSlug('')).toBe(false);\n   148→    });\n   149→  });\n   150→\n   151→  describe('validateSection', () => {\n   152→    const sections = [\n   153→      { id: 'opening', name: 'Opening', color: '#000' },\n   154→      { id: 'main', name: 'Main', color: '#fff' },\n   155→    ];\n   156→\n   157→    it('accepts valid sections', () => {\n   158→      expect(validateSection('opening', sections)).toBe(true);\n   159→      expect(validateSection('main', sections)).toBe(true);\n   160→    });\n   161→\n   162→    it('rejects unknown sections', () => {\n   163→      expect(validateSection('unknown', sections)).toBe(false);\n   164→      expect(validateSection('', sections)).toBe(false);\n   165→    });\n   166→  });\n   167→\n   168→  describe('validateImagePath', () => {\n   169→    it('accepts valid image paths', () => {\n   170→      expect(validateImagePath('slide.png')).toBe(true);\n   171→      expect(validateImagePath('images/slide.jpg')).toBe(true);\n   172→      expect(validateImagePath('path/to/image.webp')).toBe(true);\n   173→    });\n   174→\n   175→    it('rejects invalid paths', () => {\n   176→      expect(validateImagePath('/absolute/path.png')).toBe(false);\n   177→      expect(validateImagePath('file.txt')).toBe(false);\n   178→      expect(validateImagePath('')).toBe(false);\n   179→    });\n   180→  });\n   181→\n   182→  describe('validateHexColor', () => {\n   183→    it('accepts valid hex colors', () => {\n   184→      expect(validateHexColor('#000')).toBe(true);\n   185→      expect(validateHexColor('#fff')).toBe(true);\n   186→      expect(validateHexColor('#000000')).toBe(true);\n   187→      expect(validateHexColor('#FFFFFF')).toBe(true);\n   188→      expect(validateHexColor('#557373')).toBe(true);\n   189→    });\n   190→\n   191→    it('rejects invalid colors', () => {\n   192→      expect(validateHexColor('000000')).toBe(false);\n   193→      expect(validateHexColor('#00')).toBe(false);\n   194→      expect(validateHexColor('#0000000')).toBe(false);\n   195→      expect(validateHexColor('red')).toBe(false);\n   196→    });\n   197→  });\n   198→\n   199→  describe('findDuplicateSlugs', () => {\n   200→    it('finds duplicates', () => {\n   201→      expect(findDuplicateSlugs(['a', 'b', 'a', 'c'])).toEqual(['a']);\n   202→      expect(findDuplicateSlugs(['a', 'a', 'a'])).toEqual(['a']);\n   203→      expect(findDuplicateSlugs(['a', 'b', 'a', 'b'])).toEqual(['a', 'b']);\n   204→    });\n   205→\n   206→    it('returns empty for unique slugs', () => {\n   207→      expect(findDuplicateSlugs(['a', 'b', 'c'])).toEqual([]);\n   208→      expect(findDuplicateSlugs([])).toEqual([]);\n   209→    });\n   210→  });\n   211→});\n   212→\n   213→// -----------------------------------------------------------------------------\n   214→// Parser Tests\n   215→// -----------------------------------------------------------------------------\n   216→\n   217→describe('parseTalkTrack', () => {\n   218→  it('parses valid talk track', () => {\n   219→    const result = parseTalkTrack(VALID_TALK_TRACK);\n   220→\n   221→    expect(result.version).toBe(5);\n   222→    expect(result.title).toBe('Test Presentation');\n   223→    expect(result.subtitle).toBe('A Subtitle');\n   224→    expect(result.author).toBe('Test Author');\n   225→    expect(result.event).toBe('Test Event');\n   226→    expect(result.date).toBe('2026-01-21');\n   227→    expect(result.targetMinutes).toBe(30);\n   228→    expect(result.audioVoice).toBe('af_heart');\n   229→  });\n   230→\n   231→  it('parses sections correctly', () => {\n   232→    const result = parseTalkTrack(VALID_TALK_TRACK);\n   233→\n   234→    expect(result.sections).toHaveLength(2);\n   235→    expect(result.sections[0]).toEqual({\n   236→      id: 'opening',\n   237→      name: 'Opening',\n   238→      color: '#557373',\n   239→    });\n   240→  });\n   241→\n   242→  it('parses slides table correctly', () => {\n   243→    const result = parseTalkTrack(VALID_TALK_TRACK);\n   244→\n   245→    expect(result.slides).toHaveLength(3);\n   246→    expect(result.slides[0]).toEqual({\n   247→      position: '1',\n   248→      slug: 'title',\n   249→      title: 'Title Slide',\n   250→      image: 'slide-title.png',\n   251→      section: 'opening',\n   252→    });\n   253→  });\n   254→\n   255→  it('parses slide content correctly', () => {\n   256→    const result = parseTalkTrack(VALID_TALK_TRACK);\n   257→\n   258→    expect(result.slideContent.size).toBe(3);\n   259→\n   260→    const titleSlide = result.slideContent.get('title');\n   261→    expect(titleSlide).toBeDefined();\n   262→    expect(titleSlide?.slug).toBe('title');\n   263→    expect(titleSlide?.title).toBe('Title Slide');\n   264→    expect(titleSlide?.audioText).toContain('Welcome to my presentation');\n   265→    expect(titleSlide?.speakerNotes).toContain('Remember to smile');\n   266→  });\n   267→\n   268→  it('parses semantic tags correctly', () => {\n   269→    const result = parseTalkTrack(VALID_TALK_TRACK);\n   270→\n   271→    const introSlide = result.slideContent.get('intro');\n   272→    expect(introSlide?.semanticTags).toContainEqual(\n   273→      expect.objectContaining({ type: 'KEY_POINT' }),\n   274→    );\n   275→    expect(introSlide?.semanticTags).toContainEqual(\n   276→      expect.objectContaining({ type: 'PAUSE', duration: 500 }),\n   277→    );\n   278→  });\n   279→\n   280→  it('parses minimal talk track', () => {\n   281→    const result = parseTalkTrack(MINIMAL_TALK_TRACK);\n   282→\n   283→    expect(result.version).toBe(5);\n   284→    expect(result.title).toBe('Minimal');\n   285→    expect(result.audioVoice).toBe('af_heart'); // Default\n   286→    expect(result.slides).toHaveLength(1);\n   287→  });\n   288→\n   289→  it('throws on missing frontmatter', () => {\n   290→    expect(() => parseTalkTrack('No frontmatter here')).toThrow(TalkTrackParseError);\n   291→  });\n   292→\n   293→  it('throws on wrong version', () => {\n   294→    const content = MINIMAL_TALK_TRACK.replace('version: 5', 'version: 4');\n   295→    expect(() => parseTalkTrack(content)).toThrow(TalkTrackParseError);\n   296→  });\n   297→});\n   298→\n   299→describe('safeParseTalkTrack', () => {\n   300→  it('returns success for valid content', () => {\n   301→    const result = safeParseTalkTrack(VALID_TALK_TRACK);\n   302→\n   303→    expect(result.success).toBe(true);\n   304→    expect(result.data).toBeDefined();\n   305→    expect(result.errors).toBeUndefined();\n   306→  });\n   307→\n   308→  it('returns errors for invalid content', () => {\n   309→    const result = safeParseTalkTrack('Invalid content');\n   310→\n   311→    expect(result.success).toBe(false);\n   312→    expect(result.data).toBeUndefined();\n   313→    expect(result.errors).toBeDefined();\n   314→    expect(result.errors?.length).toBeGreaterThan(0);\n   315→  });\n   316→});\n   317→\n   318→describe('stripSemanticTags', () => {\n   319→  it('removes all semantic tags', () => {\n   320→    const input = '[HOOK] Hello world. [PAUSE] [KEY_POINT] Important. [PAUSE:500]';\n   321→    const result = stripSemanticTags(input);\n   322→\n   323→    expect(result).not.toContain('[HOOK]');\n   324→    expect(result).not.toContain('[PAUSE]');\n   325→    expect(result).not.toContain('[KEY_POINT]');\n   326→    expect(result).not.toContain('[PAUSE:500]');\n   327→    expect(result).toContain('Hello world');\n   328→    expect(result).toContain('Important');\n   329→  });\n   330→});\n   331→\n   332→describe('validateTalkTrack', () => {\n   333→  it('returns empty array for valid content', () => {\n   334→    const errors = validateTalkTrack(VALID_TALK_TRACK);\n   335→    expect(errors).toEqual([]);\n   336→  });\n   337→\n   338→  it('returns errors for invalid content', () => {\n   339→    const errors = validateTalkTrack('Invalid');\n   340→    expect(errors.length).toBeGreaterThan(0);\n   341→  });\n   342→});\n   343→"}]},"parent_tool_use_id":"toolu_01Hv4DasBDFoVNnhH6QmfxmU","session_id":"fae97709-6dbb-4c53-abde-6088a81b1e30","uuid":"bcfebd33-96dd-466f-9e5d-9d7725ed6c82"}
