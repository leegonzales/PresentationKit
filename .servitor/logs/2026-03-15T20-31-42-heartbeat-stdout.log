{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CpUzrpd7rRcvoZcAqkeQRE","type":"tool_result","content":"     1→/**\n     2→ * HTML Presentation Renderer\n     3→ *\n     4→ * Generates interactive HTML presentations from Talk Track v5 documents.\n     5→ * Output is a self-contained HTML file with embedded CSS and JavaScript.\n     6→ *\n     7→ * Features:\n     8→ * - Full-screen slide display with keyboard navigation\n     9→ * - Speaker notes toggle (N key)\n    10→ * - Timer display with warnings (T key to toggle)\n    11→ * - Progress bar and slide counter\n    12→ * - Audio playback per slide (if audio exists)\n    13→ * - Section indicator with color theming\n    14→ * - Touch/swipe support for mobile\n    15→ * - Print to PDF support (P key)\n    16→ * - Help overlay (H or ? key)\n    17→ *\n    18→ * @example\n    19→ * ```typescript\n    20→ * import { renderHtmlPresentation } from './renderers/html/index.js';\n    21→ * import { parseTalkTrack } from './parsers/talk-track.js';\n    22→ * import { readFileSync } from 'fs';\n    23→ *\n    24→ * const content = readFileSync('talk-track.md', 'utf-8');\n    25→ * const talkTrack = parseTalkTrack(content);\n    26→ *\n    27→ * // Without audio (timeline is null)\n    28→ * await renderHtmlPresentation(talkTrack, null, './output/presentation.html');\n    29→ *\n    30→ * // With audio timeline\n    31→ * await renderHtmlPresentation(talkTrack, timeline, './output/presentation.html', {\n    32→ *   primaryColor: '#2563eb',\n    33→ * });\n    34→ * ```\n    35→ */\n    36→\n    37→import { writeFile, mkdir } from 'fs/promises';\n    38→import { dirname } from 'path';\n    39→import type { TalkTrackV5, Section } from '../../parsers/types.js';\n    40→import type { Timeline } from '../../generators/timeline/types.js';\n    41→import type {\n    42→  HtmlOptions,\n    43→  PreparedHtmlSlide,\n    44→  PreparedHtmlMetadata,\n    45→  SectionInfo,\n    46→} from './types.js';\n    47→import { DEFAULT_HTML_OPTIONS } from './types.js';\n    48→import { generateHtmlPresentation } from './template.js';\n    49→import {\n    50→  stripSemanticTags,\n    51→  getSectionColor,\n    52→  getSectionName,\n    53→  formatDate,\n    54→} from './utils.js';\n    55→import { resolveTheme, applyImageSuffix } from '../../themes/index.js';\n    56→\n    57→// Re-export types for convenience\n    58→export type {\n    59→  HtmlOptions,\n    60→  PreparedHtmlSlide,\n    61→  PreparedHtmlMetadata,\n    62→  SectionInfo,\n    63→} from './types.js';\n    64→export { DEFAULT_HTML_OPTIONS } from './types.js';\n    65→\n    66→// Re-export standalone renderer\n    67→export {\n    68→  renderStandaloneHtml,\n    69→  type StandaloneHtmlOptions,\n    70→} from './standalone.js';\n    71→\n    72→\n    73→/**\n    74→ * Prepares slide data for rendering.\n    75→ *\n    76→ * @param talkTrack - Parsed Talk Track v5 document\n    77→ * @param timeline - Timeline with audio data (null if no audio)\n    78→ * @param options - Rendering options\n    79→ * @returns Array of prepared slide data\n    80→ */\n    81→function prepareSlides(\n    82→  talkTrack: TalkTrackV5,\n    83→  timeline: Timeline | null,\n    84→  options: Required<HtmlOptions>,\n    85→): PreparedHtmlSlide[] {\n    86→  const slides: PreparedHtmlSlide[] = [];\n    87→\n    88→  // Resolve theme suffix once before the loop\n    89→  const themeSuffix = options.theme\n    90→    ? (resolveTheme(options.theme)?.imageSuffix || '')\n    91→    : '';\n    92→\n    93→  for (const slideDef of talkTrack.slides) {\n    94→    const content = talkTrack.slideContent.get(slideDef.slug);\n    95→\n    96→    // Get timeline data if available\n    97→    const timelineSlide = timeline?.slides.find((s) => s.slug === slideDef.slug);\n    98→\n    99→    // Determine audio path and duration\n   100→    let audioPath: string | null = null;\n   101→    let audioDuration = 0;\n   102→\n   103→    if (timelineSlide?.audioPath) {\n   104→      audioPath = timelineSlide.audioPath;\n   105→      audioDuration = timelineSlide.audioDuration;\n   106→    }\n   107→\n   108→    // Get section info\n   109→    const sectionColor = getSectionColor(\n   110→      slideDef.section,\n   111→      talkTrack.sections,\n   112→      options.primaryColor,\n   113→    );\n   114→\n   115→    // Prepare speaker notes\n   116→    let speakerNotes: string | undefined;\n   117→    if (content?.audioText) {\n   118→      speakerNotes = stripSemanticTags(content.audioText);\n   119→    }\n   120→    // Append additional speaker notes if present\n   121→    if (content?.speakerNotes) {\n   122→      speakerNotes = speakerNotes\n   123→        ? `${speakerNotes}\\n\\n${content.speakerNotes}`\n   124→        : content.speakerNotes;\n   125→    }\n   126→\n   127→    const isAppendix =\n   128→      slideDef.section.toLowerCase() === 'appendix' ||\n   129→      slideDef.position.toUpperCase().startsWith('A');\n   130→\n   131→    slides.push({\n   132→      position: slideDef.position,\n   133→      slug: slideDef.slug,\n   134→      title: slideDef.title,\n   135→      imagePath: options.imageBasePath + applyImageSuffix(slideDef.image, themeSuffix),\n   136→      section: getSectionName(slideDef.section, talkTrack.sections),\n   137→      sectionColor,\n   138→      audioPath: audioPath ? options.audioBasePath + audioPath.split('/').pop() : null,\n   139→      audioDuration,\n   140→      speakerNotes,\n   141→      speaker: content?.speaker,\n   142→      isAppendix,\n   143→    });\n   144→  }\n   145→\n   146→  return slides;\n   147→}\n   148→\n   149→/**\n   150→ * Extracts section information from prepared slides.\n   151→ *\n   152→ * @param slides - Prepared slide data\n   153→ * @param talkTrackSections - Section definitions from TalkTrack\n   154→ * @returns Array of section info with slide indices\n   155→ */\n   156→function extractSections(\n   157→  slides: PreparedHtmlSlide[],\n   158→  talkTrackSections: Section[],\n   159→): SectionInfo[] {\n   160→  const sections: SectionInfo[] = [];\n   161→  let currentSection = '';\n   162→  let currentStartIndex = 0;\n   163→  let currentCount = 0;\n   164→\n   165→  for (let i = 0; i < slides.length; i++) {\n   166→    const slide = slides[i];\n   167→\n   168→    if (slide.section !== currentSection) {\n   169→      // Save previous section if exists\n   170→      if (currentSection && currentCount > 0) {\n   171→        const sectionDef = talkTrackSections.find(\n   172→          (s) => s.name === currentSection || s.id === currentSection,\n   173→        );\n   174→        sections.push({\n   175→          id: sectionDef?.id ?? currentSection.toLowerCase().replace(/\\s+/g, '-'),\n   176→          name: currentSection,\n   177→          color: slides[currentStartIndex].sectionColor,\n   178→          startIndex: currentStartIndex,\n   179→          slideCount: currentCount,\n   180→        });\n   181→      }\n   182→\n   183→      // Start new section\n   184→      currentSection = slide.section;\n   185→      currentStartIndex = i;\n   186→      currentCount = 1;\n   187→    } else {\n   188→      currentCount++;\n   189→    }\n   190→  }\n   191→\n   192→  // Save last section\n   193→  if (currentSection && currentCount > 0) {\n   194→    const sectionDef = talkTrackSections.find(\n   195→      (s) => s.name === currentSection || s.id === currentSection,\n   196→    );\n   197→    sections.push({\n   198→      id: sectionDef?.id ?? currentSection.toLowerCase().replace(/\\s+/g, '-'),\n   199→      name: currentSection,\n   200→      color: slides[currentStartIndex].sectionColor,\n   201→      startIndex: currentStartIndex,\n   202→      slideCount: currentCount,\n   203→    });\n   204→  }\n   205→\n   206→  return sections;\n   207→}\n   208→\n   209→/**\n   210→ * Prepares presentation metadata for rendering.\n   211→ *\n   212→ * @param talkTrack - Parsed Talk Track v5 document\n   213→ * @param slides - Prepared slide data\n   214→ * @param timeline - Timeline data (null if no audio)\n   215→ * @returns Prepared metadata object\n   216→ */\n   217→function prepareMetadata(\n   218→  talkTrack: TalkTrackV5,\n   219→  slides: PreparedHtmlSlide[],\n   220→  timeline: Timeline | null,\n   221→): PreparedHtmlMetadata {\n   222→  const totalAudioDuration = timeline?.totalDuration ?? 0;\n   223→\n   224→  return {\n   225→    title: talkTrack.title,\n   226→    subtitle: talkTrack.subtitle,\n   227→    author: talkTrack.author,\n   228→    event: talkTrack.event,\n   229→    dateFormatted: formatDate(talkTrack.date),\n   230→    totalSlides: slides.length,\n   231→    targetMinutes: talkTrack.targetMinutes,\n   232→    totalAudioDuration,\n   233→    generatedAt: new Date().toLocaleString('en-US', {\n   234→      year: 'numeric',\n   235→      month: 'long',\n   236→      day: 'numeric',\n   237→      hour: 'numeric',\n   238→      minute: '2-digit',\n   239→      hour12: true,\n   240→    }),\n   241→  };\n   242→}\n   243→\n   244→/**\n   245→ * Merges user options with defaults and branding from TalkTrack.\n   246→ *\n   247→ * @param talkTrack - Parsed Talk Track v5 document\n   248→ * @param options - User-provided options\n   249→ * @returns Merged options with all fields populated\n   250→ */\n   251→function mergeOptions(\n   252→  talkTrack: TalkTrackV5,\n   253→  options?: HtmlOptions,\n   254→): Required<HtmlOptions> {\n   255→  const branding = talkTrack.branding ?? {};\n   256→\n   257→  // Resolve theme if specified (CLI option or branding config)\n   258→  const themeName = options?.theme || branding.imageTheme || '';\n   259→  const theme = themeName ? resolveTheme(themeName) : undefined;\n   260→\n   261→  return {\n   262→    ...DEFAULT_HTML_OPTIONS,\n   263→    // Color precedence: user options > branding > theme > defaults\n   264→    primaryColor: options?.primaryColor ?? branding.primary ?? theme?.primaryColor ?? DEFAULT_HTML_OPTIONS.primaryColor,\n   265→    backgroundColor: options?.backgroundColor ?? branding.background ?? theme?.backgroundColor ?? DEFAULT_HTML_OPTIONS.backgroundColor,\n   266→    textColor: options?.textColor ?? branding.text ?? theme?.textColor ?? DEFAULT_HTML_OPTIONS.textColor,\n   267→    targetMinutes: talkTrack.targetMinutes,\n   268→    theme: themeName,\n   269→    // Speaker precedence: user options > frontmatter > default (false)\n   270→    showSpeakers: options?.showSpeakers ?? talkTrack.showSpeakers ?? DEFAULT_HTML_OPTIONS.showSpeakers,\n   271→    ...options,\n   272→  };\n   273→}\n   274→\n   275→/**\n   276→ * Renders an interactive HTML presentation from a Talk Track v5 document.\n   277→ *\n   278→ * @param talkTrack - Parsed Talk Track v5 document\n   279→ * @param timeline - Timeline with audio data (null if no audio generated)\n   280→ * @param outputPath - Path to write the HTML file\n   281→ * @param options - Optional rendering configuration\n   282→ * @throws Error if writing fails\n   283→ *\n   284→ * @example\n   285→ * ```typescript\n   286→ * import { renderHtmlPresentation } from './renderers/html/index.js';\n   287→ *\n   288→ * // Without audio\n   289→ * await renderHtmlPresentation(talkTrack, null, './output/presentation.html');\n   290→ *\n   291→ * // With audio timeline\n   292→ * await renderHtmlPresentation(talkTrack, timeline, './output/presentation.html', {\n   293→ *   primaryColor: '#2563eb',\n   294→ *   showProgressBar: true,\n   295→ * });\n   296→ * ```\n   297→ */\n   298→export async function renderHtmlPresentation(\n   299→  talkTrack: TalkTrackV5,\n   300→  timeline: Timeline | null,\n   301→  outputPath: string,\n   302→  options?: HtmlOptions,\n   303→): Promise<void> {\n   304→  const opts = mergeOptions(talkTrack, options);\n   305→\n   306→  // Prepare data\n   307→  const slides = prepareSlides(talkTrack, timeline, opts);\n   308→  const sections = extractSections(slides, talkTrack.sections);\n   309→  const metadata = prepareMetadata(talkTrack, slides, timeline);\n   310→\n   311→  // Generate HTML\n   312→  const html = generateHtmlPresentation(metadata, slides, sections, opts);\n   313→\n   314→  // Ensure output directory exists\n   315→  const outputDir = dirname(outputPath);\n   316→  await mkdir(outputDir, { recursive: true });\n   317→\n   318→  // Write file\n   319→  await writeFile(outputPath, html, 'utf-8');\n   320→}\n   321→\n   322→/**\n   323→ * Generates HTML presentation as a string without writing to disk.\n   324→ * Useful for preview or streaming scenarios.\n   325→ *\n   326→ * @param talkTrack - Parsed Talk Track v5 document\n   327→ * @param timeline - Timeline with audio data (null if no audio)\n   328→ * @param options - Optional rendering configuration\n   329→ * @returns HTML string\n   330→ */\n   331→export function renderHtmlPresentationToString(\n   332→  talkTrack: TalkTrackV5,\n   333→  timeline: Timeline | null,\n   334→  options?: HtmlOptions,\n   335→): string {\n   336→  const opts = mergeOptions(talkTrack, options);\n   337→\n   338→  const slides = prepareSlides(talkTrack, timeline, opts);\n   339→  const sections = extractSections(slides, talkTrack.sections);\n   340→  const metadata = prepareMetadata(talkTrack, slides, timeline);\n   341→\n   342→  return generateHtmlPresentation(metadata, slides, sections, opts);\n   343→}\n   344→\n   345→/**\n   346→ * Gets summary statistics for the HTML presentation.\n   347→ * Useful for CLI output or validation.\n   348→ *\n   349→ * @param talkTrack - Parsed Talk Track v5 document\n   350→ * @param timeline - Timeline with audio data (null if no audio)\n   351→ * @returns Summary statistics\n   352→ */\n   353→export function getHtmlPresentationSummary(\n   354→  talkTrack: TalkTrackV5,\n   355→  timeline: Timeline | null,\n   356→): {\n   357→  title: string;\n   358→  slideCount: number;\n   359→  mainSlideCount: number;\n   360→  appendixSlideCount: number;\n   361→  sectionCount: number;\n   362→  hasAudio: boolean;\n   363→  totalAudioDuration: number;\n   364→  targetMinutes: number;\n   365→} {\n   366→  const opts = mergeOptions(talkTrack, {});\n   367→  const slides = prepareSlides(talkTrack, timeline, opts);\n   368→  const sections = extractSections(slides, talkTrack.sections);\n   369→\n   370→  const mainSlides = slides.filter((s) => !s.isAppendix);\n   371→  const appendixSlides = slides.filter((s) => s.isAppendix);\n   372→  const hasAudio = slides.some((s) => s.audioPath !== null);\n   373→  const totalAudioDuration = timeline?.totalDuration ?? 0;\n   374→\n   375→  return {\n   376→    title: talkTrack.title,\n   377→    slideCount: slides.length,\n   378→    mainSlideCount: mainSlides.length,\n   379→    appendixSlideCount: appendixSlides.length,\n   380→    sectionCount: sections.length,\n   381→    hasAudio,\n   382→    totalAudioDuration,\n   383→    targetMinutes: talkTrack.targetMinutes,\n   384→  };\n   385→}\n   386→"}]},"parent_tool_use_id":"toolu_01CxjStoqz4pfoTiMxyQouKJ","session_id":"fae97709-6dbb-4c53-abde-6088a81b1e30","uuid":"000b74cc-ef50-415e-98d9-58a89e493a8a"}
