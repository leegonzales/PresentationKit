{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011pd3m41vcwYBkNAnZpUuLz","type":"tool_result","content":"     1→/**\n     2→ * Timeline Types\n     3→ *\n     4→ * Type definitions for the presentation timeline that synchronizes\n     5→ * slides, audio, and captions for video rendering.\n     6→ */\n     7→\n     8→/**\n     9→ * Word-level timing information from TTS providers like ElevenLabs.\n    10→ */\n    11→export interface WordTiming {\n    12→  /** The word text */\n    13→  word: string;\n    14→  /** Start time in seconds relative to slide audio start */\n    15→  start: number;\n    16→  /** End time in seconds relative to slide audio start */\n    17→  end: number;\n    18→}\n    19→\n    20→/**\n    21→ * Caption segment with timing information.\n    22→ * Represents a sentence or phrase to display as a caption.\n    23→ */\n    24→export interface Caption {\n    25→  /** Caption text (typically a sentence or phrase) */\n    26→  text: string;\n    27→  /** Start time in seconds relative to slide start */\n    28→  startTime: number;\n    29→  /** End time in seconds relative to slide start */\n    30→  endTime: number;\n    31→  /** Word-level timings for animated captions (optional) */\n    32→  words?: WordTiming[];\n    33→}\n    34→\n    35→/**\n    36→ * Timeline data for a single slide.\n    37→ */\n    38→export interface TimelineSlide {\n    39→  /** Unique slide identifier */\n    40→  slug: string;"}]},"parent_tool_use_id":null,"session_id":"fae97709-6dbb-4c53-abde-6088a81b1e30","uuid":"85b31df4-5b23-4e72-babc-3158d771b969","tool_use_result":{"type":"text","file":{"filePath":"/Users/leegonzales/Projects/leegonzales/PresentationKit/src/generators/timeline/types.ts","content":"/**\n * Timeline Types\n *\n * Type definitions for the presentation timeline that synchronizes\n * slides, audio, and captions for video rendering.\n */\n\n/**\n * Word-level timing information from TTS providers like ElevenLabs.\n */\nexport interface WordTiming {\n  /** The word text */\n  word: string;\n  /** Start time in seconds relative to slide audio start */\n  start: number;\n  /** End time in seconds relative to slide audio start */\n  end: number;\n}\n\n/**\n * Caption segment with timing information.\n * Represents a sentence or phrase to display as a caption.\n */\nexport interface Caption {\n  /** Caption text (typically a sentence or phrase) */\n  text: string;\n  /** Start time in seconds relative to slide start */\n  startTime: number;\n  /** End time in seconds relative to slide start */\n  endTime: number;\n  /** Word-level timings for animated captions (optional) */\n  words?: WordTiming[];\n}\n\n/**\n * Timeline data for a single slide.\n */\nexport interface TimelineSlide {\n  /** Unique slide identifier */\n  slug: string;","numLines":40,"startLine":1,"totalLines":121}}}
