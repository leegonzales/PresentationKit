{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012oCqpJMLjsYxgUy9v5YNdY","type":"tool_result","content":"    75→ */\n    76→function splitOnClauses(sentence: string): string[] {\n    77→  // Try splitting on common clause delimiters\n    78→  const clausePattern = /[,;:]\\s+|\\s+(?:and|but|or|because|although|while|when|if)\\s+/i;\n    79→\n    80→  if (!clausePattern.test(sentence)) {\n    81→    // No good split points - just return as is\n    82→    return [sentence];\n    83→  }\n    84→\n    85→  const parts: string[] = [];\n    86→  let remaining = sentence;\n    87→  let currentPart = '';\n    88→\n    89→  // Split while trying to keep parts under max length\n    90→  const words = sentence.split(/\\s+/);\n    91→  for (const word of words) {\n    92→    const test = currentPart ? `${currentPart} ${word}` : word;\n    93→\n    94→    if (test.length > MAX_CAPTION_LENGTH && currentPart) {\n    95→      parts.push(currentPart.trim());\n    96→      currentPart = word;\n    97→    } else {\n    98→      currentPart = test;\n    99→    }\n   100→  }\n   101→\n   102→  if (currentPart.trim()) {\n   103→    parts.push(currentPart.trim());\n   104→  }\n   105→\n   106→  return parts.filter((p) => p.length > 0);\n   107→}\n   108→\n   109→/**\n   110→ * Aligns captions to audio using word-level timing from ElevenLabs.\n   111→ * Creates caption segments that match sentence boundaries.\n   112→ *\n   113→ * @param text - Original text that was spoken\n   114→ * @param wordTimings - Word-level timing data from TTS provider"}]},"parent_tool_use_id":null,"session_id":"d007eaed-9b6b-48a1-9b64-8f6d3ff16c03","uuid":"163281d0-9e4e-4cd8-8f3d-4f5cd0e09170","tool_use_result":{"type":"text","file":{"filePath":"/Users/leegonzales/Projects/leegonzales/PresentationKit/src/generators/timeline/caption-sync.ts","content":" */\nfunction splitOnClauses(sentence: string): string[] {\n  // Try splitting on common clause delimiters\n  const clausePattern = /[,;:]\\s+|\\s+(?:and|but|or|because|although|while|when|if)\\s+/i;\n\n  if (!clausePattern.test(sentence)) {\n    // No good split points - just return as is\n    return [sentence];\n  }\n\n  const parts: string[] = [];\n  let remaining = sentence;\n  let currentPart = '';\n\n  // Split while trying to keep parts under max length\n  const words = sentence.split(/\\s+/);\n  for (const word of words) {\n    const test = currentPart ? `${currentPart} ${word}` : word;\n\n    if (test.length > MAX_CAPTION_LENGTH && currentPart) {\n      parts.push(currentPart.trim());\n      currentPart = word;\n    } else {\n      currentPart = test;\n    }\n  }\n\n  if (currentPart.trim()) {\n    parts.push(currentPart.trim());\n  }\n\n  return parts.filter((p) => p.length > 0);\n}\n\n/**\n * Aligns captions to audio using word-level timing from ElevenLabs.\n * Creates caption segments that match sentence boundaries.\n *\n * @param text - Original text that was spoken\n * @param wordTimings - Word-level timing data from TTS provider","numLines":40,"startLine":75,"totalLines":288}}}
