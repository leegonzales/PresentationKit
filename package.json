{
  "name": "@leegonzales/presentation-kit",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-native presentation generator from markdown to video",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "pk": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "presentation",
    "video",
    "remotion",
    "ai",
    "tts",
    "elevenlabs"
  ],
  "author": "Lee Gonzales",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.0",
    "got": "^14.4.1",
    "inquirer": "^9.2.23",
    "nanoid": "^5.0.7",
    "ora": "^8.0.1",
    "p-limit": "^6.1.0",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "eslint": "^9.5.0",
    "prettier": "^3.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
